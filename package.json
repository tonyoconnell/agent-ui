{
  "name": "envelope-system",
  "type": "module",
  "version": "1.0.0",
  "workspaces": [
    "cli",
    "packages/sdk",
    "packages/mcp",
    "packages/templates"
  ],
  "scripts": {
    "build:pkgs": "cd packages/sdk && bun run build && cd ../mcp && bun run build && cd ../templates && bun run build && cd ../../cli && bun run build",
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:bench": "PERF_SCALE=1 vitest run src/engine/routing.test.ts",
    "test:live": "LIVE=1 vitest run src/__tests__/live/",
    "check": "biome check .",
    "check:fix": "biome check --fix .",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "typecheck": "bash scripts/typecheck.sh",
    "audit:design": "bun run scripts/audit-design-tokens.ts",
    "verify": "biome check . && bash scripts/typecheck.sh && vitest run && bun run scripts/audit-design-tokens.ts",
    "bootstrap": "bash scripts/bootstrap.sh",
    "seed:tasks": "bun run scripts/seed-tasks.ts",
    "seed:agents": "bun run scripts/seed-agents.ts",
    "deploy": "bun scripts/deploy.ts",
    "tunnel": "cloudflared tunnel --url http://localhost:4321",
    "tunnel:local": "cloudflared tunnel --config ~/.cloudflared/one-local.yml run",
    "tunnel:dev": "cloudflared tunnel --config ~/.cloudflared/one-dev.yml run",
    "tunnel:main": "cloudflared tunnel --config ~/.cloudflared/one-main.yml run",
    "tunnel:list": "cloudflared tunnel list"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.66",
    "@ai-sdk/openai": "^3.0.52",
    "@ai-sdk/openai-compatible": "^2.0.41",
    "@ai-sdk/react": "^3.0.148",
    "@astrojs/cloudflare": "^12.6.9",
    "@astrojs/node": "^9.4.4",
    "@astrojs/react": "^4.4.0",
    "@dagrejs/dagre": "^2.0.4",
    "@mysten/sui": "^1.45.2",
    "@nanostores/react": "^1.1.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.7",
