{
  "name": "envelope-system",
  "type": "module",
  "version": "1.0.0",
  "workspaces": [
    "packages/sdk",
    "packages/cli",
    "packages/mcp",
    "packages/templates"
  ],
  "scripts": {
    "build:pkgs": "cd packages/sdk && bun run build && cd ../cli && bun run build && cd ../mcp && bun run build && cd ../templates && bun run build",
    "postinstall": "bun run build:pkgs",
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:bench": "PERF_SCALE=1 vitest run src/engine/routing.test.ts",
    "test:live": "LIVE=1 vitest run src/__tests__/live/",
    "check": "biome check .",
    "check:fix": "biome check --fix .",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "typecheck": "bash scripts/typecheck.sh",
    "audit:design": "bun run scripts/audit-design-tokens.ts",
    "verify": "biome check . && bash scripts/typecheck.sh && vitest run && bun run scripts/audit-design-tokens.ts",
    "bootstrap": "bash scripts/bootstrap.sh",
    "seed:tasks": "bun run scripts/seed-tasks.ts",
    "seed:agents": "bun run scripts/seed-agents.ts",
    "deploy": "bun scripts/deploy.ts",
    "release": "bun scripts/release.ts",
    "cf-cutover": "bun scripts/cf-cutover.ts",
    "tunnel": "cloudflared tunnel --url http://localhost:4321",
    "tunnel:local": "cloudflared tunnel --config ~/.cloudflared/one-local.yml run",
    "tunnel:main": "cloudflared tunnel --config ~/.cloudflared/one-main.yml run",
    "tunnel:list": "cloudflared tunnel list"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.71",
    "@ai-sdk/openai": "^3.0.53",
    "@ai-sdk/openai-compatible": "^2.0.41",
    "@ai-sdk/react": "^3.0.170",
    "@astrojs/cloudflare": "^13.1.10",
    "@astrojs/node": "^10.0.5",
    "@astrojs/react": "^5.0.3",
    "@dagrejs/dagre": "^3.0.0",
    "@mysten/dapp-kit": "^1.0.4",
    "@mysten/sui": "^2.16.0",
    "@nanostores/react": "^1.1.0",
    "@radix-ui/react-accordion": "^1.2.12",
