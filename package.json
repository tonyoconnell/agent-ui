    "vaul": "^1.1.2",
    "wrangler": "^4.80.0",
    "ws": "^8.20.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@types/node": "^25.5.2",
    "typescript": "5.9.2",
    "vitest": "^4.1.2"
  }
}
