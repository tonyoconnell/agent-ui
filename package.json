    "@types/react-dom": "^19.1.9",
    "@types/ws": "^8.18.1",
    "@xyflow/react": "^12.10.0",
    "ai": "^6.0.146",
    "ai-sdk-provider-claude-code": "^3.4.4",
    "astro": "^5.14.1",
    "better-auth": "^1.5.6",
    "class-variance-authority": "^0.7.1",
