---
export const prerender = true
import Layout from "@/layouts/Layout.astro"

/**
 * Theme colours (bright display variants for dark backgrounds)
 * Primary  — hsl(216 55% 25%) → bright: #7AA3E1 (navy blue family)
 * Secondary— hsl(219 14% 28%) → bright: #8496B8 (cool slate family)
 * Tertiary — hsl(105 22% 25%) → bright: #78B464 (forest green family)
 */
const C = {
  pb: "#7AA3E1",
  pm: "rgba(122,163,225,0.38)",
  pd: "rgba(122,163,225,0.11)",
  sb: "#8496B8",
  sm: "rgba(132,150,184,0.38)",
  sd: "rgba(132,150,184,0.11)",
  tb: "#78B464",
  tm: "rgba(120,180,100,0.38)",
  td: "rgba(120,180,100,0.11)",
}

const tint = {
  p: `background:rgba(20,40,80,0.30);border-color:rgba(122,163,225,0.22)`,
  s: `background:rgba(32,38,52,0.42);border-color:rgba(132,150,184,0.20)`,
  t: `background:rgba(18,40,14,0.30);border-color:rgba(120,180,100,0.22)`,
  pm: `background:rgba(20,40,80,0.28);border-color:${`rgba(122,163,225,0.38)`}`,
}

const icons = {
  fingerprint: `<svg width="44" height="44" viewBox="0 0 44 44" fill="none" aria-hidden="true">
    <circle cx="22" cy="22" r="17" fill="${C.pd}"/>
    <circle cx="22" cy="22" r="1.75" fill="${C.pb}"/>
    <path d="M22 18.5c-1.93 0-3.5 1.57-3.5 3.5 0 3 1.2 5.8 3.5 7.5" stroke="${C.pb}" stroke-width="1.6" stroke-linecap="round"/>
    <path d="M22 15c-3.87 0-7 3.13-7 7 0 5 2.2 9.5 7 11.5" stroke="${C.pm}" stroke-width="1.5" stroke-linecap="round"/>
    <path d="M22 11.5c-5.8 0-10.5 4.7-10.5 10.5 0 7 3.3 13 10.5 15.5" stroke="${C.pm}" stroke-width="1.4" stroke-linecap="round" opacity="0.6"/>
    <path d="M29.5 13A10.48 10.48 0 0 1 32.5 22c0 7-3.3 13-10.5 15.5" stroke="${C.pm}" stroke-width="1.4" stroke-linecap="round" opacity="0.4"/>
  </svg>`,

  fingerprintLg: `<svg width="72" height="72" viewBox="0 0 44 44" fill="none" aria-hidden="true">
    <circle cx="22" cy="22" r="17" fill="${C.pd}"/>
    <circle cx="22" cy="22" r="1.75" fill="${C.pb}"/>
    <path d="M22 18.5c-1.93 0-3.5 1.57-3.5 3.5 0 3 1.2 5.8 3.5 7.5" stroke="${C.pb}" stroke-width="1.6" stroke-linecap="round"/>
    <path d="M22 15c-3.87 0-7 3.13-7 7 0 5 2.2 9.5 7 11.5" stroke="${C.pm}" stroke-width="1.5" stroke-linecap="round"/>
    <path d="M22 11.5c-5.8 0-10.5 4.7-10.5 10.5 0 7 3.3 13 10.5 15.5" stroke="${C.pm}" stroke-width="1.4" stroke-linecap="round" opacity="0.6"/>
    <path d="M29.5 13A10.48 10.48 0 0 1 32.5 22c0 7-3.3 13-10.5 15.5" stroke="${C.pm}" stroke-width="1.4" stroke-linecap="round" opacity="0.4"/>
  </svg>`,

  lock: `<svg width="44" height="44" viewBox="0 0 44 44" fill="none" aria-hidden="true">
    <rect x="9" y="20" width="26" height="17" rx="4" fill="${C.pd}" stroke="${C.pb}" stroke-width="1.6"/>
    <path d="M15 20v-5.5a7 7 0 0 1 14 0V20" stroke="${C.pb}" stroke-width="1.6" stroke-linecap="round"/>
    <circle cx="22" cy="29.5" r="3" fill="${C.pm}"/>
    <path d="M22 29.5v3" stroke="${C.pb}" stroke-width="1.6" stroke-linecap="round"/>
  </svg>`,

  chain: `<svg width="44" height="44" viewBox="0 0 44 44" fill="none" aria-hidden="true">
    <rect x="5" y="16" width="16" height="12" rx="6" fill="${C.td}" stroke="${C.tb}" stroke-width="1.6"/>
    <rect x="23" y="16" width="16" height="12" rx="6" fill="${C.td}" stroke="${C.tb}" stroke-width="1.6"/>
    <path d="M21 22h2" stroke="${C.tb}" stroke-width="2" stroke-linecap="round"/>
    <path d="M11 28.5 9 33M33 28.5l2 4.5" stroke="${C.tm}" stroke-width="1.4" stroke-linecap="round"/>
  </svg>`,

  power: `<svg width="44" height="44" viewBox="0 0 44 44" fill="none" aria-hidden="true">
    <circle cx="22" cy="22" r="14" fill="${C.sd}"/>
    <circle cx="22" cy="22" r="14" stroke="${C.sm}" stroke-width="1.5"/>
    <path d="M15 16.2A11 11 0 1 0 29 16.2" stroke="${C.sb}" stroke-width="1.9" stroke-linecap="round"/>
    <path d="M22 11v10" stroke="${C.sb}" stroke-width="1.9" stroke-linecap="round"/>
  </svg>`,

  scales: `<svg width="44" height="44" viewBox="0 0 44 44" fill="none" aria-hidden="true">
    <ellipse cx="12" cy="28" rx="7" ry="3.5" fill="${C.pd}" stroke="${C.pb}" stroke-width="1.5"/>
    <ellipse cx="32" cy="28" rx="7" ry="3.5" fill="${C.pd}" stroke="${C.pb}" stroke-width="1.5"/>
    <line x1="22" y1="11" x2="22" y2="36" stroke="${C.pm}" stroke-width="1.5" stroke-linecap="round"/>
    <path d="M16 36h12" stroke="${C.pm}" stroke-width="1.5" stroke-linecap="round"/>
    <path d="M7 17l15-6 15 6" stroke="${C.pb}" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
    <path d="M7 17l5 11" stroke="${C.pb}" stroke-width="1.5" stroke-linecap="round"/>
    <path d="M37 17l-5 11" stroke="${C.pb}" stroke-width="1.5" stroke-linecap="round"/>
    <circle cx="22" cy="11" r="2.5" fill="${C.pb}"/>
  </svg>`,

  columns: `<svg width="44" height="44" viewBox="0 0 44 44" fill="none" aria-hidden="true">
    <rect x="7" y="34" width="30" height="3.5" rx="1.75" fill="${C.sd}" stroke="${C.sb}" stroke-width="1.4"/>
    <rect x="7" y="9" width="30" height="4.5" rx="1.75" fill="${C.sd}" stroke="${C.sb}" stroke-width="1.4"/>
    <rect x="10" y="13.5" width="5" height="20.5" rx="2.5" fill="${C.sd}" stroke="${C.sb}" stroke-width="1.4"/>
    <rect x="19.5" y="13.5" width="5" height="20.5" rx="2.5" fill="${C.sm}" stroke="${C.sb}" stroke-width="1.4"/>
    <rect x="29" y="13.5" width="5" height="20.5" rx="2.5" fill="${C.sd}" stroke="${C.sb}" stroke-width="1.4"/>
  </svg>`,

  shield: `<svg width="44" height="44" viewBox="0 0 44 44" fill="none" aria-hidden="true">
    <path d="M22 6L8 12v10c0 9.5 6.2 17.5 14 20 7.8-2.5 14-10.5 14-20V12L22 6z" fill="${C.td}" stroke="${C.tb}" stroke-width="1.6" stroke-linejoin="round"/>
    <path d="M15 22l5 5.5 9-10" stroke="${C.tb}" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>`,

  bars: `<svg width="44" height="44" viewBox="0 0 44 44" fill="none" aria-hidden="true">
    <rect x="7" y="28" width="8" height="8" rx="2" fill="${C.pd}" stroke="${C.pb}" stroke-width="1.5"/>
    <rect x="18" y="20" width="8" height="16" rx="2" fill="${C.pd}" stroke="${C.pb}" stroke-width="1.5" opacity="0.85"/>
    <rect x="29" y="11" width="8" height="25" rx="2" fill="${C.pd}" stroke="${C.pb}" stroke-width="1.5" opacity="0.7"/>
    <circle cx="33" cy="8" r="3" fill="${C.pb}"/>
    <path d="M11 22l10-8 10 5" stroke="${C.pm}" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>`,

  globe: `<svg width="44" height="44" viewBox="0 0 44 44" fill="none" aria-hidden="true">
    <circle cx="22" cy="22" r="15" fill="${C.td}" stroke="${C.tb}" stroke-width="1.6"/>
    <ellipse cx="22" cy="22" rx="6" ry="15" stroke="${C.tm}" stroke-width="1.3"/>
    <path d="M7 22h30" stroke="${C.tm}" stroke-width="1.3"/>
    <path d="M9.5 15h25M9.5 29h25" stroke="${C.tm}" stroke-width="1.1" opacity="0.6"/>
    <circle cx="22" cy="22" r="2.5" fill="${C.tb}"/>
    <path d="M22 19.5v-3.5M22 26v3.5M19.5 22H16M28 22h-3.5" stroke="${C.tb}" stroke-width="1.4" stroke-linecap="round"/>
  </svg>`,

  approve: `<svg width="44" height="44" viewBox="0 0 44 44" fill="none" aria-hidden="true">
    <rect x="7" y="9" width="22" height="28" rx="4" fill="${C.pd}" stroke="${C.pm}" stroke-width="1.5"/>
    <path d="M12 18h12M12 23h9M12 28h6" stroke="${C.pm}" stroke-width="1.4" stroke-linecap="round"/>
    <circle cx="33" cy="31" r="8" fill="rgba(20,40,80,0.80)" stroke="${C.pb}" stroke-width="1.5"/>
    <path d="M29 31l3 3 5-5" stroke="${C.pb}" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>`,

  bell: `<svg width="44" height="44" viewBox="0 0 44 44" fill="none" aria-hidden="true">
    <path d="M22 8c-6.6 0-11 4.9-11 11v8l-3 4h28l-3-4V19c0-6.1-4.4-11-11-11z" fill="${C.sd}" stroke="${C.sb}" stroke-width="1.6" stroke-linejoin="round"/>
    <path d="M19 34a3 3 0 0 0 6 0" stroke="${C.sb}" stroke-width="1.5" stroke-linecap="round"/>
    <circle cx="31" cy="12" r="4.5" fill="${C.pb}"/>
    <path d="M29.5 12h3M31 10.5v3" stroke="rgba(0,0,0,0.5)" stroke-width="1.3" stroke-linecap="round"/>
  </svg>`,
}

const orgRows = [
  { icon: "scales",  family: "p", accent: C.pb, title: "Legal and contracts",
    lead: "Every authorisation is now a provable event, not a disputed claim.",
    body: `A Touch ID signature meets the technical criteria for a qualified electronic signature in most jurisdictions — sole control, uniquely identifies the signer, linked to the signed data, tamper-evident. Board resolutions, financial authorisations, governance actions: each carries a biometric proof that the person was there. Not their device. Not their account. Them.` },
  { icon: "columns", family: "s", accent: C.sb, title: "Governance",
    lead: "Multi-sig extends the biometric root across your leadership team.",
    body: `Require three of five board members to biometrically confirm before a major action executes. No single stolen device, no single coerced person can act alone. Governance gets a physics layer — not because we wrote a policy, but because the cryptography requires it.` },
  { icon: "shield",  family: "t", accent: C.tb, title: "Compliance and audit",
    lead: "Every transaction traces to a biometric authorisation. KYC at the root, not the edge.",
    body: `An auditor follows any payment to the human who set the limits that permitted it. GDPR erasure is a biometrically-signed action with an immutable record. The audit trail lives on the Sui blockchain — we cannot alter it.` },
  { icon: "bars",    family: "p", accent: C.pb, title: "Finance and treasury",
    lead: "An AI agent with treasury access is a liability. A capped, auditable one is an asset.",
    body: `An agent whose spending limit was set with your CEO's biometric signature, whose allowed recipient list was signed by your CFO, and whose pause trigger fires the moment either of them calls it — that is a controlled, legally-grounded instrument. The agent acts. The human remains accountable.` },
  { icon: "globe",   family: "t", accent: C.tb, title: "Government and sovereign",
    lead: "Run your own substrate. We never hold your keys.",
    body: `Your own biometric root, your own key hierarchy, your own database. Every action taken in the system traces to a biometrically-proven person in your organisation. Federation with other agencies requires a biometric handshake from both sides. The audit trail is yours, on-chain, and cannot be altered.` },
]

const howCards = [
  { icon: "fingerprint", accent: C.pb, step: "01", label: "The Secure Enclave", text: "A dedicated security chip inside every Apple device. It generates a private key at manufacture and is physically designed to never let it out — not to the OS, not to apps, not to us. When you touch Touch ID, the chip signs. The key stays inside." },
  { icon: "chain",       accent: C.tb, step: "02", label: "Key derivation",     text: "Touch ID produces a 32-byte hardware-bound secret. From this, every key in your system is derived: your wallet, your API access, your agents' encryption keys. One biometric. All keys. None on our servers." },
  { icon: "lock",        accent: C.pb, step: "03", label: "Spending caps",      text: "When you set an agent's limit, it becomes a Move object on the Sui blockchain — enforced by 100+ validators on every transaction. Not a rule in our database. Not a policy in our code. The blockchain enforces it. We cannot override it." },
  { icon: "shield",      accent: C.tb, step: "04", label: "Recovery",           text: "Twelve words on paper. Written once. If every device is lost, those twelve words reconstruct the same key hierarchy, the same wallet, the same agent limits. No support ticket. No waiting." },
]
---

<Layout
  title="ONE Security — Biometrics prove the human. Blockchain bounds the agent."
  description="For the first time, every digital action in your organisation traces back to a fingerprint. Not a password. Not a token. A human who was physically there."
>
  <main class="mx-auto max-w-4xl px-6 text-white">

    <!-- HERO -->
    <section class="py-20 sm:py-28">
      <p class="text-xs font-mono tracking-widest uppercase mb-6" style={`color:${C.pb}`}>Security</p>
      <h1 class="text-5xl sm:text-7xl font-bold leading-[1.05] tracking-tight mb-7">
        Prove the human.<br />
        <span style={`color:${C.pb}`}>Then trust the agent.</span>
      </h1>
      <p class="text-xl text-zinc-300 max-w-xl leading-relaxed mb-10">
        For the first time, every digital action in your organisation traces back
        to a fingerprint on a chip — not a password, not a token, not a claim.
        A human who was physically there. That changes everything downstream.
      </p>
      <div class="flex gap-3 flex-wrap items-center">
        <a href="/u" class="font-semibold px-7 py-3.5 rounded-lg transition-opacity hover:opacity-90 text-black text-sm" style={`background:${C.pb}`}>
          Open your wallet
        </a>
        <a href="/security/whitepaper" class="text-sm text-zinc-400 hover:text-zinc-200 transition-colors underline underline-offset-4">
          Technical whitepaper →
        </a>
      </div>
    </section>

    <!-- TRUST STATS -->
    <section class="border-y border-white/8 py-8 mb-20">
      <div class="grid sm:grid-cols-3 gap-6 sm:gap-0 sm:divide-x divide-white/8">
        {[
          { icon: icons.fingerprint, stat: "2B+ devices",         sub: "Apple Secure Enclave — the chip your keys live on" },
          { icon: icons.chain,       stat: "100+ validators",      sub: "Independent Sui nodes enforcing every spending cap" },
          { icon: icons.lock,        stat: "Zero keys on servers", sub: "A breach of our systems yields nothing usable" },
        ].map(({ icon, stat, sub }) => (
          <div class="flex items-center gap-4 sm:px-8 first:pl-0 last:pr-0">
            <div class="shrink-0" set:html={icon} />
            <div>
              <p class="text-white font-semibold text-lg leading-tight">{stat}</p>
              <p class="text-zinc-500 text-sm leading-snug mt-0.5">{sub}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- THE SHIFT -->
    <section class="mb-24">
      <h2 class="text-3xl font-bold mb-3">
        Digital identity has been unsolved for fifty years.
      </h2>
      <p class="text-zinc-400 mb-8 max-w-xl leading-relaxed">
        Every system before biometrics is built on a claim. Claims can be wrong.
      </p>

      <div class="overflow-x-auto rounded-2xl border border-white/8 bg-white/2 mb-6">
        <table class="w-full text-sm text-left border-collapse">
          <thead>
            <tr class="border-b border-white/10">
              <th class="px-6 py-4 text-xs font-mono uppercase tracking-widest text-zinc-500 w-1/2">Old model — a claim</th>
              <th class="px-6 py-4 text-xs font-mono uppercase tracking-widest" style={`color:${C.pb}`}>With biometrics — a proof</th>
            </tr>
          </thead>
          <tbody>
            {[
              ["Someone with this password did this",    "This human was physically here"],
              ["Repudiable — \"my password was stolen\"", "Non-repudiable — your fingerprint fired"],
              ["Identity is a string",                   "Identity is physics"],
              ["Trust-me audit trail",                   "Cryptographic proof of presence"],
              ["Compliance bolted on afterwards",        "KYC at the cryptographic root"],
              ["\"Who authorised this?\" is a question", "\"Who authorised this?\" is a fact"],
            ].map(([old, next]) => (
              <tr class="border-b border-white/6 last:border-0">
                <td class="px-6 py-4 text-zinc-500">{old}</td>
                <td class="px-6 py-4 text-zinc-200">{next}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <div class="grid sm:grid-cols-2 gap-4">
        <div class="border border-white/10 rounded-2xl p-6 bg-white/3">
          <p class="text-xs font-mono uppercase tracking-widest text-zinc-500 mb-3">The old model</p>
          <p class="text-zinc-300 leading-relaxed text-sm">
            A password says "someone who knows this string is authorised."
            A token says "someone who possesses this credential is authorised."
            Both are claims. Claims transfer. Claims get stolen.
          </p>
        </div>
        <div class="border rounded-2xl p-6" style={`border-color:${C.pb}40;background:${C.pd}`}>
          <p class="text-xs font-mono uppercase tracking-widest mb-3" style={`color:${C.pb}`}>The new model</p>
          <p class="text-zinc-300 leading-relaxed text-sm">
            Touch ID on Apple's Secure Enclave says: <strong class="text-white">"the person whose fingerprint is enrolled on this chip was physically present."</strong>
            That cannot be delegated, forwarded, or stolen. The only way to produce it is to be there.
          </p>
        </div>
      </div>
    </section>

    <!-- FOR YOUR ORGANISATION -->
    <section class="mb-24">
      <h2 class="text-3xl font-bold mb-3">What this means for your organisation.</h2>
      <p class="text-zinc-400 mb-8 max-w-xl">From legal standing to treasury — the implications are specific.</p>

      <div class="space-y-2">
        {orgRows.map(({ icon, family, accent, title, lead, body }) => (
          <details
            class="group border rounded-2xl overflow-hidden"
            style={
              family === "p" ? tint.p :
              family === "s" ? tint.s :
                               tint.t
            }
          >
            <summary class="px-6 py-5 cursor-pointer list-none flex items-center gap-5">
              <div class="shrink-0" set:html={icons[icon as keyof typeof icons]} />
              <div class="flex-1 min-w-0">
                <p class="text-white font-semibold">{title}</p>
                <p class="text-zinc-400 text-sm mt-0.5 leading-snug">{lead}</p>
              </div>
              <span class="text-zinc-500 text-xl shrink-0 group-open:rotate-45 transition-transform duration-200 leading-none mr-1">+</span>
            </summary>
            <p class="px-6 pb-6 text-zinc-300 text-sm leading-relaxed border-t border-white/8 pt-5 ml-[68px]">{body}</p>
          </details>
        ))}
      </div>
    </section>

    <!-- AUTHORITY CHAIN -->
    <section class="mb-24">
      <h2 class="text-3xl font-bold mb-3">
        Every agent action traces back to a human who was there.
      </h2>
      <p class="text-zinc-400 mb-8 max-w-xl leading-relaxed">
        When you give an AI agent a spending limit, you are signing a bounded power of attorney
        with your biometric. The blockchain records it. A Move smart contract enforces it.
        The agent cannot exceed it — regardless of what its model tells it to do.
      </p>

      <div class="rounded-2xl p-7 mb-6 overflow-x-auto border border-white/8 bg-white/3">
        <p class="text-xs font-mono uppercase tracking-widest text-zinc-500 mb-5">The authority chain</p>
        <div class="font-mono text-sm leading-[2.2] text-zinc-300">
          <span style={`color:${C.pb}`}>Your fingerprint</span>
          <span class="text-zinc-600"> — Secure Enclave, non-transferable by physics</span><br />
          <span class="text-zinc-600 ml-4">↓  proves your presence</span><br />
          <span class="ml-4">Spending cap transaction</span>
          <span class="text-zinc-600"> — signed, recorded on-chain</span><br />
          <span class="text-zinc-600 ml-8">↓  authorises the agent</span><br />
          <span class="ml-8">Agent's wallet</span>
          <span class="text-zinc-600"> — bounded by the cap you set</span><br />
          <span class="text-zinc-600 ml-12">↓  bounded sub-agents inherit remaining cap</span><br />
          <span class="ml-12">Every transaction across the tree</span><br />
          <span class="text-zinc-600 ml-16">↓  traces to you, with your biometric signature</span>
        </div>
      </div>

      <div class="grid sm:grid-cols-3 gap-4">
        {[
          { head: "Regulator asks", q: "Who authorised this payment?", a: "A cryptographic chain, not a policy document. A biometrically-signed transaction record.", f: "p" },
          { head: "Auditor asks",   q: "Who hired this agent?",         a: "A biometrically-signed record. \"Who changed these limits?\" — same answer. The trail says who was there.", f: "s" },
          { head: "Something goes wrong", q: "Who is accountable?",    a: "The chain points to a human who was physically present when they set the limits. Provably.", f: "t" },
        ].map(({ head, q, a, f }) => (
          <div class="border rounded-xl p-5" style={
            f === "p" ? tint.p : f === "s" ? tint.s : tint.t
          }>
            <p class="text-xs font-mono uppercase tracking-widest mb-2" style={
              f === "p" ? `color:${C.pb}` : f === "s" ? `color:${C.sb}` : `color:${C.tb}`
            }>{head}</p>
            <p class="text-white text-sm font-medium mb-2">"{q}"</p>
            <p class="text-zinc-400 text-sm leading-relaxed">{a}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- AGENT AUTONOMY -->
    <section class="mb-24">
      <h2 class="text-3xl font-bold mb-3">
        Agents run autonomously.<br />
        <span style={`color:${C.pb}`}>Exceptions need a fingerprint.</span>
      </h2>
      <p class="text-zinc-400 mb-10 max-w-xl leading-relaxed">
        You set the rules once with Touch ID. Your agent operates freely inside them.
        When it needs to go further, it shows you exactly what it wants to do —
        and you sign exactly that transaction. Nothing else.
      </p>

      <div class="grid sm:grid-cols-3 gap-3 mb-10">
        {[
          { label: "Autonomous zone", accent: C.tb, bg: tint.t, bullet: "Agent acts. No human needed.", items: ["Within daily cap", "Known recipient", "Permitted action type", "Cap active and unexpired"] },
          { label: "Approval zone",   accent: C.pb, bg: tint.p, bullet: "Agent requests. You Touch ID.", items: ["New recipient", "Exceeds daily cap", "Spawn sub-agent", "Change cap structure"] },
          { label: "Hard stop",       accent: C.sb, bg: tint.s, bullet: "Move contract blocks. Immovable.", items: ["Cap is paused", "Total cap exceeded", "Parent expired", "Forbidden action type"] },
        ].map(({ label, accent, bg, bullet, items }) => (
          <div class="border rounded-xl p-5" style={bg}>
            <p class="text-xs font-mono uppercase tracking-widest mb-2" style={`color:${accent}`}>{label}</p>
            <p class="text-white text-sm font-medium mb-3">{bullet}</p>
            <ul class="space-y-1.5">
              {items.map(item => (
                <li class="text-zinc-400 text-sm flex items-start gap-2">
                  <span style={`color:${accent}`} class="shrink-0 mt-0.5">›</span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>

