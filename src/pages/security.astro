---
export const prerender = true
import Layout from "@/layouts/Layout.astro"

/**
 * Theme colours (bright display variants for dark backgrounds)
 * Primary  — hsl(216 55% 25%) → bright: #7AA3E1 (navy blue family)
 * Secondary— hsl(219 14% 28%) → bright: #8496B8 (cool slate family)
 * Tertiary — hsl(105 22% 25%) → bright: #78B464 (forest green family)
 */
const C = {
  // Primary (blue)
  pb: "#7AA3E1",           // bright accent
  pm: "rgba(122,163,225,0.38)",  // mid stroke
  pd: "rgba(122,163,225,0.11)",  // dim body fill
  // Secondary (slate)
  sb: "#8496B8",
  sm: "rgba(132,150,184,0.38)",
  sd: "rgba(132,150,184,0.11)",
  // Tertiary (green)
  tb: "#78B464",
  tm: "rgba(120,180,100,0.38)",
  td: "rgba(120,180,100,0.11)",
}

// Card tints — subtle background + border per colour family
const card = {
  p: 'style="background:rgba(20,40,80,0.32);border-color:rgba(122,163,225,0.22)"',
  s: 'style="background:rgba(32,38,52,0.42);border-color:rgba(132,150,184,0.20)"',
  t: 'style="background:rgba(18,40,14,0.32);border-color:rgba(120,180,100,0.22)"',
}

const icons = {
  // Fingerprint — Primary
  fingerprint: `<svg width="44" height="44" viewBox="0 0 44 44" fill="none" aria-hidden="true">
    <circle cx="22" cy="22" r="17" fill="${C.pd}"/>
    <circle cx="22" cy="22" r="1.75" fill="${C.pb}"/>
    <path d="M22 18.5c-1.93 0-3.5 1.57-3.5 3.5 0 3 1.2 5.8 3.5 7.5" stroke="${C.pb}" stroke-width="1.6" stroke-linecap="round"/>
    <path d="M22 15c-3.87 0-7 3.13-7 7 0 5 2.2 9.5 7 11.5" stroke="${C.pm}" stroke-width="1.5" stroke-linecap="round"/>
    <path d="M22 11.5c-5.8 0-10.5 4.7-10.5 10.5 0 7 3.3 13 10.5 15.5" stroke="${C.pm}" stroke-width="1.4" stroke-linecap="round" opacity="0.6"/>
    <path d="M29.5 13A10.48 10.48 0 0 1 32.5 22c0 7-3.3 13-10.5 15.5" stroke="${C.pm}" stroke-width="1.4" stroke-linecap="round" opacity="0.4"/>
  </svg>`,

  // Padlock — Primary
  lock: `<svg width="44" height="44" viewBox="0 0 44 44" fill="none" aria-hidden="true">
    <rect x="9" y="20" width="26" height="17" rx="4" fill="${C.pd}" stroke="${C.pb}" stroke-width="1.6"/>
    <path d="M15 20v-5.5a7 7 0 0 1 14 0V20" stroke="${C.pb}" stroke-width="1.6" stroke-linecap="round"/>
    <circle cx="22" cy="29.5" r="3" fill="${C.pm}"/>
    <path d="M22 29.5v3" stroke="${C.pb}" stroke-width="1.6" stroke-linecap="round"/>
  </svg>`,

  // Chain links — Tertiary
  chain: `<svg width="44" height="44" viewBox="0 0 44 44" fill="none" aria-hidden="true">
    <rect x="5" y="16" width="16" height="12" rx="6" fill="${C.td}" stroke="${C.tb}" stroke-width="1.6"/>
    <rect x="23" y="16" width="16" height="12" rx="6" fill="${C.td}" stroke="${C.tb}" stroke-width="1.6"/>
    <path d="M21 22h2" stroke="${C.tb}" stroke-width="2" stroke-linecap="round"/>
    <path d="M11 28.5 9 33M33 28.5l2 4.5" stroke="${C.tm}" stroke-width="1.4" stroke-linecap="round"/>
  </svg>`,

  // Power button — Secondary
  power: `<svg width="44" height="44" viewBox="0 0 44 44" fill="none" aria-hidden="true">
    <circle cx="22" cy="22" r="14" fill="${C.sd}"/>
    <circle cx="22" cy="22" r="14" stroke="${C.sm}" stroke-width="1.5"/>
    <path d="M15 16.2A11 11 0 1 0 29 16.2" stroke="${C.sb}" stroke-width="1.9" stroke-linecap="round"/>
    <path d="M22 11v10" stroke="${C.sb}" stroke-width="1.9" stroke-linecap="round"/>
  </svg>`,

  // Scales — Primary
  scales: `<svg width="44" height="44" viewBox="0 0 44 44" fill="none" aria-hidden="true">
    <ellipse cx="12" cy="28" rx="7" ry="3.5" fill="${C.pd}" stroke="${C.pb}" stroke-width="1.5"/>
    <ellipse cx="32" cy="28" rx="7" ry="3.5" fill="${C.pd}" stroke="${C.pb}" stroke-width="1.5"/>
    <line x1="22" y1="11" x2="22" y2="36" stroke="${C.pm}" stroke-width="1.5" stroke-linecap="round"/>
    <path d="M16 36h12" stroke="${C.pm}" stroke-width="1.5" stroke-linecap="round"/>
    <path d="M7 17l15-6 15 6" stroke="${C.pb}" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
    <path d="M7 17l5 11" stroke="${C.pb}" stroke-width="1.5" stroke-linecap="round"/>
    <path d="M37 17l-5 11" stroke="${C.pb}" stroke-width="1.5" stroke-linecap="round"/>
    <circle cx="22" cy="11" r="2.5" fill="${C.pb}"/>
  </svg>`,

  // Columns — Secondary
  columns: `<svg width="44" height="44" viewBox="0 0 44 44" fill="none" aria-hidden="true">
    <rect x="7" y="34" width="30" height="3.5" rx="1.75" fill="${C.sd}" stroke="${C.sb}" stroke-width="1.4"/>
    <rect x="7" y="9" width="30" height="4.5" rx="1.75" fill="${C.sd}" stroke="${C.sb}" stroke-width="1.4"/>
    <rect x="10" y="13.5" width="5" height="20.5" rx="2.5" fill="${C.sd}" stroke="${C.sb}" stroke-width="1.4"/>
    <rect x="19.5" y="13.5" width="5" height="20.5" rx="2.5" fill="${C.sm}" stroke="${C.sb}" stroke-width="1.4"/>
    <rect x="29" y="13.5" width="5" height="20.5" rx="2.5" fill="${C.sd}" stroke="${C.sb}" stroke-width="1.4"/>
  </svg>`,

  // Shield + check — Tertiary
  shield: `<svg width="44" height="44" viewBox="0 0 44 44" fill="none" aria-hidden="true">
    <path d="M22 6L8 12v10c0 9.5 6.2 17.5 14 20 7.8-2.5 14-10.5 14-20V12L22 6z" fill="${C.td}" stroke="${C.tb}" stroke-width="1.6" stroke-linejoin="round"/>
    <path d="M15 22l5 5.5 9-10" stroke="${C.tb}" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>`,

  // Rising bars — Primary
  bars: `<svg width="44" height="44" viewBox="0 0 44 44" fill="none" aria-hidden="true">
    <rect x="7" y="28" width="8" height="8" rx="2" fill="${C.pd}" stroke="${C.pb}" stroke-width="1.5"/>
    <rect x="18" y="20" width="8" height="16" rx="2" fill="${C.pd}" stroke="${C.pb}" stroke-width="1.5" opacity="0.85"/>
    <rect x="29" y="11" width="8" height="25" rx="2" fill="${C.pd}" stroke="${C.pb}" stroke-width="1.5" opacity="0.7"/>
    <circle cx="33" cy="8" r="3" fill="${C.pb}"/>
    <path d="M11 22l10-8 10 5" stroke="${C.pm}" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>`,

  // Globe + nodes — Tertiary
  globe: `<svg width="44" height="44" viewBox="0 0 44 44" fill="none" aria-hidden="true">
    <circle cx="22" cy="22" r="15" fill="${C.td}" stroke="${C.tb}" stroke-width="1.6"/>
    <ellipse cx="22" cy="22" rx="6" ry="15" stroke="${C.tm}" stroke-width="1.3"/>
    <path d="M7 22h30" stroke="${C.tm}" stroke-width="1.3"/>
    <path d="M9.5 15h25M9.5 29h25" stroke="${C.tm}" stroke-width="1.1" opacity="0.6"/>
    <circle cx="22" cy="22" r="2.5" fill="${C.tb}"/>
    <path d="M22 19.5v-3.5M22 26v3.5M19.5 22H16M28 22h-3.5" stroke="${C.tb}" stroke-width="1.4" stroke-linecap="round"/>
  </svg>`,

  // Approval checkmark — Primary
  approve: `<svg width="44" height="44" viewBox="0 0 44 44" fill="none" aria-hidden="true">
    <rect x="7" y="9" width="22" height="28" rx="4" fill="${C.pd}" stroke="${C.pm}" stroke-width="1.5"/>
    <path d="M12 18h12M12 23h9M12 28h6" stroke="${C.pm}" stroke-width="1.4" stroke-linecap="round"/>
    <circle cx="33" cy="31" r="8" fill="rgba(20,40,80,0.80)" stroke="${C.pb}" stroke-width="1.5"/>
    <path d="M29 31l3 3 5-5" stroke="${C.pb}" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>`,

  // Bell notification — Secondary
  bell: `<svg width="44" height="44" viewBox="0 0 44 44" fill="none" aria-hidden="true">
    <path d="M22 8c-6.6 0-11 4.9-11 11v8l-3 4h28l-3-4V19c0-6.1-4.4-11-11-11z" fill="${C.sd}" stroke="${C.sb}" stroke-width="1.6" stroke-linejoin="round"/>
    <path d="M19 34a3 3 0 0 0 6 0" stroke="${C.sb}" stroke-width="1.5" stroke-linecap="round"/>
    <circle cx="31" cy="12" r="4.5" fill="${C.pb}"/>
    <path d="M29.5 12h3M31 10.5v3" stroke="rgba(0,0,0,0.5)" stroke-width="1.3" stroke-linecap="round"/>
  </svg>`,
}

// Org section rows: [icon, title, color family, body text]
const orgRows = [
  {
    icon: "scales",
    family: "p",
    title: "Legal and contracts",
    accent: C.pb,
    body: `A Touch ID signature meets the technical criteria for a qualified electronic signature in most jurisdictions —
      sole control, uniquely identifies the signer, linked to the signed data, tamper-evident.
      Board resolutions, financial authorisations, governance actions: each one now carries a biometric proof
      that the person was there. Not their device. Not their account. Them.`
  },
  {
    icon: "columns",
    family: "s",
    title: "Governance",
    accent: C.sb,
    body: `Multi-signature extends the biometric root across your leadership team.
      Require three of five board members to biometrically confirm before a major action executes.
      No single stolen device, no single coerced person can act alone.
      Governance gets a physics layer — not because we wrote a policy, but because the cryptography requires it.`
  },
  {
    icon: "shield",
    family: "t",
    title: "Compliance and audit",
    accent: C.tb,
    body: `Every transaction in your agent fleet traces to a biometric authorisation.
      An auditor follows any payment to the human who set the limits that permitted it.
      GDPR erasure is a biometrically-signed action with an immutable record.
      KYC is at the cryptographic root — not added later, not bolted on.
      The audit trail lives on the Sui blockchain: we cannot alter it.`
  },
  {
    icon: "bars",
    family: "p",
    title: "Finance and treasury",
    accent: C.pb,
    body: `An AI agent with access to your treasury is a liability.
      An AI agent whose spending limit was set with your CEO's biometric signature,
      whose allowed recipient list was signed by your CFO,
      and whose pause trigger fires the moment either of them calls it —
      that is a controlled, auditable, legally-grounded instrument.
      The agent acts. The human remains accountable. The chain is unambiguous.`
  },
  {
    icon: "globe",
    family: "t",
    title: "Government and sovereign deployments",
    accent: C.tb,
    body: `Run your own substrate — your own biometric root, your own key hierarchy, your own database.
      We never hold your keys. Every action taken in the system traces to a biometrically-proven
      person in your organisation. Federation with other agencies requires a biometric handshake from both sides.
      The audit trail is yours, on-chain, and cannot be altered.`
  },
]

// How-it-works cards
const howCards = [
  { icon: "fingerprint", accent: C.pb, label: "The Secure Enclave", text: "A dedicated security chip inside every Apple device. It generates a private key at manufacture and is physically designed to never let it out. Not to the OS, not to apps, not to us. When you touch Touch ID, the chip signs. The key stays inside." },
  { icon: "chain",       accent: C.tb, label: "The PRF output",     text: "Touch ID asks the chip for a 32-byte secret — deterministic per credential, hardware-bound, never stored. From this, every key in your system is derived: your wallet, your API access, your agents' key-encrypting keys. One biometric. All keys. None on our servers." },
  { icon: "lock",        accent: C.pb, label: "The spending cap",   text: "When you set an agent's limit, that limit becomes a Move object on the Sui blockchain — enforced by 100+ validators on every transaction. It is not a rule in a database. It is not a policy in our code. The blockchain enforces it. We cannot override it." },
  { icon: "shield",      accent: C.tb, label: "The recovery",       text: "Twelve words on paper. Written once, stored somewhere you trust with your life — because that is what they are worth. If every device is lost, those twelve words reconstruct the same key hierarchy, the same wallet address, the same agent limits. No support ticket. No waiting." },
]

// Safety downstream cards
const safetyCards = [
  { icon: "lock",  accent: C.pb, family: "p", title: "Nothing to steal",       text: "No plaintext keys on our servers. A breach yields scrambled hashes — useless without your device and your finger." },
  { icon: "chain", accent: C.tb, family: "t", title: "Agents can't overspend", text: "Daily caps enforced by blockchain consensus, not application policy. The Move contract cannot be bypassed by software." },
  { icon: "power", accent: C.sb, family: "s", title: "One tap stops everything", text: "Pause any agent. The pause cascades to every sub-agent below it via the blockchain. Instant. No exceptions." },
]
---

<Layout
	title="ONE Security — Biometrics prove the human. Blockchain bounds the agent."
	description="For the first time, every digital action in your organisation traces back to a fingerprint. Not a password. Not a token. A human who was physically there."
>
	<main class="mx-auto max-w-4xl px-6 py-16 sm:py-24 text-white">

		<!-- HERO -->
		<section class="mb-20">
			<p class="text-xs font-mono tracking-widest uppercase mb-6" style={`color:${C.pb}`}>Security</p>
			<h1 class="text-5xl sm:text-7xl font-bold leading-[1.05] tracking-tight mb-8">
				Prove the human.<br />
				<span style={`color:${C.pb}`}>Then trust the agent.</span>
			</h1>
			<p class="text-xl text-zinc-300 max-w-2xl leading-relaxed mb-4">
				For the first time, every digital action in your organisation traces back
				to a fingerprint on a chip — not a password, not a token, not a claim.
				A human who was physically there.
			</p>
			<p class="text-lg text-zinc-400 max-w-2xl leading-relaxed mb-10">
				That changes legal standing. It changes governance. It changes what accountability means.
				The safety properties — spending caps, breach protection, instant shutdown —
				are downstream of that.
			</p>
			<div class="flex gap-4 flex-wrap">
				<a href="/u" class="font-semibold px-7 py-3 rounded-lg transition-colors text-black" style={`background:${C.pb}`}>
					Open your wallet
				</a>
				<a href="/platform" class="border border-white/15 hover:border-white/30 px-7 py-3 rounded-lg transition-colors">
					Enterprise
				</a>
				<a href="/security/whitepaper" class="px-7 py-3 transition-colors underline underline-offset-4 text-zinc-400 hover:text-zinc-200">
					Technical whitepaper
				</a>
			</div>
		</section>

		<div class="border-t border-white/8 mb-20"></div>

		<!-- PARADIGM SHIFT -->
		<section class="mb-24">
			<h2 class="text-3xl font-bold mb-6">
				Digital identity has been unsolved for fifty years.
			</h2>
			<div class="grid sm:grid-cols-2 gap-6 mb-10">
				<div class="border border-white/10 rounded-2xl p-6 bg-white/4">
					<p class="text-xs font-mono uppercase tracking-widest text-zinc-500 mb-4">The old model</p>
					<p class="text-zinc-300 leading-relaxed mb-4">
						A password says: <em class="text-zinc-400 not-italic">"someone who knows this string is authorised."</em><br />
						A token says: <em class="text-zinc-400 not-italic">"someone who possesses this credential is authorised."</em>
					</p>
					<p class="text-zinc-300 leading-relaxed">
						Passwords are shareable. Tokens are copyable. Credentials are stolen.
						Every digital identity system before biometrics is built on a claim — and claims can be wrong.
					</p>
				</div>
				<div class="border rounded-2xl p-6" style={`border-color:${C.pb}40;background:${C.pd}`}>
					<p class="text-xs font-mono uppercase tracking-widest mb-4" style={`color:${C.pb}`}>The new model</p>
					<p class="text-zinc-300 leading-relaxed mb-4">
						Touch ID on Apple's Secure Enclave says: <strong class="text-white">"the person whose fingerprint is enrolled on this chip was physically present at this moment."</strong>
					</p>
					<p class="text-zinc-300 leading-relaxed">
						That proof is generated inside hardware that cannot be remotely accessed, cloned, or socially engineered.
						It cannot be delegated. It cannot be forwarded.
						The only way to produce it is to be there.
					</p>
				</div>
			</div>

			<div class="overflow-x-auto">
				<table class="w-full text-sm text-left border-collapse">
					<thead>
						<tr class="border-b border-white/10">
							<th class="py-3 pr-8 text-xs font-mono uppercase tracking-widest text-zinc-500">Old model</th>
							<th class="py-3 text-xs font-mono uppercase tracking-widest" style={`color:${C.pb}`}>With biometrics</th>
						</tr>
					</thead>
					<tbody>
						{[
							["Someone with this password did this",   "This human was physically here"],
							["Repudiable — \"my password was stolen\"", "Non-repudiable — your fingerprint fired"],
							["Identity is a string",                  "Identity is physics"],
							["Trust-me audit trail",                  "Cryptographic proof of presence"],
							["Compliance bolted on afterwards",       "KYC at the cryptographic root"],
							["\"Who authorised this?\" is a question","\"Who authorised this?\" is a fact"],
						].map(([old, next]) => (
							<tr class="border-b border-white/6">
								<td class="py-3 pr-8 text-zinc-500">{old}</td>
								<td class="py-3 text-zinc-200">{next}</td>
							</tr>
						))}
					</tbody>
				</table>
			</div>
		</section>

		<!-- AUTHORITY CHAIN -->
		<section class="mb-24">
			<h2 class="text-3xl font-bold mb-4">
				Every agent action traces back to a human who was there.
			</h2>
			<p class="text-zinc-300 text-lg leading-relaxed mb-8 max-w-2xl">
				When you give an AI agent a spending limit in ONE, you are signing a bounded power of attorney
				with your biometric. The blockchain records it. The Move smart contract enforces it.
			</p>

			<div class="rounded-2xl p-7 mb-8 overflow-x-auto border border-white/8 bg-white/3">
				<p class="text-xs font-mono uppercase tracking-widest text-zinc-500 mb-5">The authority chain</p>
				<div class="font-mono text-sm leading-loose text-zinc-300">
					<span style={`color:${C.pb}`}>Your fingerprint</span> <span class="text-zinc-600">(Secure Enclave — non-transferable by physics)</span><br />
					<span class="text-zinc-600 ml-4">↓ proves your presence</span><br />
					<span class="text-zinc-300 ml-4">Spending cap transaction</span> <span class="text-zinc-600">(signed, recorded on-chain)</span><br />
					<span class="text-zinc-600 ml-8">↓ authorises the agent</span><br />
					<span class="text-zinc-300 ml-8">Agent's wallet</span> <span class="text-zinc-600">(bounded by the cap you set)</span><br />
					<span class="text-zinc-600 ml-12">↓</span><br />
					<span class="text-zinc-300 ml-12">Agent's sub-agents</span> <span class="text-zinc-600">(each bounded by their parent's remaining cap)</span><br />
					<span class="text-zinc-600 ml-16">↓</span><br />
					<span class="text-zinc-300 ml-16">Every transaction across the entire tree</span><br />
					<span class="text-zinc-600 ml-20">↓ traces back to you, with your biometric signature</span>
				</div>
			</div>

			<div class="grid sm:grid-cols-3 gap-4">
				{[
					{ head: "When a regulator asks",    body: `"Who authorised this payment?" — the answer is a cryptographic chain, not a policy document. A biometrically-signed transaction record.`, f: "p" },
					{ head: "When an auditor asks",     body: `"Who hired this agent?" — a biometrically-signed record. "Who changed these limits?" — same. The audit trail says who was there.`, f: "s" },
					{ head: "When something goes wrong",body: `"Who is accountable?" — the chain points to a human who was physically present when they set the limits. "I didn't know" is not "I didn't authorise."`, f: "t" },
				].map(({ head, body, f }) => (
					<div class="border rounded-xl p-5" style={
						f === "p" ? `background:rgba(20,40,80,0.28);border-color:${C.pm}` :
						f === "s" ? `background:rgba(32,38,52,0.38);border-color:${C.sm}` :
						            `background:rgba(18,40,14,0.28);border-color:${C.tm}`
					}>
						<p class="text-sm font-semibold text-white mb-2">{head}</p>
						<p class="text-zinc-400 text-sm leading-relaxed">{body}</p>
					</div>
				))}
			</div>
		</section>

		<!-- AGENT AUTONOMY + APPROVAL -->
		<section class="mb-24">
			<h2 class="text-3xl font-bold mb-4">
				Agents run autonomously.<br />
				<span style={`color:${C.pb}`}>Exceptions need a fingerprint.</span>
			</h2>
			<p class="text-zinc-300 text-lg leading-relaxed mb-10 max-w-2xl">
				You set the rules once — with Touch ID. Your agent operates freely inside them,
				no approval needed. When it needs to do something outside those bounds,
				it asks you exactly once, tells you exactly what it wants to do,
				and you sign exactly that transaction. Nothing else.
			</p>

			<!-- Three zones -->
			<div class="grid sm:grid-cols-3 gap-4 mb-10">
				{[
					{
						label: "Autonomous zone",
						accent: C.tb,
						bg: "rgba(18,40,14,0.28)",
						bc: "rgba(120,180,100,0.22)",
						bullet: "Agent acts. No human needed.",
						items: ["Amount within daily cap", "Recipient in approved list", "Action within permitted set", "Cap not expired or paused"],
					},
					{
						label: "Approval zone",
						accent: C.pb,
						bg: "rgba(20,40,80,0.28)",
						bc: "rgba(122,163,225,0.22)",
						bullet: "Agent requests. You Touch ID.",
						items: ["New recipient", "Amount above daily cap", "Spawn a sub-agent", "Change cap structure"],
					},
					{
						label: "Hard stop",
						accent: C.sb,
						bg: "rgba(32,38,52,0.38)",
						bc: "rgba(132,150,184,0.20)",
						bullet: "Move contract blocks. Immovable.",
						items: ["Cap paused — every tx fails", "Total remaining exceeded", "Parent cap expired", "Forbidden action type"],
					},
				].map(({ label, accent, bg, bc, bullet, items }) => (
					<div class="border rounded-xl p-5" style={`background:${bg};border-color:${bc}`}>
						<p class="text-xs font-mono uppercase tracking-widest mb-2" style={`color:${accent}`}>{label}</p>
						<p class="text-white text-sm font-medium mb-3">{bullet}</p>
						<ul class="space-y-1.5">
							{items.map(item => (
								<li class="text-zinc-400 text-sm flex items-start gap-2">
									<span style={`color:${accent}`} class="shrink-0 mt-0.5">›</span>
									<span>{item}</span>
								</li>
							))}
						</ul>
					</div>
				))}
			</div>

			<!-- What an approval looks like -->
			<div class="grid sm:grid-cols-2 gap-8 items-start">
				<!-- Mock approval card -->
