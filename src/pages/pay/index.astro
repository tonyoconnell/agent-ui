---
import Layout from "@/layouts/Layout.astro"
import { PayShowcaseHeader, PayShowcaseFooter } from "@/components/pay/PayShowcase"
import PayLiveDemo from "@/components/pay/PayLiveDemo"
import ReferenceBanner from "@/components/landing/ReferenceBanner.astro"

export const prerender = false
---

<Layout
  title="Accept payments — Stripe, Sui, crypto links · ONE"
  description="Accept payments on every rail at once. One API, one signal. Stripe Elements for cards, Sui dapp-kit for wallets, shareable links for crypto. The graph routes tomorrow's buyers down the lanes that paid yesterday."
>
  <ReferenceBanner endpoint="POST /api/pay/stripe/create-intent, /api/sui/escrow/*" note="Drop into your checkout — Stripe + Sui rails, one SDK call" />

  <main class="min-h-screen bg-[#0a0a0f] text-slate-100">
    <PayShowcaseHeader client:only="react" />
    <PayLiveDemo client:only="react" />
    <PayShowcaseFooter client:only="react" />
  </main>
</Layout>

<script is:inline>
  fetch('/api/signal', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      receiver: 'ui:pay:showcase:view',
      data: { tags: ['pay', 'showcase', 'view', 'page'] }
    })
  }).catch(() => {})
</script>
