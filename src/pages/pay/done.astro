---
import Layout from "@/layouts/Layout.astro"
import { Button } from "@/components/ui/button"
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from "@/components/ui/card"
import { Check, Clock, X } from "lucide-react"
import { getStripeClient } from "@/lib/stripe"

export const prerender = false

const url = new URL(Astro.request.url)
const piId = url.searchParams.get("payment_intent")
const redirectStatus = url.searchParams.get("redirect_status")
const ref = piId ?? url.searchParams.get("ref") ?? "unknown"
const masked = ref.length > 12 ? `${ref.slice(0, 6)}…${ref.slice(-4)}` : ref

type Outcome = "succeeded" | "processing" | "failed"
let outcome: Outcome = redirectStatus === "succeeded" ? "succeeded" : redirectStatus === "processing" ? "processing" : "failed"
let amountFormatted: string | null = null

if (piId && piId.startsWith("pi_")) {
  const stripe = getStripeClient()
  if (stripe) {
    try {
      const pi = await stripe.paymentIntents.retrieve(piId)
      if (pi.status === "succeeded") outcome = "succeeded"
      else if (pi.status === "processing" || pi.status === "requires_action" || pi.status === "requires_capture") outcome = "processing"
      else outcome = "failed"
      amountFormatted = (pi.amount / 100).toLocaleString(undefined, {
        style: "currency",
        currency: pi.currency.toUpperCase(),
      })
    } catch {
      // Fall back to whatever Stripe redirected with
    }
  }
}

const copy: Record<Outcome, { title: string; description: string; tone: string; icon: "check" | "clock" | "x" }> = {
  succeeded: {
    title: "Payment complete",
    description: amountFormatted ? `${amountFormatted} received.` : "Your payment has been received.",
    tone: "text-emerald-400",
    icon: "check",
  },
  processing: {
    title: "Confirming payment",
    description: amountFormatted ? `${amountFormatted} pending. We'll notify you when it clears.` : "Your bank is finishing the transfer.",
    tone: "text-amber-400",
    icon: "clock",
  },
  failed: {
    title: "Payment didn't go through",
    description: "No charge was made. You can try again on the previous page.",
    tone: "text-rose-400",
    icon: "x",
  },
}

const c = copy[outcome]
---

<Layout
  title={`${c.title} · ONE`}
  description="Stripe payment status — receipt, reference, next step."
  noindex={true}
>
  <main class="fixed inset-0 flex items-center justify-center p-4 bg-gradient-to-br from-background via-background to-primary/5">
    <Card className="w-full max-w-sm border-primary/20 shadow-lg">
      <CardHeader className="items-center text-center space-y-3">
        <div class:list={["flex h-12 w-12 items-center justify-center rounded-full bg-primary/10", c.tone]}>
          {c.icon === "check" && <Check className="h-6 w-6" />}
          {c.icon === "clock" && <Clock className="h-6 w-6" />}
          {c.icon === "x" && <X className="h-6 w-6" />}
        </div>
        <CardTitle>{c.title}</CardTitle>
        <CardDescription>{c.description}</CardDescription>
      </CardHeader>
      <CardContent className="space-y-5">
        <div class="rounded-md border bg-background px-3 py-2 text-xs flex items-center justify-between">
          <span class="text-muted-foreground">Reference</span>
          <code class="font-mono text-foreground">{masked}</code>
        </div>
        <div class="flex gap-2">
          {outcome === "failed" ? (
            <Button asChild variant="outline" className="flex-1">
              <a href="/pay/touch">Try again</a>
            </Button>
          ) : null}
          <Button asChild className="flex-1">
            <a href="/">Return home</a>
          </Button>
        </div>
      </CardContent>
    </Card>
  </main>
  <script is:inline define:vars={{ ref, outcome }}>
    fetch('/api/signal', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        receiver: 'ui:pay:done:view',
        data: { tags: ['pay','done','view', outcome], content: { ref, outcome } }
      })
    }).catch(() => {})
  </script>
</Layout>
