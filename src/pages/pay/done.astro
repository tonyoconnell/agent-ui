---
import Layout from "@/layouts/Layout.astro"
import { Button } from "@/components/ui/button"
import { Card, CardContent, CardHeader, CardTitle, CardDescription } from "@/components/ui/card"
import { Check } from "lucide-react"

export const prerender = false

const url = new URL(Astro.request.url)
const ref = url.searchParams.get("ref") ?? "unknown"
const masked = ref.length > 12 ? ref.slice(0, 6) + "…" + ref.slice(-4) : ref
---

<Layout title="Payment complete">
  <main class="fixed inset-0 flex items-center justify-center p-4 bg-gradient-to-br from-background via-background to-primary/5">
    <Card className="w-full max-w-sm border-primary/20 shadow-lg">
      <CardHeader className="items-center text-center space-y-3">
        <div class="flex h-12 w-12 items-center justify-center rounded-full bg-primary/10 text-primary">
          <Check className="h-6 w-6" />
        </div>
        <CardTitle>Payment complete</CardTitle>
        <CardDescription>Your payment has been received.</CardDescription>
      </CardHeader>
      <CardContent className="space-y-5">
        <div class="rounded-md border bg-background px-3 py-2 text-xs flex items-center justify-between">
          <span class="text-muted-foreground">Reference</span>
          <code class="font-mono text-foreground">{masked}</code>
        </div>
        <Button asChild className="w-full">
          <a href="/">Return home</a>
        </Button>
      </CardContent>
    </Card>
  </main>
  <script is:inline define:vars={{ ref }}>
    fetch('/api/signal', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        receiver: 'ui:pay:page:done:view',
        data: { tags: ['pay','page','view','done'], content: { ref } }
      })
    }).catch(() => {})
  </script>
</Layout>
