---
import Layout from "@/layouts/Layout.astro"
import { PayPage } from "@/components/pay/PayPage"

const { skillId } = Astro.params

// SSR: look up skill info from KV snapshot
let skill: { name: string; price: number; seller: string } | null = null

try {
  const kv = await import("@/lib/edge")
  const skills = await kv.kvGet("skills") as any[] | null
  const found = skills?.find((s: any) => s.skillId === skillId || s.id === skillId)
  if (found) {
    skill = {
      name: found.name ?? skillId,
      price: found.price ?? 0,
      seller: found.seller ?? found.uid ?? "unknown",
    }
  }
} catch {
  // Fallback: render with just the skillId
}

if (!skill) {
  skill = { name: skillId ?? "Skill", price: 0, seller: "unknown" }
}
---

<Layout title={`Pay · ${skill.name}`}>
  <main class="min-h-screen bg-[#0a0a0f] flex items-center justify-center p-4">
    <PayPage
      client:only="react"
      skillId={skillId ?? ""}
      skillName={skill.name}
      price={skill.price}
      seller={skill.seller}
    />
  </main>
</Layout>
