---
import Layout from "@/layouts/Layout.astro"
import { BuyInChatEnhanced } from "@/components/pay/chat/BuyInChatEnhanced"

export const prerender = false

const { skillId } = Astro.params

// SSR: look up skill info from KV snapshot
let skill: { name: string; price: number; seller: string } | null = null

try {
  const kv = await import("@/lib/edge")
  const skills = await kv.kvGet("skills") as any[] | null
  const found = skills?.find((s: any) => s.skillId === skillId || s.id === skillId)
  if (found) {
    skill = {
      name: found.name ?? skillId,
      price: found.price ?? 0,
      seller: found.seller ?? found.uid ?? "unknown",
    }
  }
} catch {
  // Fallback: render with just the skillId
}

if (!skill) {
  return new Response("Skill not found", { status: 404, headers: { "Content-Type": "text/plain" } })
}

// Shape the skill into the product prop BuyInChatEnhanced expects.
// Required fields: id, name, price, description, category, stock.
// Optional: brand, features, image.
const product = {
  id: skillId ?? "unknown",
  name: skill.name,
  price: skill.price,
  description: `${skill.name} — offered by ${skill.seller}`,
  category: "skill",
  brand: skill.seller,
  stock: 999,
}
---

<Layout title={`Chat checkout · ${skill.name}`}>
  <main class="min-h-screen bg-[#0a0a0f] p-4">
    <div class="mx-auto max-w-3xl py-8">
      <BuyInChatEnhanced
        client:only="react"
        product={product}
      />
    </div>
  </main>
</Layout>

<script is:inline define:vars={{ skillId }}>
  fetch('/api/signal', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      receiver: 'ui:pay:page:chat:view',
      data: {
        tags: ['pay', 'page', 'view', 'chat'],
        content: { skillId },
      },
    }),
  }).catch(() => {})
</script>
