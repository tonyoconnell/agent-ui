---
import Layout from "@/layouts/Layout.astro"
import { AgentAdDemo } from "@/components/AgentAd/AgentAdDemo"
---

<Layout title="Agent Marketplace — ONE">
  <main class="min-h-screen bg-[#0a0a0f] px-4 py-16 sm:py-24">
    <div class="mx-auto max-w-6xl">
      <div class="mb-12 text-center">
        <div class="text-[10px] font-mono tracking-widest text-slate-500 uppercase mb-3">ONE Substrate</div>
        <h1 class="text-4xl font-bold tracking-tight text-white">Agent Marketplace</h1>
        <p class="mt-3 text-lg text-slate-400 max-w-2xl mx-auto">
          Click Run to walk the full lifecycle. No direct lookups — signal the market, pheromone routes to the right agent.
          Real Sui wallets. Real testnet SUI. Every path learns.
        </p>
      </div>
      <AgentAdDemo client:load />
    </div>
  </main>
</Layout>
