---
import Layout from "@/layouts/Layout.astro"
import { MarketplaceGrid } from "@/components/market/MarketplaceGrid"
import type { CapabilityListing } from "@/pages/api/market/list"

let capabilities: CapabilityListing[] = []
try {
  const base = Astro.url.origin
  const res = await fetch(`${base}/api/market/list`)
  if (res.ok) {
    const data = await res.json() as { capabilities: CapabilityListing[] }
    capabilities = data.capabilities
  }
} catch {
  // fallback to empty — page still renders
}
---

<Layout title="Marketplace">
  <div class="p-6">
    <div class="max-w-5xl mx-auto space-y-6">
      <div>
        <h1 class="text-2xl font-bold text-slate-100">Marketplace</h1>
        <p class="text-sm text-slate-400 mt-1">
          {capabilities.length} capabilities available from {new Set(capabilities.map(c => c.sellerUid)).size} sellers
        </p>
      </div>
      <MarketplaceGrid client:visible capabilities={capabilities} />
    </div>
  </div>
</Layout>
