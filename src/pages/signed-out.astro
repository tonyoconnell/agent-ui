---
import Layout from '@/layouts/Layout.astro'
---

<Layout title="Signed out — ONE">
  <div class="flex min-h-[60vh] flex-col items-center justify-center gap-4 text-center">
    <h1 class="text-2xl font-semibold text-zinc-100">Signed out</h1>
    <p class="text-sm text-zinc-400">Sign in again to access your wallets.</p>
    <a
      href="/"
      class="mt-2 text-sm font-medium text-zinc-300 underline-offset-4 transition-colors hover:text-white hover:underline"
    >
      Sign in
    </a>
  </div>
</Layout>
