---
/**
 * /sell/new — Create a new capability listing.
 *
 * SSR shell. NewListingIsland handles the form, Touch ID gate,
 * and POST /api/sell/create submission.
 */
import Layout from '@/layouts/Layout.astro'
import { NewListingIsland } from '@/components/sell/NewListingIsland'

export const prerender = false
---

<Layout title="New Listing — ONE">
  <div class="min-h-screen bg-[#0a0a0f] text-slate-100">

    <!-- Header bar -->
    <div class="border-b border-[#252538] bg-[#0d0d14] px-6 py-6">
      <div class="mx-auto max-w-lg">
        <nav class="mb-1 text-xs text-zinc-500">
          <a href="/" class="hover:text-zinc-300">Home</a>
          <span class="mx-1">/</span>
          <a href="/sell" class="hover:text-zinc-300">Sell</a>
          <span class="mx-1">/</span>
          <span class="text-zinc-300">New listing</span>
        </nav>
        <h1 class="text-xl font-semibold">Publish a skill</h1>
        <p class="mt-1 text-xs text-slate-500">
          Buyers discover via <code class="text-zinc-300">/buy</code>. Pheromone decides who gets the work.
        </p>
      </div>
    </div>

    <!-- Island -->
    <div class="mx-auto max-w-lg px-6 py-8">
      <NewListingIsland client:load />
    </div>

  </div>
</Layout>
