---
import Layout from "@/layouts/Layout.astro"
import { WorldPageWrapper } from "@/components/WorldPageWrapper"
import WorldWorkspace from "@/components/WorldWorkspace"
import { VisitorBanner } from "@/components/world/VisitorBanner"
import { GuideNarrator } from "@/components/world/GuideNarrator"

// Check if user is authenticated (from session or headers)
const isAuthenticated = !!Astro.locals.session?.user
---

<Layout title="ONE World">
  <WorldPageWrapper client:load>
    <VisitorBanner isAuthenticated={isAuthenticated} />
    <WorldWorkspace />
    <GuideNarrator />
  </WorldPageWrapper>
</Layout>

<style is:global>
  /* Metaphor skin animations */
  @keyframes particle-burst {
    0% {
      transform: translate(0, 0) scale(1);
      opacity: 1;
    }
    100% {
      transform: translate(var(--tx), var(--ty)) scale(0);
      opacity: 0;
    }
  }

  @keyframes sparkle {
    0% {
      transform: scale(0) rotate(0deg);
      opacity: 1;
    }
    50% {
      transform: scale(1.5) rotate(180deg);
      opacity: 1;
    }
    100% {
      transform: scale(0) rotate(360deg);
      opacity: 0;
    }
  }

  /* Smooth skin transitions */
  .skin-transition {
    transition: background-color 0.3s ease, border-color 0.3s ease, color 0.3s ease;
  }
</style>
