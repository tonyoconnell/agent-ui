---
import Layout from "@/layouts/Layout.astro"
import { Inbox } from "@/components/in/Inbox"
import { getGroupsForUser, resolveUnitFromSession } from '@/lib/api-auth'

const OWNER_ROLES = ['chairman', 'ceo', 'operator']
const auth = await resolveUnitFromSession(Astro.request, Astro.locals).catch(() => null)
if (!auth?.isValid) return Astro.redirect('/', 302)

const groups = await getGroupsForUser(auth.user, OWNER_ROLES)
if (groups.length === 0) return Astro.redirect('/', 302)
if (groups.length === 1) return Astro.redirect(`/in/${groups[0].gid}`, 302)
---

<Layout title="/in — ONE">
  <div class="h-screen w-screen overflow-hidden">
    <Inbox client:only="react" groups={groups} />
  </div>
</Layout>
