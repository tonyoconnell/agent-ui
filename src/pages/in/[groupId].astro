---
export const prerender = false
import AppLayout from "@/layouts/AppLayout.astro"
import { Inbox } from "@/components/in/Inbox"
import { getGroupsForUser, resolveUnitFromSession } from '@/lib/api-auth'

const auth = await resolveUnitFromSession(Astro.request, Astro.locals).catch(() => null)
if (!auth?.isValid) return Astro.redirect('/', 302)

const { groupId } = Astro.params
const groups = await getGroupsForUser(auth.user)
const thisGroup = groups.find((g) => g.gid === groupId)
if (!thisGroup) return Astro.redirect('/', 302)
---

<AppLayout title={`/in/${groupId} — ONE`}>
  <Inbox client:only="react" groupId={groupId} groups={groups} />
</AppLayout>
