---
export const prerender = true;

/**
 * /u - The Universal Wallet Dashboard
 *
 * Beautiful multi-chain wallet experience.
 * Wired to wallet-v2: idb.ts (one-wallet IDB), passkey-PRF, BIP39.
 */
