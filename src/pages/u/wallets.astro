---
// SSR required - client-side wallet interactions
export const prerender = true;

/**
 * /u/wallets - Wallet Management
 *
 * All your wallets across all chains.
 * Generate, import, export, manage.
 */
import Layout from "@/layouts/Layout.astro";
import { WalletsPage } from "@/components/u/pages/WalletsPage";

const title = "Wallets | u";
