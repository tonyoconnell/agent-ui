---
import Layout from "@/layouts/Layout.astro"
import { SpeedJourney } from "@/components/speed/SpeedJourney"
import { LifecycleSpeedrun } from "@/components/speed/LifecycleSpeedrun"
import { Badge } from "@/components/ui/badge"
import { Button } from "@/components/ui/button"
import {
  Card,
  CardContent,
  CardDescription,
  CardHeader,
  CardTitle,
} from "@/components/ui/card"
import {
  Activity,
  Cpu,
  GitBranch,
  Layers,
  Repeat,
  Shield,
  Sparkles,
  Zap,
} from "lucide-react"

export const prerender = true

// Verified benchmarks surfaced from docs/speed-test.md — PERF_SCALE=3, 125 samples.
// p50 on idle hardware. Budget is the hard target; p50 is observed.
type Bench = { op: string; budget: string; p50: string; replaces: string }

const routingBench: Bench[] = [
  { op: "select() from 100 paths",   budget: "0.005ms", p50: "0.007ms", replaces: "LLM routing (~300ms)" },
  { op: "select() from 1,000 paths", budget: "1.00ms",  p50: "0.074ms", replaces: "search API + rank" },
  { op: "follow strongest",          budget: "0.050ms", p50: "0.005ms", replaces: "keyword search" },
  { op: "follow batch (10k)",        budget: "0.005ms", p50: "0.005ms", replaces: "—" },
]

const pheromoneBench: Bench[] = [
  { op: "mark()",            budget: "0.001ms", p50: "0.45μs",  replaces: "DB write (~10ms)" },
  { op: "warn()",            budget: "0.001ms", p50: "0.22μs",  replaces: "—" },
  { op: "sense()",           budget: "0.001ms", p50: "0.04μs",  replaces: "—" },
  { op: "fade() over 1,000", budget: "5.00ms",  p50: "0.137ms", replaces: "—" },
  { op: "highways() top-10", budget: "5.00ms",  p50: "0.92μs",  replaces: "—" },
]

const signalBench: Bench[] = [
  { op: "dispatch (in-memory)", budget: "1.00ms", p50: "0.72μs",  replaces: "HTTP call (~50ms)" },
  { op: "dispatch: dissolved",  budget: "1.00ms", p50: "0.12μs",  replaces: "—" },
  { op: "queue round-trip",     budget: "1.00ms", p50: "2.0μs",   replaces: "—" },
  { op: "ask: chain-3",         budget: "100ms",  p50: "0.017ms", replaces: "3 sequential LLM (~6s)" },
]

const infraBench: Bench[] = [
  { op: "edge cache hit",       budget: "0.010ms", p50: "0.52μs", replaces: "TypeDB RTT (~100ms)" },
  { op: "Sui keypair derive",   budget: "5.00ms",  p50: "2.45ms", replaces: "HSM round-trip" },
  { op: "Sui tx build",         budget: "0.010ms", p50: "0.51μs", replaces: "—" },
  { op: "Sui sign",             budget: "5.00ms",  p50: "0.36ms", replaces: "—" },
]

const benchCards = [
  { title: "Routing Layer",   ops: routingBench,   titleCls: "text-cyan-400",    p50Cls: "text-cyan-400" },
  { title: "Pheromone Layer", ops: pheromoneBench, titleCls: "text-emerald-400", p50Cls: "text-emerald-400" },
  { title: "Signal Layer",    ops: signalBench,    titleCls: "text-violet-400",  p50Cls: "text-violet-400" },
  { title: "Edge · Sui",      ops: infraBench,     titleCls: "text-amber-400",   p50Cls: "text-amber-400" },
] as const

const principles = [
  {
    icon: Cpu,
    title: "Routing is arithmetic",
    body: "weight = 1 + max(0, strength − resistance) × sensitivity. No ML. No coordinator. Just a single formula applied across proven paths.",
    stat: "<0.005ms / decision",
  },
  {
    icon: Layers,
    title: "The deterministic sandwich",
    body: "Toxicity → capability → LLM → mark/warn. Four of five layers cost $0. Only one is probabilistic. The rest is math wrapped around the model.",
    stat: "4 of 5 layers free",
  },
  {
    icon: Repeat,
    title: "Every signal closes its loop",
    body: "result → mark. failure → warn. dissolved → warn(0.5). Pheromone accumulates on paths automatically, so the system learns as it runs.",
    stat: "43,200 signals/day",
  },
]
---

<Layout
  title="Speed — Ride a Signal Through the World"
  description="Watch one real signal travel through 9 stops — click, edge, route, sandwich, LLM, mark, loops, highway, harden — with live timings at every step."
  imageAlt="ONE Speed — the 9-stop journey of a signal through the substrate"
>
  <main class="min-h-screen bg-[#0a0a0f] text-slate-200">

    <!-- Hero -->
    <section class="relative overflow-hidden border-b border-slate-800 px-6 py-20 md:px-10 md:py-28">
      <div class="absolute inset-0 -z-10 bg-gradient-to-br from-cyan-950/40 via-[#0a0a0f] to-transparent"></div>
      <div class="absolute -right-40 top-16 hidden h-[540px] w-[540px] rounded-full bg-cyan-500/10 blur-3xl md:block"></div>
      <div class="absolute -left-40 bottom-0 hidden h-[440px] w-[440px] rounded-full bg-violet-500/10 blur-3xl md:block"></div>

      <div class="mx-auto max-w-5xl space-y-8 text-center">
        <Badge variant="outline" className="border-cyan-800/60 bg-cyan-950/30 text-cyan-300 font-mono text-xs uppercase tracking-wider">
          <Sparkles className="mr-1.5 h-3 w-3" /> live · verified · measured
        </Badge>

        <h1 class="text-4xl font-semibold leading-[1.05] tracking-tight text-slate-100 sm:text-5xl md:text-6xl lg:text-7xl">
          Ride a Signal
        </h1>

        <p class="mx-auto max-w-3xl text-base leading-relaxed text-slate-400 md:text-lg">
          One real signal. Nine stops. Click → edge → route → sandwich → LLM →
          mark → loops → highway → harden. Every step measured, every step honest.
        </p>

        <div class="mx-auto flex max-w-3xl flex-wrap items-center justify-center gap-3 pt-4">
          <span class="inline-flex items-center gap-2 rounded-full border border-emerald-800/50 bg-emerald-950/30 px-4 py-1.5 font-mono text-xs text-emerald-300">
            <Zap className="h-3 w-3" /> routing &lt;0.005ms
          </span>
          <span class="inline-flex items-center gap-2 rounded-full border border-cyan-800/50 bg-cyan-950/30 px-4 py-1.5 font-mono text-xs text-cyan-300">
            <Activity className="h-3 w-3" /> mark &lt;0.001ms
          </span>
          <span class="inline-flex items-center gap-2 rounded-full border border-violet-800/50 bg-violet-950/30 px-4 py-1.5 font-mono text-xs text-violet-300">
            <GitBranch className="h-3 w-3" /> gateway &lt;10ms
          </span>
          <span class="inline-flex items-center gap-2 rounded-full border border-amber-800/50 bg-amber-950/30 px-4 py-1.5 font-mono text-xs text-amber-300">
            <Shield className="h-3 w-3" /> 320 tests · &lt;7s
          </span>
        </div>

        <div class="pt-4 text-xs font-mono text-slate-600">
          ↓ scroll — or skip to the <a href="#lifecycle" class="text-cyan-400 hover:underline">lifecycle speedrun</a>
        </div>
      </div>
    </section>

    <!-- Section 1 · The Interactive Journey -->
    <section class="border-b border-slate-800 px-6 py-16 md:px-10 md:py-24">
      <div class="mx-auto max-w-5xl space-y-10">
        <div class="space-y-2">
          <p class="font-mono text-xs uppercase tracking-wider text-cyan-400">§ 01 · The Journey</p>
          <h2 class="text-3xl font-semibold tracking-tight text-slate-100 sm:text-4xl">
            Send a signal. Watch it travel.
          </h2>
          <p class="max-w-2xl text-sm text-slate-400 md:text-base">
            Click the button. The signal fires into a real Cloudflare Worker,
            runs through every layer of the substrate, and streams its timing
            back over SSE. No mock. No delay. Live numbers.
          </p>
        </div>
        <SpeedJourney client:load />
      </div>
    </section>

    <!-- Section 2 · Why it's fast -->
    <section class="border-b border-slate-800 bg-slate-950/40 px-6 py-16 md:px-10 md:py-24">
      <div class="mx-auto max-w-6xl space-y-12">
        <div class="space-y-3 text-center">
          <p class="font-mono text-xs uppercase tracking-wider text-cyan-400">§ 02 · The Math</p>
          <h2 class="text-3xl font-semibold tracking-tight text-slate-100 sm:text-4xl">
            Why it&rsquo;s fast
          </h2>
          <p class="mx-auto max-w-2xl text-sm text-slate-400 md:text-base">
            We don&rsquo;t compete on LLMs. Everyone&rsquo;s inference runs at physics speed.
            The difference is everything around it — and everything around it is arithmetic.
          </p>
        </div>

        <div class="grid gap-4 md:grid-cols-3">
          {principles.map((p) => (
            <Card className="bg-[#111118] border-slate-800 hover:border-slate-700 transition-colors">
              <CardHeader className="space-y-3">
                <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-cyan-500/10 text-cyan-400">
                  <p.icon className="h-5 w-5" />
                </div>
                <CardTitle className="text-slate-100">{p.title}</CardTitle>
                <CardDescription className="text-slate-400 leading-relaxed">
                  {p.body}
                </CardDescription>
              </CardHeader>
              <CardContent>
                <div class="inline-flex items-center gap-2 rounded-md bg-slate-900 px-3 py-1.5 font-mono text-xs text-emerald-400 ring-1 ring-emerald-900/40">
                  {p.stat}
                </div>
              </CardContent>
            </Card>
          ))}
        </div>
      </div>
    </section>

    <!-- Section 3 · Lifecycle speedrun -->
    <section id="lifecycle" class="border-b border-slate-800 px-6 py-16 md:px-10 md:py-24">
      <div class="mx-auto max-w-5xl space-y-10">
        <div class="space-y-2">
          <p class="font-mono text-xs uppercase tracking-wider text-cyan-400">§ 03 · End-to-End</p>
          <h2 class="text-3xl font-semibold tracking-tight text-slate-100 sm:text-4xl">
            Lifecycle speedrun
          </h2>
          <p class="max-w-2xl text-sm text-slate-400 md:text-base">
            Full commerce loop on Sui testnet: create wallet, fund, list service,
            discover, message, sell, subscribe, browse, buy, verify. Ten stages.
            One continuous run. Real wallets, real digests.
          </p>
        </div>
        <LifecycleSpeedrun client:visible />
      </div>
    </section>

    <!-- Section 4 · Verified benchmarks -->
    <section class="border-b border-slate-800 bg-slate-950/40 px-6 py-16 md:px-10 md:py-24">
      <div class="mx-auto max-w-6xl space-y-12">
        <div class="space-y-3 text-center">
          <p class="font-mono text-xs uppercase tracking-wider text-cyan-400">§ 04 · Receipts</p>
          <h2 class="text-3xl font-semibold tracking-tight text-slate-100 sm:text-4xl">
            Verified benchmarks
          </h2>
          <p class="mx-auto max-w-2xl text-sm text-slate-400 md:text-base">
            Every number below is produced by <code class="rounded bg-slate-900 px-1.5 py-0.5 text-xs text-cyan-300">scripts/speed-report.ts</code>
            after every <code class="rounded bg-slate-900 px-1.5 py-0.5 text-xs text-cyan-300">bun test</code>.
            p50 observed vs. budget target · PERF_SCALE=3 · 125 samples.
          </p>
        </div>

        <div class="grid gap-6 lg:grid-cols-2">
          {benchCards.map((group) => (
            <Card className="bg-[#111118] border-slate-800">
              <CardHeader className="pb-3">
                <CardTitle className={`text-base ${group.titleCls}`}>{group.title}</CardTitle>
                <CardDescription className="text-xs text-slate-500">
                  budget · p50 observed · replaces
                </CardDescription>
              </CardHeader>
              <CardContent className="space-y-1.5">
                {group.ops.map((o) => (
                  <div class="grid grid-cols-[1fr_auto_auto] items-center gap-3 rounded-md border border-slate-800/60 bg-slate-900/40 px-3 py-2">
                    <div class="min-w-0">
                      <p class="truncate text-sm font-mono text-slate-200">{o.op}</p>
                      <p class="truncate text-[10px] text-slate-500">{o.replaces}</p>
                    </div>
                    <span class="font-mono text-[10px] uppercase tracking-wider text-slate-500">
                      budget <span class="text-slate-300">{o.budget}</span>
                    </span>
                    <span class={`font-mono text-xs tabular-nums ${group.p50Cls}`}>
                      {o.p50}
                    </span>
                  </div>
                ))}
              </CardContent>
            </Card>
          ))}
        </div>

        <p class="text-center text-xs text-slate-500">
          Full table: <a href="/speedtest" class="text-cyan-400 hover:underline">/speedtest</a> ·
          source: <code class="text-slate-400">docs/speed-test.md</code>
        </p>
      </div>
    </section>

    <!-- CTA -->
    <section class="px-6 py-20 md:px-10 md:py-28">
      <div class="mx-auto max-w-3xl space-y-8 text-center">
        <h2 class="text-3xl font-semibold tracking-tight text-slate-100 sm:text-4xl">
          Run it yourself.
        </h2>
        <p class="text-sm text-slate-400 md:text-base">
          Don&rsquo;t take our word for it. Every benchmark above is reproducible in
          under seven seconds on your machine. The substrate has no secret sauce —
          just 670 lines of engine and a formula.
        </p>
        <div class="flex flex-wrap items-center justify-center gap-3">
          <a href="/speedtest">
            <Button className="bg-cyan-500 hover:bg-cyan-400 text-slate-950 font-medium">
              See the engine benchmarks
            </Button>
          </a>
          <a href="https://api.one.ie/health" target="_blank" rel="noopener noreferrer">
            <Button variant="outline" className="border-slate-700 text-slate-300 hover:bg-slate-800">
              Ping the gateway
            </Button>
          </a>
          <a href="https://dev.one.ie/api/export/highways" target="_blank" rel="noopener noreferrer">
            <Button variant="outline" className="border-slate-700 text-slate-300 hover:bg-slate-800">
              Export live highways
            </Button>
          </a>
        </div>
        <div class="pt-6 text-xs text-slate-600">
          <span class="font-mono">math + pheromone + 4-layer sandwich = </span>
          <span class="font-mono text-cyan-400">instant routing, forever learning.</span>
        </div>
      </div>
    </section>
  </main>
</Layout>
