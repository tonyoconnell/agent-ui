---
import Layout from "@/layouts/Layout.astro"
import { SpeedJourney } from "@/components/speed/SpeedJourney"
import { LifecycleSpeedrun } from "@/components/speed/LifecycleSpeedrun"

export const prerender = true
---

<Layout title="Speed — Ride a Signal Through the World">
  <main class="min-h-screen bg-[#0a0a0f] text-slate-200 p-6 md:p-10">
    <div class="max-w-4xl mx-auto space-y-10">
      <header class="space-y-2">
        <h1 class="text-3xl md:text-4xl font-semibold tracking-tight">
          Ride a Signal
        </h1>
        <p class="text-slate-400 max-w-3xl text-sm md:text-base">
          Watch one real signal travel through 9 stops — click, edge, route, sandwich,
          LLM, mark, loops, highway, harden — with live timings at every step.
        </p>
      </header>

      <SpeedJourney client:load />

      <section class="pt-8 border-t border-slate-800 space-y-4">
        <h2 class="text-xl font-semibold text-slate-200">Lifecycle Speedrun</h2>
        <p class="text-sm text-slate-400">
          Full lifecycle wall-time: wallet, fund, list, discover, message, sell, subscribe, browse, buy, verify.
        </p>
        <LifecycleSpeedrun client:visible />
      </section>

      <footer class="text-xs text-slate-500 pt-4 border-t border-slate-800">
        Engine-level ms benchmarks live at <a class="text-cyan-500 hover:underline" href="/speedtest">/speedtest</a>.
      </footer>
    </div>
  </main>
</Layout>
