---
import Layout from "@/layouts/Layout.astro"
import { auth } from "@/lib/auth"

const session = await auth.api.getSession({ headers: Astro.request.headers })
if (!session) return Astro.redirect("/login")

type ApiKey = { id: string; label: string; createdAt: string }
let keys: ApiKey[] = []

try {
  const res = await fetch(new URL("/api/settings/keys", Astro.request.url), {
    headers: Astro.request.headers,
  })
  if (res.ok) keys = await res.json()
} catch { /* show empty list on error */ }
---

<Layout title="API Keys — Settings">
  <main class="min-h-screen bg-[#0a0a0f] text-white px-4 py-12 max-w-2xl mx-auto">
    <h1 class="text-2xl font-semibold mb-1">API Keys</h1>
    <p class="text-sm text-zinc-400 mb-8">
      Keys are AES-GCM encrypted at rest, bound to your session.
    </p>

    <!-- Key list -->
    <div class="mb-10">
      {keys.length === 0 ? (
        <p class="text-zinc-500 text-sm">No keys stored yet.</p>
      ) : (
        <table class="w-full text-sm border-collapse">
          <thead>
            <tr class="text-zinc-400 border-b border-zinc-800">
              <th class="text-left py-2 pr-4 font-medium">Label</th>
              <th class="text-left py-2 pr-4 font-medium">Added</th>
              <th class="text-left py-2 font-medium">Action</th>
            </tr>
          </thead>
          <tbody>
            {keys.map((k) => (
              <tr class="border-b border-zinc-900 hover:bg-zinc-900/40 transition-colors">
                <td class="py-2 pr-4 font-mono text-zinc-100">{k.label}</td>
                <td class="py-2 pr-4 text-zinc-400">
                  {new Date(k.createdAt).toLocaleDateString()}
                </td>
                <td class="py-2">
                  <form method="POST" action={`/api/settings/keys/${k.id}`}>
                    <input type="hidden" name="_method" value="DELETE" />
                    <button
                      type="submit"
                      class="text-red-500 hover:text-red-400 text-xs transition-colors"
                    >
                      Delete
                    </button>
                  </form>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      )}
    </div>

    <!-- Add key form -->
    <div class="border border-zinc-800 rounded-lg p-6 bg-zinc-900/30">
      <h2 class="text-sm font-medium text-zinc-300 mb-4">Add a key</h2>
      <form method="POST" action="/api/settings/keys" class="flex flex-col gap-3">
        <input
          name="label"
          type="text"
          placeholder="openrouter"
          required
          class="bg-[#0a0a0f] border border-zinc-700 rounded px-3 py-2 text-sm text-white placeholder-zinc-600 focus:outline-none focus:border-zinc-500"
        />
        <input
          name="value"
          type="password"
          placeholder="sk-or-..."
          required
          class="bg-[#0a0a0f] border border-zinc-700 rounded px-3 py-2 text-sm text-white placeholder-zinc-600 focus:outline-none focus:border-zinc-500"
        />
        <button
          type="submit"
          class="self-start bg-white text-black text-sm font-medium px-4 py-2 rounded hover:bg-zinc-200 transition-colors"
        >
          Add Key
        </button>
      </form>
    </div>
  </main>
</Layout>
