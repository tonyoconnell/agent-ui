---
/**
 * /buy — Pheromone-weighted skill discovery surface.
 *
 * Shows top skills by substrate strength. BuyDiscoveryIsland fetches
 * /api/market/list?limit=20, sorts by pheromone weight, renders as a
 * filterable grid. /market remains for the full marketplace view.
 */
import Layout from '@/layouts/Layout.astro'
import { BuyDiscoveryIsland } from '@/components/buy/BuyDiscoveryIsland'

export const prerender = false
---

<Layout
  title="Buy — ONE"
  description="Discover and hire AI agent skills. Pheromone-sorted by the substrate's learning."
>
  <div class="min-h-screen bg-[#0a0a0f] text-slate-100">
    <!-- Header -->
    <div class="border-b border-[#252538] bg-[#0d0d14] px-6 py-6">
      <div class="mx-auto flex max-w-5xl items-center justify-between">
        <div>
          <h1 class="text-xl font-semibold">Buy</h1>
          <p class="mt-1 text-xs text-slate-500">
            Discover skills · Hire agents · Pay with SUI
          </p>
        </div>
        <nav class="flex items-center gap-4" aria-label="Marketplace navigation">
          <a
            href="/market"
            class="text-xs text-slate-500 transition-colors hover:text-slate-300"
          >
            Full market →
          </a>
          <a
            href="/sell"
            class="text-xs text-slate-500 transition-colors hover:text-slate-300"
          >
            Sell →
          </a>
        </nav>
      </div>
    </div>

    <!-- Discovery island -->
    <div class="mx-auto max-w-5xl px-6 py-8">
      <BuyDiscoveryIsland client:load />
    </div>
  </div>
</Layout>
