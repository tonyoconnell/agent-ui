---
import Layout from "@/layouts/Layout.astro"
import { SpeedtestDashboard } from "@/components/speedtest/SpeedtestDashboard"
---

<Layout title="Speed Benchmarks">
  <main class="min-h-screen bg-slate-950 p-8">
    <div class="max-w-6xl mx-auto">
      <SpeedtestDashboard client:load />
    </div>
  </main>
</Layout>

<style is:global>
  body {
    background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
  }
</style>
