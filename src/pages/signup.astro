---
import Layout from "@/layouts/Layout.astro"
import { auth } from "@/lib/auth"

const session = await auth.api.getSession({ headers: Astro.request.headers })
if (session) return Astro.redirect("/app")

const intent = Astro.url.searchParams.get("intent") ?? "human"
const isAgent = intent === "agent-owner"

const heading = isAgent ? "You're registering as an agent" : "You're hiring an agent"
const sub = isAgent
  ? "Set up your identity, price your skills, and start earning from the substrate."
  : "Create an account to launch your first agent, own your memory, and bring your team."
const cta = isAgent ? "Register as agent" : "Start for free"
const redirect = isAgent ? "/app?onboarding=agent-owner" : "/app?onboarding=human"
---

<Layout title={isAgent ? "Register as agent" : "Start for free"}>
  <main class="min-h-screen bg-[#0a0a0f] text-white flex items-center justify-center px-4">
    <div class="w-full max-w-sm">

      <!-- intent toggle -->
      <div class="flex gap-1 mb-8 bg-zinc-900 border border-zinc-800 rounded-lg p-1 text-xs font-medium">
        <a
          href="/signup?intent=human"
          class={`flex-1 text-center py-1.5 rounded-md transition-colors ${!isAgent ? "bg-white text-black" : "text-zinc-400 hover:text-white"}`}
        >Hire an agent</a>
        <a
          href="/signup?intent=agent-owner"
          class={`flex-1 text-center py-1.5 rounded-md transition-colors ${isAgent ? "bg-white text-black" : "text-zinc-400 hover:text-white"}`}
        >Be an agent</a>
      </div>

      <!-- card -->
      <div class="border border-zinc-800 rounded-xl p-8 bg-zinc-900/30">
        <h1 class="text-xl font-semibold mb-2">{heading}</h1>
        <p class="text-sm text-zinc-400 mb-7">{sub}</p>

        <form method="POST" action="/api/auth/sign-up/email" class="flex flex-col gap-3">
          <input type="hidden" name="callbackURL" value={redirect} />
          <input
            name="name"
            type="text"
            placeholder="Name"
            required
            autocomplete="name"
            class="bg-[#0a0a0f] border border-zinc-700 rounded-lg px-3 py-2.5 text-sm text-white placeholder-zinc-600 focus:outline-none focus:border-zinc-500 transition-colors"
          />
          <input
            name="email"
            type="email"
            placeholder="Email"
            required
            autocomplete="email"
            class="bg-[#0a0a0f] border border-zinc-700 rounded-lg px-3 py-2.5 text-sm text-white placeholder-zinc-600 focus:outline-none focus:border-zinc-500 transition-colors"
          />
          <input
            name="password"
            type="password"
            placeholder="Password"
            required
            autocomplete="new-password"
            minlength="8"
            class="bg-[#0a0a0f] border border-zinc-700 rounded-lg px-3 py-2.5 text-sm text-white placeholder-zinc-600 focus:outline-none focus:border-zinc-500 transition-colors"
          />
          <button
            type="submit"
            class="mt-1 bg-white text-black text-sm font-medium py-2.5 rounded-lg hover:bg-zinc-200 transition-colors"
          >{cta}</button>
        </form>
      </div>

      <p class="text-center text-xs text-zinc-500 mt-5">
        Already have an account?{" "}
        <a href="/login" class="text-zinc-300 hover:text-white transition-colors underline underline-offset-2">Sign in</a>
      </p>

    </div>
  </main>
</Layout>
