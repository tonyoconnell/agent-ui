# =============================================================================
# WORLD.TQL — The Schema
# =============================================================================
#
# One file. One world. One source of truth.
#
# The world moves signals. TypeDB remembers.
#
# Runtime (nervous system):
#   world.ts — units, signals, strength, resistance, queue
#   persist.ts — actor, flow, know, recall
#
# TypeDB (brain):
#   unit — persisted actors (model, prompt, generation)
#   path — persisted pheromone (strength, resistance, revenue)
#   signal — event log (who sent what, paid what)
#   capability — who can do what at what price
#   group + membership — group queries
#   hypothesis/frontier/objective — knowledge (slow loops)
#
# Tasks are handlers on units (.on()). Dependencies are continuations (.then()).
# Trails are scent map entries. TypeDB doesn't track task lifecycle —
# the world does.
#
# 6 Dimensions:
#   1. Groups    — groups (scope, isolation, hierarchy)
#   2. Actors    — units (humans, agents, LLMs)
#   3. Things    — skills with optional price (capability)
#   4. Paths     — weighted connections (pheromone)
#   5. Events    — signals (who sent what, paid how much)
#   6. Knowledge — hypotheses, frontiers, objectives (emergent)
#
# =============================================================================

define


# =============================================================================
# DIMENSION 1: GROUPS
# =============================================================================

entity group,
    owns gid @key,
    owns name,
    owns purpose,
    owns group-type,              # "persona", "team", "colony", "dao"
    owns status,
    owns created,
    plays hierarchy:parent,
    plays hierarchy:child,
    plays membership:group;

relation hierarchy,
    relates parent,
    relates child;


# =============================================================================
# DIMENSION 2: ACTORS
# =============================================================================

entity unit,
    owns uid @key,
    owns name,                    # canonical display name (owner-set)
    owns alias-ant,               # skin-specific: ant metaphor
    owns alias-brain,             # skin-specific: brain metaphor
    owns alias-team,              # skin-specific: team metaphor
    owns alias-mail,              # skin-specific: mail metaphor
    owns alias-water,             # skin-specific: water metaphor
    owns alias-signal,            # skin-specific: signal metaphor
    owns unit-kind,               # "human", "agent", "llm", "system"
    owns wallet,                  # Sui address
    owns sui-unit-id,             # Sui Unit object ID (0x...)
    owns status,                  # "active" | "proven" | "at-risk" (inferred)
    owns balance,
    owns reputation,
    owns success-rate,            # 0.0-1.0
    owns activity-score,          # 0.0-100.0
    owns sample-count,            # interaction count
    owns model,                   # "opus", "sonnet", "haiku"
    owns system-prompt,           # mutable — evolves over time
    owns generation,              # prompt iteration count
    owns last-evolved,            # evolution cooldown
    owns tag @card(0..),          # flat tags: "scout", "harvester", "team-alpha", etc.
    owns cost-per-signal,         # model economics
    owns created,
    plays path:source,
    plays path:target,
    plays capability:provider,
    plays membership:member,
    plays signal:sender,
    plays signal:receiver,
    plays contribution-event:contributor-unit,
    plays api-authorization:authorized-unit;


# =============================================================================
# DIMENSION 3: THINGS (skills)
# =============================================================================
# A skill with a price IS a service. No lifecycle — that lives in the runtime.
# unit —[capability, price: 0.01]→ skill "translate"

entity skill,
    owns skill-id @key,
    owns name,
    owns description,
    owns tag @card(0..),          # flat tags: "build", "wire", "P0", "frontend", etc.
    owns price,                   # x402 price (0 = free, >0 = paid service)
    owns currency,                # "SUI", "USDC", "FET"
    plays capability:offered;


# =============================================================================
# DIMENSION 3b: TASKS (prioritized work items)
# =============================================================================
# Tasks extracted from docs. Priority = value + phase + persona + blocking.
# Each task shares its task-id with a skill-id for capability routing.
# Pheromone adjusts effective priority at runtime.

entity task,
    owns task-id @key,
    owns name,
    owns description,
    owns tag @card(0..),
    owns task-status,              # "open" | "active" | "done" | "blocked"
    owns task-value,               # "critical" | "high" | "medium"
    owns task-effort,              # "low" (haiku) | "medium" (sonnet) | "high" (opus)
    owns task-wave,                # "W1" | "W2" | "W3" | "W4" — wave position in cycle
    owns task-phase,               # "C1".."C7"
    owns task-persona,             # "ceo" | "dev" | "investor" | "gamer" | "kid" | "freelancer" | "agent"
    owns task-context,             # "dsl,routing,dictionary" — doc keys loaded at selection
    owns priority-score,           # computed: value + phase + persona + blocking
    owns priority-formula,         # auditable: "critical=30 + C1=40 + ceo=25 + blocks(3)=15"
    owns source-file,              # which doc it came from
    owns exit-condition,           # what "done" looks like
    owns done,                     # boolean
    owns created,
    owns owner,
    owns claimed-at,
    plays blocks:blocker,
    plays blocks:blocked;

entity wave-lock,
    owns wave-lock-id @key,
    owns owner,
    owns claimed-at;

relation blocks,
    relates blocker,
    relates blocked;


# =============================================================================
# DIMENSION 4: PATHS
# =============================================================================

# Unit-to-unit: who works with whom, how well, how much revenue
relation path,
    relates source,
    relates target,
    owns strength,                # mark() adds weight here
    owns resistance,              # warn() adds weight here
    owns traversals,
    owns revenue,                 # sum of x402 payments on this path
    owns last-used,
    owns fade-rate,               # per-path decay
    owns sui-path-id,             # Sui Path object ID (0x...)
    owns peak-strength,           # highest strength ever reached
    owns path-status;             # INFERRED: "highway" | "fresh" | "fading" | "toxic"

# Unit can do skill (at a price)
relation capability,
    relates provider,
    relates offered,
    owns price;

# Unit belongs to swarm
relation membership,
    relates group,
    relates member,
    owns joined-at;


# =============================================================================
# DIMENSION 5: EVENTS
# =============================================================================

relation signal,
    relates sender,
    relates receiver,
    owns data,                    # JSON string
    owns amount,                  # x402 payment (0 = free)
    owns success,
    owns latency,                 # ms
    owns ts,
    owns scope;                   # "private" | "group" | "public"


# =============================================================================
# DIMENSION 6: KNOWLEDGE
# =============================================================================

entity hypothesis,
    owns hid @key,
    owns statement,
    owns hypothesis-status,       # "pending" | "testing" | "confirmed" | "rejected"
    owns observations-count,
    owns p-value,
    owns action-ready,            # INFERRED
    owns source,                  # "observed" | "asserted" | "verified"
    owns observed-at,             # when the substrate learned it
    owns valid-from,              # when the fact became true
    owns valid-until;             # when it stopped being true (optional)

entity frontier,
    owns fid @key,
    owns frontier-type,
    owns frontier-description,
    owns expected-value,
    owns frontier-status,         # "unexplored" | "exploring" | "exhausted"
    plays spawns:frontier;

entity objective,
    owns oid @key,
    owns objective-type,
    owns objective-description,
    owns priority-score,
    owns progress,                # 0.0-1.0
    owns objective-status,        # "pending" | "active" | "complete"
    plays spawns:objective;

relation spawns,
    relates frontier,
    relates objective;

entity contribution,
    owns contribution-id @key,
    owns impact-score,
    owns contribution-type,       # "signal", "payment", "discovery"
    plays contribution-event:contribution;

relation contribution-event,
    relates contributor-unit,
    relates contribution;


# =============================================================================
# DIMENSION 7: API AUTHENTICATION
# =============================================================================

entity api-key,
    owns api-key-id @key,
    owns key-hash,                # bcrypt hash of actual key (never store plaintext)
    owns user-id,                 # reference to user (email or ID)
    owns permissions,             # comma-separated: "read", "write", "add", "edit", "delete"
    owns key-status,              # "active" | "revoked"
    owns created,
    owns last-used,
    owns expires-at,
    plays api-authorization:api-key;

relation api-authorization,
    relates api-key,
    relates authorized-unit;      # which unit this key can act as


# =============================================================================
# DIMENSION 7b: BETTER AUTH — Human session entities
# =============================================================================
# These are consumed by typedb-auth-adapter.ts via the BetterAuth session layer.
# Separate from substrate units — humans link to the substrate via /api/auth/agent.

entity auth-user,
    owns auth-id @key,
    owns auth-name,
    owns auth-email,
    owns auth-email-verified,
    owns auth-image,
    owns auth-password,
    owns auth-created-at,
    owns auth-updated-at;

entity auth-session,
    owns auth-id @key,
    owns auth-user-id,
    owns auth-token,
    owns auth-expires-at,
    owns auth-ip-address,
    owns auth-user-agent,
    owns auth-created-at,
    owns auth-updated-at;

entity auth-account,
    owns auth-id @key,
    owns auth-account-id,
    owns auth-provider-id,
    owns auth-user-id,
    owns auth-access-token,
    owns auth-refresh-token,
    owns auth-id-token,
    owns auth-access-token-expires-at,
    owns auth-refresh-token-expires-at,
    owns auth-scope,
    owns auth-password,
    owns auth-created-at,
    owns auth-updated-at;

entity auth-verification,
    owns auth-id @key,
    owns auth-identifier,
    owns auth-value,
    owns auth-expires-at,
    owns auth-created-at,
    owns auth-updated-at;

entity auth-rate-limit,
    owns auth-id @key,
    owns auth-rate-limit-key,
    owns auth-count,
    owns auth-last-request;


# =============================================================================
# ATTRIBUTES
# =============================================================================

# Identifiers
attribute gid, value string;
attribute uid, value string;
attribute skill-id, value string;
attribute hid, value string;
attribute fid, value string;
attribute oid, value string;
attribute contribution-id, value string;
attribute task-id, value string;
attribute api-key-id, value string;
attribute key-hash, value string;
attribute user-id, value string;
attribute permissions, value string;
attribute key-status, value string;

# BetterAuth attributes
attribute auth-id, value string;
attribute auth-name, value string;
attribute auth-email, value string;
attribute auth-email-verified, value boolean;
attribute auth-image, value string;
attribute auth-password, value string;
attribute auth-user-id, value string;
attribute auth-token, value string;
attribute auth-ip-address, value string;
attribute auth-user-agent, value string;
attribute auth-account-id, value string;
attribute auth-provider-id, value string;
attribute auth-access-token, value string;
attribute auth-refresh-token, value string;
attribute auth-id-token, value string;
attribute auth-scope, value string;
attribute auth-identifier, value string;
attribute auth-value, value string;
attribute auth-rate-limit-key, value string;
# Temporal (epoch millis stored as integer — BetterAuth serializes Date as getTime())
attribute auth-created-at, value integer;
attribute auth-updated-at, value integer;
attribute auth-expires-at, value integer;
attribute auth-access-token-expires-at, value integer;
attribute auth-refresh-token-expires-at, value integer;
attribute auth-last-request, value integer;
attribute auth-count, value integer;

# Descriptive
attribute name, value string;
attribute description, value string;
attribute purpose, value string;
attribute statement, value string;
attribute data, value string;
attribute frontier-description, value string;
attribute objective-description, value string;
attribute group-type, value string;
attribute unit-kind, value string;
attribute tag, value string;
attribute contribution-type, value string;
attribute frontier-type, value string;
attribute objective-type, value string;
attribute source, value string;           # hypothesis: "observed" | "asserted" | "verified"
attribute scope, value string;            # signal: "private" | "group" | "public"
attribute wallet, value string;
attribute sui-unit-id, value string;
attribute sui-path-id, value string;
attribute currency, value string;
attribute model, value string;
attribute system-prompt, value string;
attribute priority-formula, value string;
attribute source-file, value string;
attribute exit-condition, value string;
attribute task-value, value string;
attribute task-effort, value string;       # "low" (haiku) | "medium" (sonnet) | "high" (opus)
attribute task-wave, value string;         # "W1" | "W2" | "W3" | "W4"
attribute task-phase, value string;
attribute task-persona, value string;
attribute task-context, value string;      # "dsl,routing,dictionary" — doc keys for context
attribute owner, value string;
attribute claimed-at, value datetime;
attribute wave-lock-id, value string;

# Four-layer naming (per-skin aliases)
attribute alias-ant, value string;         # ant metaphor override
attribute alias-brain, value string;       # brain metaphor override
attribute alias-team, value string;        # team metaphor override
attribute alias-mail, value string;        # mail metaphor override
attribute alias-water, value string;       # water metaphor override
attribute alias-signal, value string;      # signal metaphor override

# Status
attribute status, value string;
attribute task-status, value string;
attribute path-status, value string;
attribute hypothesis-status, value string;
attribute frontier-status, value string;
attribute objective-status, value string;

# Numeric (double)
attribute strength, value double;
attribute resistance, value double;
attribute fade-rate, value double;
attribute balance, value double;
attribute reputation, value double;
attribute success-rate, value double;
attribute activity-score, value double;
attribute price, value double;
attribute revenue, value double;
attribute amount, value double;
attribute p-value, value double;
attribute expected-value, value double;
attribute priority-score, value double;
attribute progress, value double;
attribute impact-score, value double;
attribute latency, value double;
attribute peak-strength, value double;
attribute cost-per-signal, value double;

# Numeric (integer)
attribute traversals, value integer;
attribute sample-count, value integer;
attribute observations-count, value integer;
attribute generation, value integer;

# Boolean
attribute action-ready, value boolean;
attribute success, value boolean;
attribute done, value boolean;

# Temporal
attribute created, value datetime;
attribute last-used, value datetime;
attribute expires-at, value datetime;
attribute joined-at, value datetime;
attribute ts, value datetime;
attribute last-evolved, value datetime;
attribute observed-at, value datetime;
attribute valid-from, value datetime;
attribute valid-until, value datetime;


# =============================================================================
# CLASSIFICATION FUNCTIONS
# =============================================================================

# --- Paths ---

fun path_status($e: path) -> string:
    match $e has strength $s, has resistance $a, has traversals $t;
    return first
        if ($a > $s and $a >= 10.0) then "toxic"
        else if ($s >= 50.0) then "highway"
        else if ($s >= 10.0 and $s < 50.0 and $t < 10) then "fresh"
        else if ($s > 0.0 and $s < 5.0) then "fading"
        else "active";

fun is_highway($e: path) -> boolean:
    match $e has strength $s; $s >= 50.0;
    return first true;

# --- Validation (the deterministic sandwich) ---

# PRE-CHECK: Can this unit receive this skill signal?
fun can_receive($u: unit, $sk: skill) -> boolean:
    match (provider: $u, offered: $sk) isa capability;
    return first true;

# PRE-CHECK: Is the path to this unit safe? (not toxic)
fun is_safe($from: unit, $to: unit) -> boolean:
    match (source: $from, target: $to) isa path, has strength $s, has resistance $a;
    return first if ($a > $s and $a >= 10.0) then false else true;

# PRE-CHECK: Is the signal within budget?
fun within_budget($u: unit, $sk: skill, $amount: double) -> boolean:
    match (provider: $u, offered: $sk) isa capability, has price $p;
    return first if ($amount >= $p) then true else false;

# POST-CHECK: Does a referenced unit actually exist?
fun unit_exists($uid: string) -> boolean:
    match $u isa unit, has uid $uid;
    return first true;

# POST-CHECK: Is a unit performing well enough to trust?
fun is_trustworthy($u: unit) -> boolean:
    match $u has success-rate $sr, has sample-count $sc;
    return first if ($sr >= 0.50 or $sc < 10) then true else false;

# COMBINED: Full pre-flight check for a signal
fun preflight($from: unit, $to: unit, $sk: skill) -> boolean:
    match (provider: $to, offered: $sk) isa capability;
          (source: $from, target: $to) isa path, has strength $s, has resistance $a;
    return first if ($a > $s and $a >= 10.0) then false else true;

# --- Actors ---

fun unit_classification($u: unit) -> string:
    match $u has success-rate $sr, has activity-score $as, has sample-count $sc;
    return first
        if ($sr >= 0.75 and $as >= 70.0 and $sc >= 50) then "proven"
        else if ($sr < 0.40 and $as >= 25.0 and $sc >= 30) then "at-risk"
        else "active";

# --- Evolution ---

fun needs_evolution($u: unit) -> boolean:
    match $u has success-rate $sr, has sample-count $sc;
          $sr < 0.50; $sc >= 20;
    return first true;

# --- Hypothesis ---

fun is_action_ready($h: hypothesis) -> boolean:
    match $h has hypothesis-status "confirmed",
          has p-value $p, has observations-count $n;
          $p <= 0.05; $n >= 50;
    return first true;


# =============================================================================
# FUNCTIONS
# =============================================================================

# --- Routing ---

fun highways(threshold: double = 10.0, min_traversals: integer = 50) -> { path }:
    match $e isa path, has strength $s, has traversals $t;
          $s >= threshold; $t >= min_traversals;
    return { $e };

fun optimal_route($from: unit, $skill: skill) -> unit:
    match (source: $from, target: $to) isa path, has strength $s;
          (provider: $to, offered: $skill) isa capability;
    sort $s desc; limit 1;
    return $to;

fun cheapest_provider($skill: skill) -> unit:
    match (provider: $u, offered: $skill) isa capability, has price $p;
    sort $p asc; limit 1;
    return $u;

fun suggest_route($from: unit, $skill: skill) -> { uid, strength }:
    match $from isa unit; $skill isa skill;
          (source: $from, target: $to) isa path, has strength $s;
          (provider: $to, offered: $skill) isa capability;
          $to has uid $id; $s >= 5.0;
    sort $s desc; limit 5;
    return { $id, $s };

# --- Actors ---

fun proven_units() -> { unit }:
    match $u isa unit, has status "proven";
    return { $u };

fun at_risk_units() -> { unit }:
    match $u isa unit, has status "at-risk";
    return { $u };

fun units_by_kind($kind: string) -> { unit }:
    match $u isa unit, has unit-kind $kind, has status "active";
    return { $u };

fun collaborators($me: unit) -> { unit }:
    match (member: $me, group: $g) isa membership;
          (member: $peer, group: $g) isa membership;
          not { $me is $peer; };
    return { $peer };

fun group_members($group_name: string) -> { unit }:
    match $grp isa group, has name $group_name;
          (group: $grp, member: $u) isa membership;
    return { $u };

# --- Skills ---

fun skills_by_tag($tag: string) -> { skill }:
    match $s isa skill, has tag $tag;
    return { $s };

fun priced_skills($tag: string) -> { skill }:
    match $s isa skill, has tag $tag, has price $p; $p > 0.0;
    return { $s };

fun units_by_tag($tag: string) -> { unit }:
    match $u isa unit, has tag $tag;
    return { $u };

# --- Knowledge ---

fun actionable_hypotheses() -> { hypothesis }:
    match $h isa hypothesis, has action-ready true;
    return { $h };

fun active_tests() -> { hypothesis }:
    match $h isa hypothesis, has hypothesis-status "testing";
    return { $h };

fun promising_frontiers() -> { frontier }:
    match $f isa frontier, has frontier-status "unexplored", has expected-value $ev;
          $ev >= 0.5;
    return { $f };

fun active_objectives() -> { objective }:
    match $o isa objective, has objective-status $s;
          $s in ["pending", "active"];
    return { $o };

# --- Aggregates ---

fun total_contribution($name: string) -> double:
    match $u isa unit, has name $name;
          $ev(contributor-unit: $u, contribution: $c) isa contribution-event;
          $c has impact-score $i;
    return sum($i);

fun highway_count(threshold: double = 10.0) -> integer:
    match $e isa path, has strength $s; $s >= threshold;
    return count($e);

fun total_revenue() -> double:
    match $e isa path, has revenue $r;
    return sum($r);


# --- Tasks ---

fun open_tasks() -> { task }:
    match $t isa task, has done false;
    return { $t };

fun tasks_by_priority() -> { task, priority-score }:
    match $t isa task, has done false, has priority-score $p;
    sort $p desc;
    return { $t, $p };

fun tasks_by_phase($phase: string) -> { task }:
    match $t isa task, has task-phase $phase, has done false;
    return { $t };

fun tasks_by_value($val: string) -> { task }:
    match $t isa task, has task-value $val, has done false;
    return { $t };

fun blocked_tasks() -> { task }:
    match $t isa task, has task-status "blocked", has done false;
    return { $t };

fun task_blockers($t: task) -> { task }:
    match (blocker: $b, blocked: $t) isa blocks; $b has done false;
    return { $b };

# --- Task Subscription (tag matching) ---

# Tasks matching a unit's tags — "what can I work on?"
fun tasks_for_unit($u: unit) -> { task }:
    match $u has tag $tag;
          $t isa task, has tag $tag, has done false, has task-status "open";
    return { $t };

# Units matching a task's tags — "who can do this?"
fun units_for_task($t: task) -> { unit }:
    match $t has tag $tag;
          $u isa unit, has tag $tag, has status "active";
    return { $u };

# Best unit for a task: tag overlap + pheromone strength
fun best_unit_for_task($t: task) -> unit:
    match $t has tag $tag;
          $u isa unit, has tag $tag, has status "active";
          (source: $any, target: $u) isa path, has strength $s;
    sort $s desc; limit 1;
    return $u;

# Tasks by tag (open, sorted by priority)
fun tasks_by_tag($tag: string) -> { task }:
    match $t isa task, has tag $tag, has done false, has priority-score $p;
    sort $p desc;
    return { $t };


# =============================================================================
# ~300 lines. One file. One world. WORLD.
#
# Runtime handles: task lifecycle, dependencies, trails, queue
# TypeDB handles: paths, units, skills, signals, knowledge, classification, auth
#
# Entities: group, unit, skill, task, hypothesis, frontier, objective, contribution, api-key
# Relations: hierarchy, path, capability, membership, signal, spawns,
#            contribution-event, blocks, api-authorization
# =============================================================================
