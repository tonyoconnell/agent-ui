# =============================================================================
# ONE ONTOLOGY — 6 dimensions. 100 lines. Stable forever.
# =============================================================================
#
# ONE is a world. A world contains groups.
# Groups contain: actors, things, paths, events, learning.
# That's reality. It doesn't change.
#
# =============================================================================

define

# 1. GROUPS — containers for everything else
entity group,
    owns gid @key,
    owns name,
    owns group-type,                  # "world", "friends", "team", "community", "org", "dao", "personal"
    owns brand,                       # brand label (e.g. "acme", "one", "donal")
    owns sensitivity,                 # governance: explore ↔ exploit (0..1, default 0.7)
    owns fade-rate,                   # governance: L3 decay rate (0..1, default 0.05)
    owns toxicity-threshold,          # governance: resistance gate for toxic (default 10.0)
    owns visibility,                  # private/group/public — who can see this group
    owns plan,                        # starter|growth|enterprise — tenant quota tier
    plays hierarchy:parent,
    plays hierarchy:child,
    plays membership:group;

relation hierarchy,
    relates parent,
    relates child;

fun ancestors-of($g: group) -> { group }:
    match
        { (parent: $ancestor, child: $g) isa hierarchy; }
        or
        { (parent: $mid, child: $g) isa hierarchy;
          let $ancestor in ancestors-of($mid); };
    return { $ancestor };

# 2. ACTORS — who can act
entity actor,
    owns aid @key,
    owns name,
    owns actor-type,                  # "human", "agent", "animal", "world"
    owns model,                       # LLM model (if AI)
    owns prompt,                      # system prompt (mutable, evolves)
    owns generation,                  # prompt iteration count
    owns tag @card(0..),              # flat labels
    owns wallet,                      # Sui address (0x...) — identity on-chain
    owns auth-hash,                   # bcrypt hash of API key (never raw)
    owns valid-from,                  # not-before activation date (optional)
    owns valid-to,                    # expiry date (optional)
    owns quota-bucket,                # quota grouping key (e.g. "free", "pro")
    plays path:source,
    plays path:target,
    plays capability:provider,
    plays membership:member,
    plays signal:sender,
    plays signal:receiver,
    plays wallet-link:substrate,
    plays identity-link:subject;

# 3. THINGS — what exists
entity thing,
    owns tid @key,
    owns name,
    owns thing-type,                  # "skill", "task", "token", "service"
    owns price,                       # 0 = free, >0 = paid
    owns tag @card(0..),
    owns task-wave,                   # "W1", "W2", "W3", "W4" (for task routing)
    owns task-context @card(0..),     # doc keys providing context (can have multiple)
    owns brand,                       # brand label (e.g. "acme", "one", "donal")
    owns owner,                       # creator's user-id; first-save sets, later saves must match
    # Task-only (meaningful when thing-type='task')
    owns task-status,                 # open/blocked/picked/done/verified/failed/dissolved
    owns task-effort,                 # 0..1
    owns task-value,                  # 0..1
    owns task-priority,               # 0..1
    owns task-variant,                # null/'a'/'b'/'c' (split-test letter)
    owns exit-condition,              # machine-observable acceptance
    # Rubric (post-verify, any thing-type)
    owns rubric-fit,
    owns rubric-form,
    owns rubric-truth,
    owns rubric-taste,
    # Plan-only (meaningful when thing-type='plan')
    owns goal,
    owns cycles-planned,
    owns escape-condition,
    owns escape-action,
    # Timestamps
    owns started-at,
    owns closed-at,
    owns verified-at,
    owns valid-from,                  # not-before activation date (optional)
    owns valid-to,                    # expiry date (optional)
    owns quota-bucket,                # quota grouping key
    plays capability:offered,
    plays blocks:blocker,
    plays blocks:blocked,
    plays containment:container,
    plays containment:contained,
    plays production:producer,
    plays production:produced;

# 3b. TASKS — DEPRECATED 2026-04-20 (see one/task.md § 10 migration).
#     Kept to not break existing api/tasks/*.ts reads. Cycle 2 migrates callers;
#     Cycle 3 removes this entity. New code writes to `thing` with thing-type='task'.
entity task,
    owns task-id @key,
    owns task-name,
    owns status,                      # "open", "in-progress", "done", "blocked"
    owns done,                        # boolean: completed?
    owns value,                       # value score (0..1)
    owns effort,                      # effort score (0..1)
    owns phase,                       # "W0", "W1", "W2", "W3", "W4"
    owns persona,                     # assigned persona
    owns priority-score,              # computed: (value - effort) / time
    owns exit-condition,              # acceptance criteria
    owns tag @card(0..),              # flat labels for routing
    plays blocks:blocker,
    plays blocks:blocked;

relation blocks,
    relates blocker,
    relates blocked;

# Containment — plan contains cycle contains task
relation containment,
    relates container,
    relates contained;

# Production — a verified task produces a skill
relation production,
    relates producer,
    relates produced;

# 4. PATHS — connections with weight
relation path,
    relates source,
    relates target,
    owns strength,                    # mark() increments
    owns resistance,                  # warn() increments
    owns traversals,                  # count
    owns scope,                       # private/group/public — federation boundary
    owns bridge-kind,                 # federation/export/escrow — cross-root edge type
    owns valid-from,                  # not-before date (optional)
    owns valid-to,                    # expiry date (optional)
    owns quota-bucket;                # quota grouping key

relation capability,
    relates provider,
    relates offered,
    owns price;

relation membership,
    relates group,
    relates member,
    owns member-role;                 # owner/chairman/board/ceo/operator/agent/auditor (renamed from `role`: reserved keyword in TypeDB 3.x). owner = substrate apex singleton (see owner.md).

# 5. EVENTS — what happened
relation signal,
    relates sender,
    relates receiver,
    owns data,                        # JSON payload
    owns amount,                      # payment (0 = free)
    owns success,
    owns latency,                     # ms from dispatch to outcome
    owns ts,
    owns scope,                       # private/group/public — federation boundary
    owns valid-from,                  # not-before date (optional)
    owns valid-to,                    # expiry date (optional)
    owns quota-bucket;                # quota grouping key

# 6. LEARNING — what was discovered
entity hypothesis,
    owns hid @key,
    owns statement,
    owns confidence,
    owns observations,
    owns scope;                       # private/group/public — shared learning boundary

# ROLE GRANTS — persisted permission matrix (source of truth; overrides hard-coded fallback)
entity role-grant,
    owns rg-id @key,
    owns governance-role,             # chairman/board/ceo/operator/agent/auditor
    owns role-action;                 # action name matching RoleAction in role-check.ts

# =============================================================================
# ATTRIBUTES
# =============================================================================

attribute gid, value string;
attribute aid, value string;
attribute tid, value string;
attribute hid, value string;
attribute task-id, value string;
attribute name, value string;
attribute task-name, value string;
attribute group-type, value string;
attribute actor-type, value string;
attribute thing-type, value string;
attribute model, value string;
attribute prompt, value string;
attribute tag, value string;
attribute statement, value string;
attribute data, value string;
attribute strength, value double;
attribute resistance, value double;
attribute price, value double;
attribute amount, value double;
attribute confidence, value double;
attribute traversals, value integer;
attribute generation, value integer;
attribute observations, value integer;
attribute success, value boolean;
attribute latency, value double;
attribute ts, value datetime;
attribute task-wave, value string;
attribute task-context, value string;
attribute brand, value string;
attribute owner, value string;
attribute status, value string;
attribute done, value boolean;
attribute value, value double;
attribute effort, value double;
attribute phase, value string;
attribute persona, value string;
attribute priority-score, value double;
attribute exit-condition, value string;

# Task lifecycle (on `thing` when thing-type='task')
attribute task-status, value string;           # open/blocked/picked/done/verified/failed/dissolved
attribute task-effort, value double;
attribute task-value, value double;
attribute task-priority, value double;
attribute task-variant, value string;          # null/'a'/'b'/'c'

# Rubric scoring (any thing-type, set post-verify)
attribute rubric-fit, value double;
attribute rubric-form, value double;
attribute rubric-truth, value double;
attribute rubric-taste, value double;

# Plan-only (on `thing` when thing-type='plan')
attribute goal, value string;
attribute cycles-planned, value integer;
attribute escape-condition, value string;
attribute escape-action, value string;

# Timestamps (datetime strings)
attribute started-at, value datetime;
attribute closed-at, value datetime;
attribute verified-at, value datetime;

# GOVERNANCE — member-role, identity, scope (locked 2026-04-18)
attribute member-role, value string;      # owner/chairman/board/ceo/operator/agent/auditor (renamed from `role`: reserved in TypeDB 3.x queries). owner = substrate apex; bypasses scope/network/sensitivity gates per owner.md.
attribute wallet, value string;           # Sui address (0x...)
attribute auth-hash, value string;        # bcrypt hash of API key
attribute scope, value string;            # private/group/public
attribute visibility, value string;       # private/group/public — group visibility
attribute bridge-kind, value string;      # federation/export/escrow — cross-root edge type

# IDENTITY LINK — bridges substrate actor to external identity providers
attribute linked-at, value long;          # unix ms timestamp of link creation
attribute front-door, value string;       # which identity front-door created the link (e.g. "google", "github", "sui")

# WORLD-CONFIG KNOBS — group-level governance tuning (added 2026-04-20 for Chairman dashboard)
attribute sensitivity, value double;          # explore ↔ exploit (0..1, default 0.7)
attribute fade-rate, value double;            # L3 decay rate (0..1, default 0.05)
attribute toxicity-threshold, value double;   # resistance count for toxic path gate (default 10.0)
attribute plan, value string;                 # starter|growth|enterprise — tenant quota tier

# WALLET INTEGRATION — links substrate actor to self-custodial wallets from /u
attribute wallet-address, value string;   # external wallet address (chain-specific)

entity ext-wallet,
    owns wallet-address @key,
    plays wallet-link:external;

relation wallet-link,
    relates substrate,
    relates external;

# IDENTITY LINK — maps actor to external identity (OAuth, DID, chain address)
relation identity-link,
    relates subject,
    relates external,
    owns linked-at,
    owns front-door;

# ESCROW SETTLEMENT — locked payment for async tasks (Sui Phase 3)
entity escrow,
    owns sui-escrow-id @key,              # Sui object ID (0x...)
    owns escrow-status,                   # "created", "released", "cancelled"
    owns escrow-amount,                   # initial amount in SUI
    owns escrow-task,                     # task name
    owns escrow-created-ms,               # timestamp when created
    owns escrow-released-ms,              # timestamp when released (settled)
    owns escrow-cancelled-ms,             # timestamp when cancelled (refunded)
    owns escrow-payment-amount,           # amount paid to worker (after fee)
    owns escrow-refund-amount;            # amount refunded to poster

relation escrow-parties,
    relates creator,                      # poster unit
    relates recipient;                    # worker unit

attribute sui-escrow-id, value string;
attribute escrow-status, value string;
attribute escrow-amount, value double;
attribute escrow-task, value string;
attribute escrow-created-ms, value integer;
attribute escrow-released-ms, value integer;
attribute escrow-cancelled-ms, value integer;
attribute escrow-payment-amount, value double;
attribute escrow-refund-amount, value double;

# TEMPORAL + QUOTA (sys-302)
attribute valid-from, value datetime;
attribute valid-to, value datetime;
attribute quota-bucket, value string;

# ROLE GRANTS (sys-303)
attribute rg-id, value string;
attribute governance-role, value string;
attribute role-action, value string;

# =============================================================================
# 6 dimensions. 5 entities. 9 relations. 67 attributes. ONE.
# v2.0: `thing` now absorbs plan/cycle/task/skill (via thing-type).
# `task` entity deprecated; kept for two cycles. See one/task.md.
# Governance layer locked: member-role on membership, wallet+auth-hash on actor,
# scope on path+hypothesis. Permission = Role × Pheromone.
# Escrow layer: sui-escrow-id on escrow, status tracking for settlement audit.
# =============================================================================
