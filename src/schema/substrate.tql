# =============================================================================
# SUBSTRATE.TQL — Production ONE Schema + 6 Intelligence Lessons
# =============================================================================
#
# Integrates:
#   - ONE Ontology (6 dimensions: Groups, Actors, Things, Flows, Events, Knowledge)
#   - Lesson 1: Classification (perception — multi-attribute tier detection)
#   - Lesson 2: Quality Rules (homeostasis — automatic quality bands)
#   - Lesson 3: Hypothesis Lifecycle (state machines via inference)
#   - Lesson 4: Task Allocation (negation + pheromone-weighted selection)
#   - Lesson 5: Contribution Tracking (aggregates + synergy)
#   - Lesson 6: Emergence (autonomous goal spawning from frontiers)
#
# TypeDB declares WHAT (inference rules).
# Substrate executes HOW (signal flow).
#
# Biology: Deborah Gordon, "Ant Encounters" / ants-at-work.com
#   "The task an ant is performing depends not on any property of
#    the individual ant, but on what the ant has experienced recently."
#
# Production proven: ants-at-work runs this at 288B ops/day.
#
# =============================================================================

define

# =============================================================================
# DIMENSION 1: GROUPS — Containers (Colony structure)
# =============================================================================

entity swarm,
    owns sid @key,
    owns name,
    owns purpose,
    owns swarm-type,          # "colony", "team", "org", "dao"
    owns status,
    owns created,
    plays hierarchy:parent,
    plays hierarchy:child;

relation hierarchy,
    relates parent,
    relates child;

# =============================================================================
# DIMENSION 2: ACTORS — Who can act (Individual ants)
# =============================================================================

entity unit,
    owns uid @key,
    owns name,
    owns unit-kind,           # "agent", "llm", "human", "system"
    owns status,              # "active", "proven", "at-risk" (inferred)
    owns balance,
    owns reputation,
    owns success-rate,        # L1: classification attribute
    owns activity-score,      # L1: classification attribute
    owns sample-count,        # L1: classification attribute
    owns created,
    plays edge:source,
    plays edge:target,
    plays capability:provider,
    plays claim:claimer,
    plays claim:owner,
    plays membership:member,
    plays signal:sender,
    plays signal:receiver;

# =============================================================================
# DIMENSION 3: THINGS — Tasks, capabilities, resources
# =============================================================================

entity task,
    owns tid @key,
    owns name,
    owns task-type,           # "work", "explore", "validate"
    owns status,              # "todo", "in_progress", "complete", "blocked"
    owns priority,            # "P0", "P1", "P2", "P3"
    owns importance,          # 1-10
    owns cost,
    owns attractive,          # L4: INFERRED — ready + strong trail
    owns repelled,            # L4: INFERRED — alarm pheromone dominates
    plays capability:skill,
    plays claim:work,
    plays dependency:dependent,
    plays dependency:blocker,
    plays pheromone-trail:source-task,
    plays pheromone-trail:destination-task,
    plays continuation:trigger,
    plays continuation:result;

# =============================================================================
# DIMENSION 4: CONNECTIONS — Weighted edges (Pheromone trails)
# =============================================================================

# Core pheromone trail between units
relation edge,
    relates source,
    relates target,
    owns strength,            # success pheromone (positive reinforcement)
    owns alarm,               # failure pheromone (negative reinforcement)
    owns traversals,
    owns last-used,
    owns edge-status;         # "highway", "fresh", "fading", "dead" (inferred)

# Task-to-task pheromone trail (L4: what sequence works?)
relation pheromone-trail,
    relates source-task,
    relates destination-task,
    owns trail-pheromone,     # 0.0 - 100.0
    owns alarm-pheromone,     # 0.0 - 100.0
    owns completions,
    owns failures,
    owns trail-status;        # "proven", "fresh", "fading", "dead" (inferred)

# What a unit can do
relation capability,
    relates provider,
    relates skill,
    owns price;

# Task ownership
relation claim,
    relates claimer,
    relates work,
    relates owner,
    owns claimed-at;

# Task dependencies (L4: blocker/dependent)
relation dependency,
    relates dependent,
    relates blocker;

# Pre-defined continuations (.then chains)
relation continuation,
    relates trigger,
    relates result,
    owns template;

# Swarm membership
relation membership,
    relates member,
    relates group,
    owns joined-at;

# =============================================================================
# DIMENSION 5: EVENTS — Signals that flowed (History)
# =============================================================================

relation signal,
    relates sender,
    relates receiver,
    owns payload,
    owns ts;

# =============================================================================
# DIMENSION 6: KNOWLEDGE — Emerges from inference
# =============================================================================

# L3: Hypothesis lifecycle
entity hypothesis,
    owns hid @key,
    owns statement,
    owns hypothesis-status,   # "pending", "testing", "confirmed", "rejected"
    owns observations-count,
    owns p-value,
    owns action-ready;        # INFERRED: confirmed + p<=0.05 + obs>=50

# L6: Exploration frontiers
entity frontier,
    owns fid @key,
    owns frontier-type,       # "market", "technology", "capability"
    owns expected-value,      # potential * probability / cost
    owns frontier-status,     # "unexplored", "exploring", "exhausted"
    plays spawns:frontier;

# L6: Autonomous objectives
entity objective,
    owns oid @key,
    owns objective-type,      # "explore", "optimize", "validate"
    owns priority-score,
    owns progress,            # 0.0 - 1.0
    owns objective-status,    # "pending", "active", "complete"
    plays spawns:objective;

relation spawns,
    relates frontier,
    relates objective;

# =============================================================================
# ATTRIBUTES
# =============================================================================

# Identifiers
attribute sid, value string;
attribute uid, value string;
attribute tid, value string;
attribute hid, value string;
attribute fid, value string;
attribute oid, value string;

# Descriptive
attribute name, value string;
attribute purpose, value string;
attribute statement, value string;
attribute template, value string;
attribute payload, value string;
attribute swarm-type, value string;
attribute unit-kind, value string;
attribute task-type, value string;
attribute frontier-type, value string;
attribute objective-type, value string;

# Status
attribute status, value string;
attribute edge-status, value string;
attribute trail-status, value string;
attribute hypothesis-status, value string;
attribute frontier-status, value string;
attribute objective-status, value string;
attribute priority, value string;

# Numeric
attribute strength, value double;
attribute alarm, value double;
attribute trail-pheromone, value double;
attribute alarm-pheromone, value double;
attribute balance, value double;
attribute reputation, value double;
attribute success-rate, value double;
attribute activity-score, value double;
attribute cost, value double;
attribute price, value double;
attribute p-value, value double;
attribute expected-value, value double;
attribute priority-score, value double;
attribute progress, value double;

# Integer
attribute traversals, value integer;
attribute completions, value integer;
attribute failures, value integer;
attribute sample-count, value integer;
attribute importance, value integer;
attribute observations-count, value integer;

# Boolean
attribute attractive, value boolean;
attribute repelled, value boolean;
attribute action-ready, value boolean;

# Temporal
attribute created, value datetime;
attribute last-used, value datetime;
attribute claimed-at, value datetime;
attribute joined-at, value datetime;
attribute ts, value datetime;

# =============================================================================
# INFERENCE RULES — The Colony's Distributed Decision-Making
# =============================================================================

# --- Edge Status (unit-to-unit trails) ---

rule highway:
    when { $e isa edge, has strength $s; $s >= 50.0; }
    then { $e has edge-status "highway"; };

rule fresh-edge:
    when { $e isa edge, has strength $s, has traversals $t; $s >= 10.0; $s < 50.0; $t < 10; }
    then { $e has edge-status "fresh"; };

rule fading-edge:
    when { $e isa edge, has strength $s; $s > 0.0; $s < 5.0; }
    then { $e has edge-status "fading"; };

rule toxic-edge:
    when { $e isa edge, has alarm $a, has strength $s; $a > $s; $a >= 10.0; }
    then { $e has edge-status "toxic"; };

# --- Trail Status (task-to-task, L4) ---

rule proven-trail:
    when {
        $trail isa pheromone-trail, has trail-pheromone $tp, has completions $c, has failures $f;
        $tp >= 70.0; $c >= 10; $f < $c;
    } then { $trail has trail-status "proven"; };

rule fresh-trail:
    when {
        $trail isa pheromone-trail, has trail-pheromone $tp, has completions $c;
        $tp >= 10.0; $tp < 70.0; $c < 10;
    } then { $trail has trail-status "fresh"; };

rule fading-trail:
    when { $trail isa pheromone-trail, has trail-pheromone $tp; $tp > 0.0; $tp < 10.0; }
    then { $trail has trail-status "fading"; };

rule dead-trail:
    when { $trail isa pheromone-trail, has trail-pheromone $tp; $tp <= 0.0; }
    then { $trail has trail-status "dead"; };

# --- Actor Status ---

rule proven-unit:
    when {
        $u isa unit;
        $e (target: $u) isa edge, has strength $s, has alarm $a;
        $s >= 20.0; $s > ($a * 2.0);
    }
    then { $u has status "proven"; };

rule at-risk-unit:
    when {
        $u isa unit;
        $e (target: $u) isa edge, has alarm $a, has strength $s;
        $a >= 10.0; $a > $s;
    }
    then { $u has status "at-risk"; };

# --- Task Attractiveness (L4: pheromone-weighted selection) ---

rule attractive-task:
    when {
        $t isa task, has status "todo";
        not {
            $dep(dependent: $t, blocker: $blocker) isa dependency;
            $blocker isa task, has status $bs;
            not { $bs == "complete"; };
        };
        $trail (destination-task: $t) isa pheromone-trail, has trail-pheromone $tp;
        $tp >= 50.0;
    } then { $t has attractive true; };

rule repelled-task:
    when {
        $t isa task, has status "todo";
        $trail (destination-task: $t) isa pheromone-trail,
            has alarm-pheromone $ap, has trail-pheromone $tp;
        $ap >= 30.0; $ap > $tp;
    } then { $t has repelled true; };

# --- Hypothesis Lifecycle (L3: state machine) ---

rule hypothesis-action-ready:
    when {
        $h isa hypothesis, has hypothesis-status "confirmed",
            has p-value $p, has observations-count $n;
        $p <= 0.05; $n >= 50;
    } then { $h has action-ready true; };

# =============================================================================
# FUNCTIONS — The Interface
# =============================================================================

# --- Routing (Dimension 4) ---

fun highways(threshold: double = 10.0, min_traversals: integer = 50) -> { edge }:
    match
        $e (source: $from, target: $to) isa edge,
            has strength $s, has traversals $t;
        $s >= threshold; $t >= min_traversals;
    return { $e };

fun optimal_route($from: unit, $task: task) -> unit:
    match
        (source: $from, target: $to) isa edge, has strength $s;
        (provider: $to, skill: $task) isa capability;
    sort $s desc; limit 1;
    return $to;

fun cheapest_provider($task: task) -> unit:
    match
        (provider: $u, skill: $task) isa capability, has price $p;
    sort $p asc; limit 1;
    return $u;

fun suggest_route($from: unit, $task: task) -> { uid, strength }:
    match
        $from isa unit; $task isa task;
        (source: $from, target: $to) isa edge, has strength $s;
        (provider: $to, skill: $task) isa capability;
        $to has uid $tid; $s >= 5.0;
    sort $s desc; limit 5;
    return { $tid, $s };

# --- Actor Queries (Dimension 2) ---

fun proven_units() -> { unit }:
    match $u isa unit, has status "proven";
    return { $u };

fun at_risk_units() -> { unit }:
    match $u isa unit, has status "at-risk";
    return { $u };

fun collaborators($me: unit) -> { unit }:
    match
        (member: $me, group: $g) isa membership;
        (member: $peer, group: $g) isa membership;
        not { $me is $peer; };
    return { $peer };

# --- L1: Classification ---

fun elite_units() -> { unit }:
    match
        $u isa unit, has success-rate $sr, has activity-score $as, has sample-count $sc;
        $sr >= 0.75; $as >= 70.0; $sc >= 50;
    return { $u };

fun at_risk_by_performance() -> { unit }:
    match
        $u isa unit, has success-rate $sr, has activity-score $as, has sample-count $sc;
        $sr < 0.40; $as >= 25.0; $sc >= 30;
    return { $u };

# --- L4: Task Allocation ---

fun ready_tasks() -> { task }:
    match
        $t isa task, has status "todo";
        not {
            $dep(dependent: $t, blocker: $blocker) isa dependency;
            $blocker isa task, has status $bs;
            not { $bs == "complete"; };
        };
    return { $t };

fun attractive_tasks() -> { task }:
    match $t isa task, has attractive true;
    return { $t };

fun repelled_tasks() -> { task }:
    match $t isa task, has repelled true;
    return { $t };

fun exploratory_tasks() -> { task }:
    match
        $t isa task, has status "todo";
        not {
            $dep(dependent: $t, blocker: $blocker) isa dependency;
            $blocker isa task, has status $bs;
            not { $bs == "complete"; };
        };
        not { $trail (destination-task: $t) isa pheromone-trail; };
    return { $t };

fun superhighway_trails() -> { pheromone-trail }:
    match $trail isa pheromone-trail, has trail-status "proven";
    return { $trail };

# --- L3: Hypothesis ---

fun actionable_hypotheses() -> { hypothesis }:
    match $h isa hypothesis, has action-ready true;
    return { $h };

fun active_tests() -> { hypothesis }:
    match $h isa hypothesis, has hypothesis-status "testing";
    return { $h };

# --- L6: Emergence ---

fun promising_frontiers() -> { frontier }:
    match $f isa frontier, has frontier-status "unexplored", has expected-value $ev;
    $ev >= 0.5;
    return { $f };

fun active_objectives() -> { objective }:
    match $o isa objective, has objective-status $s;
    $s in ["pending", "active"];
    return { $o };

# --- Aggregates (L5) ---

fun highway_count(threshold: double = 10.0) -> integer:
    match $e isa edge, has strength $s; $s >= threshold;
    return count($e);

# =============================================================================
# ~280 lines. 6 dimensions. 6 lessons. ONE substrate.
#
# TypeDB declares WHAT. The substrate executes HOW.
# Together: emergence.
# =============================================================================
