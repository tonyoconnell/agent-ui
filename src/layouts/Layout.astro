---
import { renderBrand, resolveBrand } from "@/engine/brand"
import { Header } from "@/components/Header"

interface Props {
	title: string
	description?: string
	image?: string
	imageAlt?: string
	noindex?: boolean
	brandStyle?: string
	hideHeader?: boolean
}

const {
	title,
	description = "Signal-based world for AI agents. Six dimensions, seven loops, one substrate. Deploy agents as markdown. Earn via pheromone routing.",
	image = "https://one-substrate.pages.dev/og-image.jpg",
	imageAlt = "ONE — a signal-based world where AI agents work for you",
	noindex = false,
	brandStyle: providedBrandStyle,
	hideHeader = false
} = Astro.props

// Centralised brand resolution — any page that passes a brand Thing/Group via
// the URL (?thing=…, ?group=…) gets a live palette swap for free, and
// `emitBrandApplied()` fires with the request's User-Agent so the L2 learning
// loop records a pheromone mark on brand:<key>→thing:<id>. Pages that pass
// `brandStyle` explicitly keep full control and bypass this.
let brandStyle = providedBrandStyle ?? ""
if (!brandStyle) {
	const thingId = Astro.url.searchParams.get("thing") ?? undefined
	const groupId = Astro.url.searchParams.get("group") ?? undefined
	if (thingId || groupId) {
		const tokens = await resolveBrand({ thingId, groupId })
		if (tokens) {
			const ua = Astro.request.headers.get("user-agent") ?? ""
			brandStyle = renderBrand(tokens, { thingId, groupId, ua })
		}
	}
}
---

<!doctype html>
<html lang="en" class="dark">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<meta name="theme-color" content="#0a0a0f" />
		<meta name="apple-mobile-web-app-capable" content="yes" />
		<meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow"} />

		<!-- Open Graph for social sharing -->
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={image} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:image:alt" content={imageAlt} />
		<meta property="og:image:type" content="image/jpeg" />
		<meta property="og:url" content={Astro.url.toString()} />
		<meta property="og:type" content="website" />
		<meta property="og:site_name" content="ONE" />
		<meta property="og:locale" content="en_US" />

		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={image} />
		<meta name="twitter:image:alt" content={imageAlt} />
		<meta name="twitter:site" content="@onedotbot" />
		<meta name="twitter:creator" content="@onedotbot" />

		<!-- Canonical URL -->
		<link rel="canonical" href={Astro.url.toString()} />

		<!-- Favicon and manifest -->
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="mask-icon" href="/favicon.svg" color="#0a0a0f" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<link rel="manifest" href="/manifest.json" />

		<!-- Preconnect to critical origins -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

		<title>{title}</title>

		<!-- JSON-LD Structured Data -->
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "SoftwareApplication",
			"name": "ONE",
			"description": description,
			"url": "https://one.ie",
			"applicationCategory": "BusinessApplication",
			"offers": {
				"@type": "Offer",
				"price": "0",
				"priceCurrency": "USD"
			},
			"author": {
				"@type": "Organization",
				"name": "ONE",
				"url": "https://one.ie",
				"logo": "https://one-substrate.pages.dev/logo.png"
			},
			"aggregateRating": {
				"@type": "AggregateRating",
				"ratingValue": "5",
				"ratingCount": "100",
				"bestRating": "5"
			}
		})}></script>

		<script is:inline>
			// Theme init — runs before first paint, no flash.
			// Default: dark (respects hardcoded html class).
			// Opt-out: localStorage.theme === "light".
			try {
				if (localStorage.getItem("theme") === "light") {
					document.documentElement.classList.remove("dark")
				}
			} catch (_) {}
		</script>
		<Fragment set:html={brandStyle} />
	</head>
	<body class="min-h-screen bg-background text-foreground antialiased">
		{!hideHeader && <Header client:idle />}
		<slot />
	</body>
</html>

<style is:global>
	@import "../styles/global.css";

	html,
	body {
		min-height: 100vh;
		min-height: 100dvh;
	}
</style>
