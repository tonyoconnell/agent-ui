---
import { renderBrand, resolveBrand } from "@/engine/brand"
import { Header } from "@/components/Header"
import { Sidebar } from "@/components/Sidebar"
import { CookieBanner } from "@/components/legal/CookieBanner"

interface Props {
	title: string
	description?: string
	image?: string
	imageAlt?: string
	noindex?: boolean
	brandStyle?: string
	hideHeader?: boolean
	hideSidebar?: boolean
	sidebarCurrent?: string
}

const {
	title,
	description = "Signal-based world for AI agents. Six dimensions, seven loops, one substrate. Deploy agents as markdown. Earn via pheromone routing.",
	image = "https://one-substrate.pages.dev/og-image.jpg",
	imageAlt = "ONE — a signal-based world where AI agents work for you",
	noindex = false,
	brandStyle: providedBrandStyle,
	hideHeader = false,
	hideSidebar = false,
	sidebarCurrent = Astro.url.pathname
} = Astro.props

// Centralised brand resolution — any page that passes a brand Thing/Group via
// the URL (?thing=…, ?group=…) gets a live palette swap for free, and
// `emitBrandApplied()` fires with the request's User-Agent so the L2 learning
// loop records a pheromone mark on brand:<key>→thing:<id>. Pages that pass
// `brandStyle` explicitly keep full control and bypass this.
// Cloudflare sets CF-IPCountry on every request — use it for cookie banner geo.
const cfCountry = Astro.request.headers.get("cf-ipcountry") ?? undefined
// Per-request CSP nonce — set by middleware for /u/* and /chat/* surfaces.
// Astro 6 reads data-astro-csp-nonce on <html> and injects the nonce into
// every emitted inline <script> tag for island hydration.
const cspNonce = Astro.locals.cspNonce

let brandStyle = providedBrandStyle ?? ""
if (!brandStyle) {
	const thingId = Astro.url.searchParams.get("thing") ?? undefined
	const groupId = Astro.url.searchParams.get("group") ?? undefined
	if (thingId || groupId) {
		const tokens = await resolveBrand({ thingId, groupId })
		if (tokens) {
			const ua = Astro.request.headers.get("user-agent") ?? ""
			brandStyle = renderBrand(tokens, { thingId, groupId, ua })
		}
	}
}
---

<!doctype html>
<html lang="en" class="dark" data-astro-csp-nonce={cspNonce}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<meta name="theme-color" content="#0a0a0f" />
		<meta name="apple-mobile-web-app-capable" content="yes" />
		<meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow"} />
		{cspNonce && <meta name="csp-nonce" content={cspNonce} />}

		<!-- Open Graph for social sharing -->
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={image} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:image:alt" content={imageAlt} />
		<meta property="og:image:type" content="image/jpeg" />
		<meta property="og:url" content={Astro.url.toString()} />
		<meta property="og:type" content="website" />
		<meta property="og:site_name" content="ONE" />
		<meta property="og:locale" content="en_US" />

		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={image} />
		<meta name="twitter:image:alt" content={imageAlt} />
		<meta name="twitter:site" content="@onedotbot" />
		<meta name="twitter:creator" content="@onedotbot" />

		<!-- Canonical URL -->
		<link rel="canonical" href={Astro.url.toString()} />

		<!-- Favicon and manifest -->
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="mask-icon" href="/favicon.svg" color="#0a0a0f" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<link rel="manifest" href="/manifest.json" />

		<!-- Preconnect to critical origins -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

		<title>{title}</title>

		<!-- JSON-LD Structured Data -->
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "SoftwareApplication",
			"name": "ONE",
			"description": description,
			"url": "https://one.ie",
			"applicationCategory": "BusinessApplication",
			"offers": {
				"@type": "Offer",
				"price": "0",
				"priceCurrency": "USD"
			},
			"author": {
				"@type": "Organization",
				"name": "ONE",
				"url": "https://one.ie",
				"logo": "https://one-substrate.pages.dev/logo.png"
			},
			"aggregateRating": {
				"@type": "AggregateRating",
				"ratingValue": "5",
				"ratingCount": "100",
				"bestRating": "5"
			}
		})}></script>

		<script is:inline define:vars={{ cspNonce }}>
			// Theme init — runs before first paint, no flash.
			// Default: dark (respects hardcoded html class).
			// Opt-out: localStorage.theme === "light".
			// cspNonce is injected by Astro via define:vars so the nonce attribute
			// is present on this script tag when the CSP header requires it.
			void cspNonce
			try {
				if (localStorage.getItem("theme") === "light") {
					document.documentElement.classList.remove("dark")
				}
			} catch (_) {}
		</script>
		<Fragment set:html={brandStyle} />
	</head>
	<body class="min-h-screen flex flex-col bg-background text-foreground antialiased">
		{!hideHeader && <Header client:idle />}
		{!hideSidebar && <Sidebar client:idle current={sidebarCurrent} />}
		<main class:list={["flex-1", !hideSidebar && "md:pl-16 pb-20 md:pb-0"]}>
			<slot />
		</main>
		<footer class:list={["border-t border-border px-6 py-6 text-center text-xs text-muted-foreground pb-24 md:pb-6", !hideSidebar && "md:pl-16"]}>
			<nav aria-label="Legal" class="flex flex-wrap items-center justify-center gap-x-4 gap-y-1">
				<span>&copy; {new Date().getFullYear()} One Internet Enterprises Ltd</span>
				<a href="/legal/terms" class="underline underline-offset-4 hover:text-foreground transition-colors">Terms of Service</a>
				<a href="/legal/privacy" class="underline underline-offset-4 hover:text-foreground transition-colors">Privacy Policy</a>
			</nav>
		</footer>
		<CookieBanner client:idle countryCode={cfCountry} />
		{import.meta.env.PROD && import.meta.env.CF_ANALYTICS_TOKEN && (
			<script defer src='https://static.cloudflareinsights.com/beacon.min.js'
				data-cf-beacon={`{"token": "${import.meta.env.CF_ANALYTICS_TOKEN}"}`}></script>
		)}
	</body>
</html>

<style is:global>
	@import "../styles/global.css";

	html,
	body {
		min-height: 100vh;
		min-height: 100dvh;
	}

	/* Astro custom-element defaults to display: inline. Force block so islands
	   establish a proper block-formatting context — otherwise children using
	   min-h-screen / flex / grid can collapse or escape their parent. */
	astro-island,
	astro-slot {
		display: block;
	}
</style>
