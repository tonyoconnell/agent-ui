# =============================================================================
# DOMAIN EXAMPLE (TypeDB 3.x): Social Network / Community Intelligence
# =============================================================================
#
# Migrated to 3.x 2026-04-20.
#
# Demonstrates:
#   - Reputation tier classification (3 rules → one cascading fun)
#   - Content quality classification (2 rules → one fun with implicit default)
#   - Moderator-eligibility as a COMPOSED classifier (calls reputation_tier)
#   - `@cascade` on `authored:author` — deleting a member deletes their authorship
#     links (but not the content; content follows its own lifecycle)
#
# Based on patterns from: classification.tql, contribution-tracking.tql
# =============================================================================

define

# --- Entities ---

entity community-member,
    owns member-id @key,
    owns display-name,
    owns joined-at,
    owns posts-count,
    owns helpful-votes,
    owns report-count,
    owns reputation-score,
    plays follows:follower,
    plays follows:followed,
    plays authored:author;

entity content-item,
    owns content-id @key,
    owns content-type,
    owns content-text,
    owns upvotes,
    owns downvotes,
    owns report-count,
    owns created-at,
    plays authored:content;


# --- Attributes (with 3.x constraints) ---

attribute member-id,          value string;
attribute display-name,       value string;
attribute joined-at,          value datetime;
attribute posts-count,        value integer;
attribute helpful-votes,      value integer;
attribute report-count,       value integer;
attribute reputation-score,   value double;

attribute content-id,         value string;
attribute content-type,       value string @values("post", "comment", "answer");
attribute content-text,       value string;
attribute upvotes,            value integer;
attribute downvotes,          value integer;
attribute created-at,         value datetime;


# --- Relations ---

relation follows,
    relates follower @cascade,       # delete member → drop all their follows
    relates followed;

relation authored,
    relates author @cascade,
    relates content;


# =============================================================================
# CLASSIFIER FUNCTIONS — replacing 2.x rules
# =============================================================================

# --- Reputation tier: cascading classifier (replaces trusted + flagged rules) ---
#
# Ordered bands:
#   "flagged" if report ratio is concerning (strictest — takes precedence)
#   "trusted" if all three signals clear the high-reputation thresholds
#   "new"     if the member is too fresh to judge
#   "standard" otherwise
#
fun reputation_tier($m: community-member) -> string:
    match
        $m has reputation-score $rs,
           has posts-count $pc,
           has helpful-votes $hv,
           has report-count $rc;
    return first
        if ($rc >= 5 and $pc >= 1)
            then "flagged"
        else if ($rs >= 100.0 and $pc >= 50 and $rc < 3)
            then "trusted"
        else if ($pc < 5)
            then "new"
        else "standard";


# --- Moderator eligibility: composed classifier ---
#
# Replaces the 2.x `moderator-candidate` rule (which depended on
# `reputation-tier "trusted"` having fired first). 3.x composes by calling
# `reputation_tier()` inside the match; no dependency on rule ordering.
#
fun is_moderator_eligible($m: community-member) -> boolean:
    match
        let $tier = reputation_tier($m);
        $tier == "trusted";
        $m has helpful-votes $hv;
        $hv >= 200;
    return first true;


# --- Content quality: cascading classifier (replaces 2 rules + implicit default) ---
#
# Ordered bands:
#   "spam"    if reported multiple times
#   "high"    if vote ratio is strong and zero reports
#   "low"     if downvotes dominate upvotes
#   "standard" otherwise
#
fun content_quality($c: content-item) -> string:
    match
        $c has upvotes $up, has downvotes $down, has report-count $rc;
    return first
        if ($rc >= 3)
            then "spam"
        else if ($up >= 10 and $down < 3 and $rc == 0)
            then "high"
        else if ($down >= $up and $up < 3)
            then "low"
        else "standard";


# =============================================================================
# QUERY FUNCTIONS
# =============================================================================

# --- Member partitions via the tier classifier ---

fun trusted_members() -> { community-member }:
    match
        $m isa community-member;
        let $tier = reputation_tier($m);
        $tier == "trusted";
    return { $m };

fun flagged_members() -> { community-member }:
    match
        $m isa community-member;
        let $tier = reputation_tier($m);
        $tier == "flagged";
    return { $m };

# Moderator candidates (composed via is_moderator_eligible)
fun moderator_candidates() -> { community-member }:
    match
        $m isa community-member;
        let $ok = is_moderator_eligible($m);
    return { $m };


# --- Content partitions via the quality classifier ---

fun quality_content() -> { content-item }:
    match
        $c isa content-item;
        let $q = content_quality($c);
        $q == "high";
    return { $c };

fun spam_content() -> { content-item }:
    match
        $c isa content-item;
        let $q = content_quality($c);
        $q == "spam";
    return { $c };


# --- Aggregates ---

fun members_by_tier($tier: string) -> integer:
    match
        $m isa community-member;
        let $t = reputation_tier($m);
        $t == $tier;
    return count($m);

# Community health index: ratio of non-flagged content
fun quality_rate() -> double:
    match
        let $q  = spam_content_count();
        let $all = content_count();
        $all > 0;
    return first 1.0 - ($q / $all);

fun spam_content_count() -> integer:
    match
        $c isa content-item;
        let $q = content_quality($c);
        $q == "spam";
    return count($c);

fun content_count() -> integer:
    match $c isa content-item;
    return count($c);


# =============================================================================
# USAGE
# =============================================================================
#
# Moderation panel: flagged members newest first
#   match let $m = flagged_members();
#         $m has display-name $n, has joined-at $j;
#   select $m, $n, $j;
#   sort $j desc;
#
# Recruit new moderators
#   match let $m = moderator_candidates();
#         $m has display-name $n, has helpful-votes $h;
#   select $n, $h;
#
# Spam removal queue
#   match let $c = spam_content();
#         $c has content-id $id, has report-count $rc;
#   select $id, $rc;
#
# Community health dashboard
#   match
#     let $trusted  = members_by_tier("trusted");
#     let $standard = members_by_tier("standard");
#     let $new      = members_by_tier("new");
#     let $flagged  = members_by_tier("flagged");
#     let $health   = quality_rate();
#   select $trusted, $standard, $new, $flagged, $health;
#
# =============================================================================
