# =============================================================================
# DOMAIN EXAMPLE (TypeDB 3.x): IoT Device Monitoring & Anomaly Detection
# =============================================================================
#
# Migrated to 3.x 2026-04-20.
#
# Demonstrates:
#   - Device health classification (4 rules collapse into one cascading fun)
#   - Maintenance-due flag as a composed classifier (calls device_health)
#   - Fleet aggregation with `reduce ... groupby` over a classifier
#   - Alert severity type-checked via `@values`
#
# Based on patterns from: classification.tql, quality-rules.tql, autonomous-goals.tql
# =============================================================================

define

# --- Entities ---

entity device,
    owns device-id @key,
    owns device-name,
    owns device-type,
    owns location,
    owns uptime-percentage,
    owns error-rate,
    owns avg-response-ms,
    owns last-heartbeat,
    owns readings-count,
    plays device-group-membership:member,
    plays device-alert:alerting-device;

entity device-group,
    owns group-id @key,
    owns group-name,
    owns group-location,
    plays device-group-membership:group;

entity alert,
    owns alert-id @key,
    owns alert-type,
    owns alert-severity,
    owns alert-message,
    owns triggered-at,
    owns acknowledged,
    owns resolved-at,
    plays device-alert:alert-record;


# --- Attributes (with 3.x constraints) ---

attribute device-id,            value string;
attribute device-name,          value string;
attribute device-type,          value string @values("sensor", "actuator", "gateway");
attribute location,             value string;
attribute uptime-percentage,    value double  @range(0.0..100.0);
attribute error-rate,           value double;           # errors per hour
attribute avg-response-ms,      value double;
attribute last-heartbeat,       value datetime;
attribute readings-count,       value integer;

attribute group-id,             value string;
attribute group-name,           value string;
attribute group-location,       value string;

attribute alert-id,             value string;
attribute alert-type,           value string @values("threshold", "anomaly", "heartbeat");
attribute alert-severity,       value string @values("info", "warning", "critical");
attribute alert-message,        value string;
attribute triggered-at,         value datetime;
attribute acknowledged,         value boolean;
attribute resolved-at,          value datetime;


# --- Relations ---

relation device-group-membership,
    relates member @cascade,     # delete device → remove group membership
    relates group;

relation device-alert,
    relates alerting-device @cascade,
    relates alert-record;


# =============================================================================
# CLASSIFIER FUNCTIONS — replacing 2.x rules
# =============================================================================

# --- Device health: cascading classifier (replaces 3 rules: healthy/degraded/critical) ---
#
# Order: strictest criteria first. "offline" is added for heartbeat-absent
# devices (not present in 2.x, but natural in 3.x with time-aware classifiers).
#
fun device_health($d: device) -> string:
    match $d has uptime-percentage $up, has error-rate $er, has avg-response-ms $ms,
             has readings-count $rc;
    return first
        if ($up < 95.0 or $er >= 10.0)
            then "critical"
        else if ($up >= 99.0 and $er < 1.0 and $ms < 100.0 and $rc >= 100)
            then "healthy"
        else if ($rc < 100)
            then "new"
        else "degraded";


# --- Maintenance-due: composed classifier (replaces the 2.x maintenance-needed rule) ---
#
# Calls device_health() via `let`. The planner sees through the abstraction
# and can push the predicate into the main device scan.
#
fun is_maintenance_due($d: device) -> boolean:
    match
        let $h = device_health($d);
        $h == "degraded";
        $d has readings-count $rc;
        $rc >= 1000;
    return first true;


# =============================================================================
# QUERY FUNCTIONS
# =============================================================================

# --- Device partitions by health ---

fun healthy_devices() -> { device }:
    match
        $d isa device;
        let $h = device_health($d);
        $h == "healthy";
    return { $d };

fun critical_devices() -> { device }:
    match
        $d isa device;
        let $h = device_health($d);
        $h == "critical";
    return { $d };

fun degraded_devices() -> { device }:
    match
        $d isa device;
        let $h = device_health($d);
        $h == "degraded";
    return { $d };


# --- Maintenance queue (derived from classifier composition) ---

fun maintenance_queue() -> { device }:
    match
        $d isa device;
        let $due = is_maintenance_due($d);
    return { $d };


# --- Group navigation ---

fun devices_in_group($group_name: string) -> { device }:
    match
        $g isa device-group, has group-name $group_name;
        $rel (member: $d, group: $g) isa device-group-membership;
    return { $d };

# How many critical devices in a given group? (composition)
fun critical_in_group($group_name: string) -> integer:
    match
        $g isa device-group, has group-name $group_name;
        $rel (member: $d, group: $g) isa device-group-membership;
        let $h = device_health($d);
        $h == "critical";
    return count($d);


# --- Aggregates ---

fun count_by_health($health: string) -> integer:
    match
        $d isa device;
        let $h = device_health($d);
        $h == $health;
    return count($d);


# --- Alert stream ---

fun unacked_alerts() -> { alert }:
    match $a isa alert, has acknowledged false;
    return { $a };

fun critical_alerts() -> { alert }:
    match $a isa alert, has alert-severity "critical", has acknowledged false;
    return { $a };


# =============================================================================
# USAGE
# =============================================================================
#
# Ops dashboard: fleet health counts
#   match
#     let $healthy  = count_by_health("healthy");
#     let $degraded = count_by_health("degraded");
#     let $critical = count_by_health("critical");
#   select $healthy, $degraded, $critical;
#
# Maintenance crew dispatch list
#   match let $d = maintenance_queue();
#         $d has device-name $n, has location $loc;
#   select $n, $loc;
#
# Group-level SLA monitoring (count critical per group)
#   match
#     $g isa device-group, has group-name $gname;
#     let $critical = critical_in_group($gname);
#   select $gname, $critical;
#
# Alert panel (unacknowledged critical alerts, newest first):
#   match let $a = critical_alerts();
#         $a has triggered-at $ts, has alert-message $msg;
#   select $a, $ts, $msg;
#   sort $ts desc;
#
# =============================================================================
