# =============================================================================
# LESSON 2 (TypeDB 3.x): Quality Classification via Typed Functions
# =============================================================================
#
# DIFFICULTY: Beginner-Intermediate
# PREREQUISITE: classification.tql (Lesson 1)
# NEXT:         hypothesis-lifecycle.tql (Lesson 3)
#
# WHAT CHANGED FROM 2.x:
#   2.x had `rule name: when { } then { };` — rules fired automatically on
#   every query and magically inserted derived attributes.
#
#   3.x replaces rules with typed FUNCTIONS (`fun`). You now pick one of two
#   patterns explicitly:
#
#     (A) DERIVED-ON-DEMAND — call the classifier function inside any query.
#         No stored label. Always correct, always recomputed.
#
#     (B) MATERIALIZED — run a `match let $q = fn($x); insert $x has q;`
#         pipeline periodically. Stored label. Faster reads, staleness risk.
#
#   Both patterns are in this file. Choose based on read/write ratio.
#
# WHAT YOU'LL LEARN:
#   - How a single cascading `if/else` inside `fun` replaces N mutually-
#     exclusive `rule` definitions.
#   - How to compose classifier functions (cascade_sources calls record_quality).
#   - When to materialize vs derive-on-demand.
#   - 3.x schema best practices: `@values` for enum constraints, `@range` for
#     bounded probabilities, `@cascade` on relation roles for dependent cleanup.
#
# BIOLOGY (Chapter 2 — Task Allocation Without Instructions):
#   Individual ants have different RESPONSE THRESHOLDS for switching tasks.
#   High-sensitivity ants respond to weak signals, low-sensitivity ants only
#   respond to strong signals. Population variance in thresholds is essential.
#
#   In TypeDB 3.x: cascading `if/else` inside a function creates mutually-
#   exclusive bands. Unlike 2.x rules (which could overlap and cause
#   ambiguity), a single function with an ordered cascade guarantees exactly
#   one band per instance. The first branch that matches wins.
#
#   Reference: https://ants-at-work.com/book/2/
#
# USE CASES:
#   - Learning system quality tracking (high/medium/low)
#   - Content moderation tiers
#   - Service level classification
#   - Performance review bands
#
# AFTER LOADING, TEST WITH:
#   # Derived-on-demand (no materialization needed):
#   match
#     $r isa learning-record;
#     let $q = record_quality($r);
#   select $r, $q;
#
# =============================================================================

define

# =============================================================================
# SCHEMA
# =============================================================================
# Best practices demonstrated:
#   @values on record-type + quality-label + cycle-quality — type-validated enums
#   @range on effectiveness, chain-strength, accuracy-* — bounded probabilities
#   @cascade on learning-chain:source — deleting a source record dissolves the
#                                       chain rows that depended on it

entity learning-record,
    owns record-id @key,
    owns record-type,
    owns source-system,
    owns applied,
    owns effectiveness,
    owns quality-label,          # optional: set by the materialization pipeline
    owns cascade-potential,      # optional: set by the materialization pipeline
    owns insight-text,
    plays learning-chain:source,
    plays learning-chain:derived;

attribute record-id,          value string;
attribute record-type,        value string @values("insight", "rule", "hypothesis");
attribute source-system,      value string;
attribute applied,            value boolean;
attribute effectiveness,      value double @range(0.0..1.0);
attribute quality-label,      value string @values("high", "medium", "low");
attribute cascade-potential,  value boolean;
attribute insight-text,       value string;

relation learning-chain,
    relates source @cascade,     # delete a source record → chain entries go too
    relates derived,
    owns chain-strength,
    owns chain-timestamp;

attribute chain-strength,     value double @range(0.0..1.0);
attribute chain-timestamp,    value datetime;

entity work-cycle,
    owns cycle-id @key,
    owns cycle-timestamp,
    owns cycle-duration-seconds,
    owns items-completed,
    owns items-tested,
    owns items-created,
    owns accuracy-before,
    owns accuracy-after,
    owns improvement-delta,
    owns cycle-quality;          # optional: set by the materialization pipeline

attribute cycle-id,                 value string;
attribute cycle-timestamp,          value datetime;
attribute cycle-duration-seconds,   value integer;
attribute items-completed,          value integer;
attribute items-tested,             value integer;
attribute items-created,            value integer;
attribute accuracy-before,          value double @range(0.0..1.0);
attribute accuracy-after,           value double @range(0.0..1.0);
attribute improvement-delta,        value double;
attribute cycle-quality,            value string @values("excellent", "good", "average", "poor");


# =============================================================================
# CLASSIFIER FUNCTIONS — replacing 2.x rules
# =============================================================================

# --- Quality band for an applied learning-record ---
#
# Replaces 2.x rules: high-quality-record, medium-quality-record, low-quality-record
# The three rules collapse into one function with a cascading if/else.
#
# The `match` pattern filters to APPLIED records; unapplied records
# will not bind $e, so callers simply won't see a band for them
# (effectively: no label = not-yet-rated).
#
fun record_quality($r: learning-record) -> string:
    match $r has applied true, has effectiveness $e;
    return first
        if ($e >= 0.7)      then "high"
        else if ($e >= 0.4) then "medium"
        else                     "low";


# --- Cascade detection (composed classifier) ---
#
# Replaces 2.x rule: cascade-detected
#
# A record has "cascade potential" if it is high-quality AND its derived
# learnings are also high-quality — evidence that applying it catalyzed
# further high-quality outcomes downstream.
#
# 3.x best practice: compose classifiers inside the match via `let`.
# The planner sees both record_quality calls and can push the filter
# through the chain.
#
fun cascade_sources() -> { learning-record }:
    match
        (source: $src, derived: $der) isa learning-chain;
        let $src_q = record_quality($src);
        let $der_q = record_quality($der);
        $src_q == "high";
        $der_q == "high";
    return { $src };


# --- Cycle quality band ---
#
# Replaces 2.x rules: excellent-cycle, good-cycle, average-cycle, poor-cycle
# Four rules collapse to one function. Cascading if/else guarantees exactly
# one band per cycle — no overlap, no gaps.
#
fun cycle_quality($c: work-cycle) -> string:
    match $c has improvement-delta $d;
    return first
        if ($d >= 0.05) then "excellent"
        else if ($d >= 0.02) then "good"
        else if ($d >= 0.0)  then "average"
        else                      "poor";


# =============================================================================
# USAGE PATTERN A — DERIVED-ON-DEMAND (no materialization)
# =============================================================================
#
# Compute the label at query time. Always correct, zero staleness.
# Use when: writes are frequent, the label is queried by a few callers.
#
# Query "high quality records":
#   match
#       $r isa learning-record;
#       let $q = record_quality($r);
#       $q == "high";
#   select $r;
#
# Group records by quality band:
#   match
#       $r isa learning-record;
#       let $q = record_quality($r);
#   reduce $n = count groupby $q;
#
# Find cascade sources (records that catalyzed high-quality derivations):
#   match let $src = cascade_sources();
#   select $src;
#
# Fetch JSON with computed label embedded:
#   match $r isa learning-record;
#   fetch {
#       "record": $r.record-id,
#       "effectiveness": $r.effectiveness,
#       "band": record_quality($r)
#   };
#
# =============================================================================
# USAGE PATTERN B — MATERIALIZATION PIPELINE
# =============================================================================
#
# Persist the label with a write pipeline. Faster reads, but must be re-run
# whenever the source attributes change.
# Use when: the label is queried heavily, writes are rare.
#
# Materialize record quality:
#   match
#       $r isa learning-record, has applied true;
#       let $q = record_quality($r);
#   insert $r has quality-label $q;
#
# Materialize cycle quality:
#   match
#       $c isa work-cycle;
#       let $q = cycle_quality($c);
#   insert $c has cycle-quality $q;
#
# Materialize cascade-potential flag:
#   match let $src = cascade_sources();
#   insert $src has cascade-potential true;
#
# Staleness rule: always clear previous labels before re-materializing:
#   match $r isa learning-record, has quality-label $q;
#   delete has $q of $r;
#   # ... then re-run the materialization pipeline above.
#
# =============================================================================
# WHEN TO CHOOSE WHICH
# =============================================================================
#
# DERIVED-ON-DEMAND (A):
#   + Always correct (no staleness)
#   + Schema stays thin (no redundant attributes)
#   + Classifier logic has a single source of truth (the `fun` body)
#   − Every query recomputes — cost scales with read frequency
#
# MATERIALIZED (B):
#   + Fast reads by label (indexed attribute lookup)
#   + Suitable for reporting, dashboards, aggregation over labels
#   − Must re-run when source data changes
#   − Duplicate truth (the attribute and the function can disagree)
#
# RULE OF THUMB: start with (A), migrate to (B) only when a profiler shows
# the classifier is a hot path. The function body never changes when you
# switch modes — only how often you write the label.
#
# =============================================================================
