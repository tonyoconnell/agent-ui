# =============================================================================
# LESSON 4 (TypeDB 3.x): Task Management — Negation, Dependencies, Pheromone
# =============================================================================
#
# DIFFICULTY:   Intermediate
# PREREQUISITE: hypothesis-lifecycle.tql (Lesson 3 — state machines)
# NEXT:         contribution-tracking.tql (Lesson 5)
#
# WHAT CHANGED FROM 2.x:
#   - The four trail-status rules (`proven-trail`, `fresh-trail`, `fading-trail`,
#     `dead-trail`) collapse into a single cascading classifier `trail_status()`.
#   - The `attractive-task` and `repelled-task` rules become predicate functions
#     that compose existing classifiers — no stored "attractive"/"repelled"
#     attributes needed if you derive on demand.
#   - The broken `count(filter(...))` in `category_completion` is replaced with
#     two composed count functions and a division — the correct 3.x idiom.
#   - Pheromone reinforcement / alarm / decay are explicit write pipelines
#     (they were always external; the syntax is now cleaner with `update`).
#
# WHAT YOU'LL LEARN:
#   - NEGATION as the ant's test for "ready": task AND NOT blocked.
#   - Composition: `is_attractive` calls `ready_tasks` + `trail_status` —
#     functions stack without the planner losing visibility.
#   - Asymmetric decay: trail pheromone decays 5%/cycle, alarm 20%/cycle —
#     the colony forgets failure sooner than success.
#
# BIOLOGY (Chapter 2 — Task Allocation Without Instructions):
#   Gordon's central discovery: ants allocate themselves using only local
#   information. No ant gives instructions. An ant encounters the colony's
#   state — what tasks are unclaimed, where the pheromone leads — and
#   commits. `ready_tasks()` is the NEGATION pattern: a task is ready iff
#   its blockers are all complete. `attractive_tasks()` layers the
#   colony's memory on top: ready AND on a proven trail.
#
#   The task-allocation system IS the colony's emergent intelligence.
#
#   Reference: https://ants-at-work.com/book/2/
#
# USE CASES:
#   - Project management / issue trackers
#   - Workflow engines / CI pipeline stages
#   - Ant-colony task allocation (this IS the pattern)
#   - Any system that must pick "what to do next" from a graph of options
#
# AFTER LOADING, TEST WITH:
#   match let $t = ready_tasks(); $t has title $title; select $title;
#   match let $t = attractive_tasks(); $t has title $title; select $title;
#   match let $t = exploratory_tasks(); $t has title $title; select $title;
#
# =============================================================================

define

# =============================================================================
# SCHEMA
# =============================================================================
# 3.x best practices demonstrated:
#   - `@values` on status, priority, effort-size, assignee-type, trail-status:
#     domain strings become type-checked enums. Typos fail at write time.
#   - `@range` on importance (1..10), pheromones (0..100), completion (0..1):
#     bounded numerics. Out-of-range values fail at write time.
#   - `@cascade` on relation roles that own the "task" side: deleting a task
#     removes all its dependency/assignment/tag/trail rows without
#     orphaned-relation cleanup logic.

entity task,
    owns task-id @key,
    owns title,
    owns description,
    owns status,
    owns priority,
    owns importance,
    owns estimated-effort,
    owns effort-size,
    owns source-file,
    owns blocked-reason,
    owns created-at,
    owns updated-at,
    owns completed-at,
    plays dependency:dependent,
    plays dependency:blocker,
    plays assignment:assigned-task,
    plays categorization:categorized-task,
    plays milestone-membership:member-task,
    plays tag-association:tagged-task,
    plays pheromone-trail:source-task,
    plays pheromone-trail:destination-task;

entity task-category,
    owns category-id @key,
    owns category-name,
    owns category-description,
    owns parent-category,
    plays categorization:category;

entity milestone,
    owns milestone-id @key,
    owns milestone-name,
    owns milestone-description,
    owns target-date,
    owns completion-percentage,
    owns status,
    plays milestone-membership:milestone;

entity task-tag,
    owns tag-id @key,
    owns tag-name,
    owns tag-color,
    plays tag-association:tag;

entity assignee,
    owns assignee-id @key,
    owns assignee-name,
    owns assignee-type,
    plays assignment:assigned-to;


# --- Attributes (with 3.x best-practice constraints) ---

attribute task-id,                  value string;
attribute title,                    value string;
attribute description,              value string;
attribute status,                   value string @values("todo", "in_progress", "complete", "blocked");
attribute priority,                 value string @values("P0", "P1", "P2", "P3");
attribute importance,               value integer @range(1..10);
attribute estimated-effort,         value integer;
attribute effort-size,              value string @values("micro", "small", "medium", "large");
attribute source-file,              value string;
attribute blocked-reason,           value string;
attribute created-at,               value datetime;
attribute updated-at,               value datetime;
attribute completed-at,             value datetime;

attribute category-id,              value string;
attribute category-name,            value string;
attribute category-description,     value string;
attribute parent-category,          value string;

attribute milestone-id,             value string;
attribute milestone-name,           value string;
attribute milestone-description,    value string;
attribute target-date,              value datetime;
attribute completion-percentage,    value double @range(0.0..1.0);

attribute tag-id,                   value string;
attribute tag-name,                 value string;
attribute tag-color,                value string;

attribute assignee-id,              value string;
attribute assignee-name,            value string;
attribute assignee-type,            value string @values("human", "bot", "team");

# Pheromone attributes — live on EDGES (the `pheromone-trail` relation),
# not on tasks. Task attractiveness is DERIVED, not stored.
attribute trail-pheromone,          value double @range(0.0..100.0);
attribute alarm-pheromone,          value double @range(0.0..100.0);
attribute completions,              value integer;
attribute failures,                 value integer;


# --- Relations (with @cascade where dependent cleanup is natural) ---

relation dependency,
    relates dependent @cascade,     # delete dependent → remove the dependency row
    relates blocker;

relation assignment,
    relates assigned-task @cascade,
    relates assigned-to;

relation categorization,
    relates categorized-task @cascade,
    relates category;

relation milestone-membership,
    relates member-task @cascade,
    relates milestone;

relation tag-association,
    relates tagged-task @cascade,
    relates tag;

# Pheromone trails: deleting EITHER task evaporates the edge.
# The trail is MEANINGLESS without both endpoints.
relation pheromone-trail,
    relates source-task @cascade,
    relates destination-task @cascade,
    owns trail-pheromone,
    owns alarm-pheromone,
    owns completions,
    owns failures;


# =============================================================================
# CLASSIFIER FUNCTIONS (replace 2.x rules)
# =============================================================================

# --- Trail status: four rules collapse into one cascading classifier ---
#
# Replaces 2.x rules: proven-trail, fresh-trail, fading-trail, dead-trail
# Four mutually-exclusive bands resolved by ordered cascade — no overlap
# possible, no gaps possible, evaluation order is visible in source.
#
fun trail_status($trail: pheromone-trail) -> string:
    match $trail has trail-pheromone $tp, has completions $c, has failures $f;
    return first
        if ($tp >= 70.0 and $c >= 10 and $f < $c)   then "proven"
        else if ($tp >= 10.0 and $tp < 70.0 and $c < 10) then "fresh"
        else if ($tp > 0.0 and $tp < 10.0)          then "fading"
        else                                             "dead";


# --- Readiness: the NEGATION pattern ---
#
# A task is ready iff:
#   (1) status = "todo"
#   (2) for every blocker $b, $b has status "complete"
#
# Expressed via double-negation: "NOT (exists a blocker that is NOT complete)".
# This is exactly how an ant asks the colony "is this work unclaimed and
# unblocked?" — by looking for absence, not presence.
#
fun ready_tasks() -> { task }:
    match
        $t isa task, has status "todo";
        not {
            $dep (dependent: $t, blocker: $b) isa dependency;
            $b isa task, has status $bs;
            not { $bs == "complete"; };
        };
    return { $t };


# --- Single-task readiness classifier (yes/no for one task) ---
fun is_ready($t: task) -> boolean:
    match
        $t has status "todo";
        not {
            $dep (dependent: $t, blocker: $b) isa dependency;
            $b isa task, has status $bs;
            not { $bs == "complete"; };
        };
    return first true;


# --- Attractiveness: ready + strong incoming trail (composition) ---
#
# Replaces 2.x rule: attractive-task
#
# Composition matters here. `attractive_tasks()` calls `ready_tasks()` via
# subquery unification — the planner sees both constraint sets and can push
# the trail lookup into the ready filter or vice-versa. No attribute is
# materialized; the pattern IS the type.
#
fun attractive_tasks() -> { task }:
    match
        $t isa task;
        $t == ready_tasks();                         # readiness constraint
        $trail (destination-task: $t) isa pheromone-trail,
            has trail-pheromone $tp;
        $tp >= 50.0;
    return { $t };


# --- Repulsion: ready + alarm dominates trail ---
#
# Replaces 2.x rule: repelled-task
#
fun repelled_tasks() -> { task }:
    match
        $t isa task;
        $t == ready_tasks();
        $trail (destination-task: $t) isa pheromone-trail,
            has alarm-pheromone $ap, has trail-pheromone $tp;
        $ap >= 30.0;
        $ap > $tp;
    return { $t };


# --- Exploratory: ready + NO incoming trail exists ---
#
# The scout's query: "find me work the colony has never tried". In real ant
# colonies, 5–10% of foragers are scouts who ignore pheromone and search
# at random. This function is the SQL for "give me the random-search set".
#
fun exploratory_tasks() -> { task }:
    match
        $t isa task;
        $t == ready_tasks();
        not { ($trail (destination-task: $t)) isa pheromone-trail; };
    return { $t };


# =============================================================================
# QUERY FUNCTIONS (projections, lookups, aggregates)
# =============================================================================

# --- Simple partitions by attribute ---

fun tasks_by_priority($p: string) -> { task }:
    match $t isa task, has priority $p;
    return { $t };

fun tasks_by_status($s: string) -> { task }:
    match $t isa task, has status $s;
    return { $t };

fun blocked_tasks() -> { task }:
    match $t isa task, has status "blocked";
    return { $t };

fun urgent_tasks() -> { task }:
    match
        $t isa task, has priority $p, has status $s;
        $p in ["P0", "P1"];
        not { $s == "complete"; };
    return { $t };

fun high_importance_tasks($threshold: integer) -> { task }:
    match
        $t isa task, has importance $imp;
        $imp >= $threshold;
    return { $t };


# --- Dependency navigation ---

fun blockers_of($task_id: string) -> { task }:
    match
        $dependent isa task, has task-id $task_id;
        $dep (dependent: $dependent, blocker: $blocker) isa dependency;
        $blocker isa task;
    return { $blocker };

fun dependents_of($blocker_id: string) -> { task }:
    match
        $blocker isa task, has task-id $blocker_id;
        $dep (dependent: $dependent, blocker: $blocker) isa dependency;
        $dependent isa task;
    return { $dependent };


# --- Relation-based partitions (category, milestone, tag, assignee) ---

fun tasks_by_category($cat_name: string) -> { task }:
    match
        $cat isa task-category, has category-name $cat_name;
        $rel (categorized-task: $t, category: $cat) isa categorization;
    return { $t };

fun tasks_by_milestone($ms_name: string) -> { task }:
    match
        $ms isa milestone, has milestone-name $ms_name;
        $rel (member-task: $t, milestone: $ms) isa milestone-membership;
    return { $t };

fun tasks_by_tag($tag_name: string) -> { task }:
    match
        $tag isa task-tag, has tag-name $tag_name;
        $rel (tagged-task: $t, tag: $tag) isa tag-association;
    return { $t };

fun tasks_by_assignee($name: string) -> { task }:
    match
        $a isa assignee, has assignee-name $name;
        $rel (assigned-task: $t, assigned-to: $a) isa assignment;
    return { $t };


# --- Aggregates ---

fun count_by_status($s: string) -> integer:
    match $t isa task, has status $s;
    return count($t);

fun count_by_priority($p: string) -> integer:
    match $t isa task, has priority $p;
    return count($t);

# Count of complete tasks in a category (helper for completion rate)
fun complete_in_category($cat_name: string) -> integer:
    match
        $cat isa task-category, has category-name $cat_name;
        $rel (categorized-task: $t, category: $cat) isa categorization;
        $t has status "complete";
    return count($t);

# Count of all tasks in a category
fun total_in_category($cat_name: string) -> integer:
    match
        $cat isa task-category, has category-name $cat_name;
        $rel (categorized-task: $t, category: $cat) isa categorization;
    return count($t);

# Category completion rate = complete / total
# 3.x pattern: compose scalars via `let`. The broken 2.x
# `count(filter(...))` is replaced with two counts and a division.
fun category_completion($cat_name: string) -> double:
    match
        let $done  = complete_in_category($cat_name);
        let $total = total_in_category($cat_name);
        $total > 0;                                  # guard against div-by-zero
    return first $done / $total;


# --- Trail inspection ---

fun trail_strength($from_id: string, $to_id: string) -> double:
    match
        $from isa task, has task-id $from_id;
        $to   isa task, has task-id $to_id;
        $trail (source-task: $from, destination-task: $to) isa pheromone-trail,
            has trail-pheromone $tp;
    return first $tp;

fun superhighway_trails() -> { pheromone-trail }:
    match
        $trail isa pheromone-trail;
        let $status = trail_status($trail);
        $status == "proven";
    return { $trail };

fun fading_trails() -> { pheromone-trail }:
    match
        $trail isa pheromone-trail;
        let $status = trail_status($trail);
        $status == "fading";
    return { $trail };


# =============================================================================
# PHEROMONE OPERATIONS — WRITE PIPELINES
# =============================================================================
#
# These are explicit 3.x write pipelines. Run them from application code on
# task completion, task failure, or on a decay schedule.
#
# --- Reinforcement (task A → task B completed successfully) ---
#
#   match
#     $from isa task, has task-id "TASK-A";
#     $to   isa task, has task-id "TASK-B";
#     $trail (source-task: $from, destination-task: $to) isa pheromone-trail,
#         has trail-pheromone $old_tp, has completions $old_c;
#     let $new_tp = $old_tp + 5.0;
#     let $new_c  = $old_c + 1;
#   update $trail has trail-pheromone $new_tp, has completions $new_c;
#
# --- Alarm deposit (task A → task B failed) ---
#
#   match
#     $trail (source-task: $from, destination-task: $to) isa pheromone-trail,
#         has alarm-pheromone $old_ap, has failures $old_f;
#     let $new_ap = $old_ap + 8.0;
#     let $new_f  = $old_f + 1;
#   update $trail has alarm-pheromone $new_ap, has failures $new_f;
#
# --- Decay (run on a cron — forgetting is intelligence) ---
#
# Asymmetric: trail decays slower than alarm. The colony forgets failure
# sooner than success, so alarmed edges get retried after conditions change.
# This matches real ant chemistry — alarm pheromones are volatile.
#
#   match
#     $trail isa pheromone-trail,
#         has trail-pheromone $old_tp, has alarm-pheromone $old_ap;
#     let $new_tp = $old_tp * 0.95;               # 5%/cycle decay
#     let $new_ap = $old_ap * 0.80;               # 20%/cycle decay
#   update $trail has trail-pheromone $new_tp, has alarm-pheromone $new_ap;
#
# Note: `update` replaces @card(1) attributes atomically. If your TypeDB
# version of these attributes is multi-cardinality, use
#   delete has $old_tp of $trail;
#   insert $trail has trail-pheromone $new_tp;
# instead.
#
# =============================================================================
# USAGE
# =============================================================================
#
# Get all ready tasks:
#   match let $t = ready_tasks();  $t has title $title; select $title;
#
# Get attractive tasks (ready + strong incoming trail):
#   match let $t = attractive_tasks(); $t has title $title; select $title;
#
# Get exploratory tasks (ready + no trail — scout's list):
#   match let $t = exploratory_tasks(); $t has title $title; select $title;
#
# Find superhighways (proven trails):
#   match let $trail = superhighway_trails();
#     (source-task: $from, destination-task: $to) isa $trail;
#     $from has title $from_t;
#     $to   has title $to_t;
#   select $from_t, $to_t;
#
# Category completion rate:
#   match let $pct = category_completion("Backend");
#   select $pct;
#
# Is a specific task ready?
#   match
#     $t isa task, has task-id "TASK-42";
#     let $ready = is_ready($t);
#   select $t;
#
# =============================================================================
