# =============================================================================
# LAUNCHPAD.TQL - Token Launch Intelligence Layer
# =============================================================================
#
# Extends genesis.tql with Fetch Launchpad-specific entities.
# Provides automatic inference for token quality, graduation prediction,
# and entry zone classification.
#
# USAGE:
#   typedb console
#   > transaction ants-colony schema write
#   > source launchpad.tql
#   > commit
#
# NOTE: This is the "complex" approach. For most use cases, the simpler
# fetch_scout.py is sufficient. Only use this if you need:
#   - Complex relational queries across tokens/trails/observations
#   - Automatic inference rules firing on insert
#   - Integration with existing genesis.tql colony infrastructure
#
# VERSION: 1.0.0
# TYPEDB: 3.0+ ONLY
#
# =============================================================================

define


# =============================================================================
# SECTION 1: TOKEN ENTITY
# =============================================================================
#
# Represents a token on the Fetch Launchpad bonding curve.
# Tracks both on-chain metrics and inferred quality scores.

entity token,
    owns token-address @key,
    owns token-name,
    owns token-symbol,
    owns creator-address,
    owns total-fet-bought,          # Progress toward 30,000 FET
    owns graduation-threshold,      # 30,000 FET (configurable)
    owns holder-count,
    owns unique-buyers,
    owns volume-24h,
    owns velocity,                  # FET/hour
    owns velocity-acceleration,     # Is velocity increasing?
    owns buy-sell-ratio,
    owns top-10-concentration,      # % held by top 10 wallets
    owns social-score,              # Off-chain signals (Twitter, Discord)
    owns creator-history-score,     # Past launches success rate
    owns quality-score,             # INFERRED: 0-100
    owns graduation-probability,    # INFERRED: 0.0-1.0
    owns graduation-eta-hours,      # INFERRED: estimated time to graduate
    owns token-status,              # "bonding", "graduating", "graduated", "failed"
    owns created-at,
    owns graduated-at,
    plays token-trail:source-token,
    plays token-trail:destination-token,
    plays token-observation-rel:observed-token;

attribute token-address, value string;
attribute token-name, value string;
attribute token-symbol, value string;
attribute creator-address, value string;
attribute total-fet-bought, value double;
attribute graduation-threshold, value double;
attribute holder-count, value integer;
attribute unique-buyers, value integer;
attribute volume-24h, value double;
attribute velocity, value double;
attribute velocity-acceleration, value double;
attribute buy-sell-ratio, value double;
attribute top-10-concentration, value double;
attribute social-score, value double;
attribute creator-history-score, value double;
attribute quality-score, value integer;
attribute graduation-probability, value double;
attribute graduation-eta-hours, value double;
attribute token-status, value string;
attribute graduated-at, value datetime;


# =============================================================================
# SECTION 2: TOKEN OBSERVATIONS (Pheromone Deposits)
# =============================================================================
#
# Observations are pheromone deposits from scout agents.
# Each observation represents a signal detected at a point in time.
# Multiple observations on the same token = convergence.

entity token-observation,
    owns observation-id @key,
    owns observation-type,          # "volume_spike", "whale_entry", "holder_growth", "social_surge"
    owns signal-strength,           # 0-100
    owns observer-agent-id,         # Which agent made this observation
    owns observed-at,
    owns observation-data,          # JSON context (additional metadata)
    plays token-observation-rel:observation;

relation token-observation-rel,
    relates observed-token,
    relates observation;

attribute observation-id, value string;
attribute observation-type, value string;
attribute signal-strength, value double;
attribute observer-agent-id, value string;
attribute observation-data, value string;


# =============================================================================
# SECTION 3: TOKEN TRAILS (Entry -> Outcome)
# =============================================================================
#
# Trails record historical entry points and their outcomes.
# Successful entries reinforce trail pheromone.
# Failed entries deposit alarm pheromone.
# Over time, optimal entry zones emerge as superhighways.

relation token-trail,
    relates source-token,           # The token (entry state)
    relates destination-token,      # Same token (exit state)
    owns entry-percentage,          # Where on bonding curve (0-100)
    owns exit-percentage,           # Where exited (or 100 if graduated)
    owns profit-percentage,         # Outcome: (exit - entry) / entry * 100
    owns trail-pheromone,           # Reinforced on success (0-100)
    owns alarm-pheromone,           # Deposited on loss (0-100)
    owns entry-count,               # Times entered at this zone
    owns success-count,             # Times profitable
    owns trail-status;              # INFERRED: "optimal", "good", "risky", "avoid"

attribute entry-percentage, value double;
attribute exit-percentage, value double;
attribute profit-percentage, value double;
attribute entry-count, value integer;
attribute success-count, value integer;
# trail-pheromone and alarm-pheromone already defined in genesis.tql


# =============================================================================
# SECTION 4: INFERENCE RULES - Quality Classification
# =============================================================================

# High quality token: strong on-chain + off-chain signals
# Criteria: 50+ unique buyers, 2:1+ buy/sell, <30% concentration, social presence
rule high-quality-token:
    when {
        $t isa token,
            has unique-buyers $ub,
            has buy-sell-ratio $bsr,
            has top-10-concentration $conc,
            has social-score $ss,
            has creator-history-score $chs;
        $ub >= 50;
        $bsr >= 2.0;
        $conc <= 30.0;
        $ss >= 60.0;
        $chs >= 0.6;
    } then {
        $t has quality-score 85;
    };

# Medium quality token: decent fundamentals but mixed signals
rule medium-quality-token:
    when {
        $t isa token,
            has unique-buyers $ub,
            has buy-sell-ratio $bsr,
            has top-10-concentration $conc;
        $ub >= 20;
        $ub < 50;
        $bsr >= 1.5;
        $conc <= 50.0;
    } then {
        $t has quality-score 60;
    };

# Low quality token: warning signs present
rule low-quality-token:
    when {
        $t isa token,
            has top-10-concentration $conc,
            has buy-sell-ratio $bsr;
        { $conc >= 50.0; } or { $bsr < 1.0; };
    } then {
        $t has quality-score 30;
    };


# =============================================================================
# SECTION 5: INFERENCE RULES - Graduation Prediction
# =============================================================================

# High graduation probability: strong velocity + distribution + progress
rule high-graduation-probability:
    when {
        $t isa token,
            has total-fet-bought $tfb,
            has graduation-threshold $gt,
            has velocity $v,
            has unique-buyers $ub;
        $gt > 0.0;
        $progress = $tfb / $gt;
        $progress >= 0.5;
        $v >= 500.0;           # 500+ FET/hour = strong momentum
        $ub >= 50;
    } then {
        $t has graduation-probability 0.85;
    };

# Medium graduation probability: decent metrics
rule medium-graduation-probability:
    when {
        $t isa token,
            has total-fet-bought $tfb,
            has graduation-threshold $gt,
            has velocity $v,
            has unique-buyers $ub;
        $gt > 0.0;
        $progress = $tfb / $gt;
        $progress >= 0.3;
        $v >= 100.0;
        $ub >= 20;
    } then {
        $t has graduation-probability 0.55;
    };

# Low graduation probability: early stage or weak momentum
rule low-graduation-probability:
    when {
        $t isa token,
            has total-fet-bought $tfb,
            has graduation-threshold $gt,
            has velocity $v;
        $gt > 0.0;
        $progress = $tfb / $gt;
        $progress < 0.3;
        $v < 100.0;
    } then {
        $t has graduation-probability 0.25;
    };


# =============================================================================
# SECTION 6: INFERENCE RULES - Entry Zone Classification
# =============================================================================

# Optimal entry zone: historically profitable, many successes
rule optimal-entry-zone:
    when {
        $trail isa token-trail,
            has entry-percentage $ep,
            has profit-percentage $pp,
            has success-count $sc,
            has entry-count $ec;
        $ep >= 15.0;
        $ep <= 25.0;
        $pp >= 100.0;          # 100%+ avg profit
        $sc >= 10;
        $ec > 0;
        $success_rate = $sc / $ec;
        $success_rate >= 0.7;
    } then {
        $trail has trail-status "optimal";
    };

# Good entry zone: profitable but less proven
rule good-entry-zone:
    when {
        $trail isa token-trail,
            has entry-percentage $ep,
            has profit-percentage $pp,
            has success-count $sc,
            has entry-count $ec;
        $ep >= 10.0;
        $ep <= 35.0;
        $pp >= 50.0;
        $ec > 0;
        $success_rate = $sc / $ec;
        $success_rate >= 0.5;
    } then {
        $trail has trail-status "good";
    };

# Risky entry zone: early entries with high failure rate
rule risky-entry-zone:
    when {
        $trail isa token-trail,
            has entry-percentage $ep,
            has success-count $sc,
            has entry-count $ec;
        $ep < 15.0;
        $ec >= 5;
        $success_rate = $sc / $ec;
        $success_rate < 0.5;
    } then {
        $trail has trail-status "risky";
    };

# Avoid zone: alarm pheromone dominates
rule avoid-entry-zone:
    when {
        $trail isa token-trail,
            has alarm-pheromone $ap,
            has trail-pheromone $tp;
        $ap >= 30.0;
        $ap > $tp;
    } then {
        $trail has trail-status "avoid";
    };


# =============================================================================
# SECTION 7: QUERY FUNCTIONS
# =============================================================================

# -----------------------------------------------------------------------------
# Token Discovery Functions
# -----------------------------------------------------------------------------

# Tokens likely to graduate (high probability, still bonding)
fun graduating_tokens() -> { token }:
    match
        $t isa token,
            has graduation-probability $gp,
            has token-status "bonding";
        $gp >= 0.7;
    return { $t };

# High-quality tokens currently in optimal entry zone
fun alpha_opportunities() -> { token }:
    match
        $t isa token,
            has quality-score $qs,
            has total-fet-bought $tfb,
            has graduation-threshold $gt,
            has token-status "bonding";
        $gt > 0.0;
        $qs >= 75;
        $progress = $tfb / $gt;
        $progress >= 0.15;
        $progress <= 0.30;
    return { $t };

# All tokens by status
fun tokens_by_status($status: string) -> { token }:
    match
        $t isa token,
            has token-status $status;
    return { $t };

# Tokens by minimum quality score
fun quality_tokens($min_score: integer) -> { token }:
    match
        $t isa token,
            has quality-score $qs;
        $qs >= $min_score;
    return { $t };


# -----------------------------------------------------------------------------
# Convergence Detection Functions
# -----------------------------------------------------------------------------

# Count observations for a token
fun observation_count($token_addr: string) -> integer:
    match
        $t isa token, has token-address $token_addr;
        $rel (observed-token: $t, observation: $o) isa token-observation-rel;
    return count($o);

# Get all observations for a token
fun token_observations($token_addr: string) -> { token-observation }:
    match
        $t isa token, has token-address $token_addr;
        $rel (observed-token: $t, observation: $o) isa token-observation-rel;
    return { $o };

# Observations by type
fun observations_by_type($type: string) -> { token-observation }:
    match
        $o isa token-observation,
            has observation-type $type;
    return { $o };

# Strong observations (signal strength >= threshold)
fun strong_observations($threshold: double) -> { token-observation }:
    match
        $o isa token-observation,
            has signal-strength $s;
        $s >= $threshold;
    return { $o };


# -----------------------------------------------------------------------------
# Trail Analysis Functions
# -----------------------------------------------------------------------------

# Optimal entry trails (superhighways)
fun optimal_entries() -> { token-trail }:
    match
        $trail isa token-trail,
            has trail-status "optimal";
    return { $trail };

# Trails to avoid (alarm pheromone high)
fun avoid_entries() -> { token-trail }:
    match
        $trail isa token-trail,
            has trail-status "avoid";
    return { $trail };

# Average profit at a given entry percentage range
fun avg_profit_at_entry($min_pct: double, $max_pct: double) -> double:
    match
        $trail isa token-trail,
            has entry-percentage $ep,
            has profit-percentage $pp;
        $ep >= $min_pct;
        $ep <= $max_pct;
    return avg($pp);

# Success rate at a given entry percentage range
fun success_rate_at_entry($min_pct: double, $max_pct: double) -> double:
    match
        $trail isa token-trail,
            has entry-percentage $ep,
            has success-count $sc,
            has entry-count $ec;
        $ep >= $min_pct;
        $ep <= $max_pct;
        $ec > 0;
    return sum($sc) / sum($ec);


# -----------------------------------------------------------------------------
# Analytics Functions
# -----------------------------------------------------------------------------

# Count tokens by status
fun count_tokens_by_status($status: string) -> integer:
    match
        $t isa token,
            has token-status $status;
    return count($t);

# Average velocity of graduating tokens
fun avg_graduating_velocity() -> double:
    match
        $t isa token,
            has graduation-probability $gp,
            has velocity $v;
        $gp >= 0.7;
    return avg($v);

# Total volume across all tokens
fun total_volume_24h() -> double:
    match
        $t isa token,
            has volume-24h $v;
    return sum($v);


# =============================================================================
# END OF LAUNCHPAD SCHEMA
# =============================================================================
#
# USAGE EXAMPLES:
#
# 1. Find alpha opportunities:
#    match let $t in alpha_opportunities();
#    $t has token-symbol $sym, has quality-score $qs;
#    select $sym, $qs;
#
# 2. Check convergence on a token:
#    match let $count = observation_count("0x123...");
#    select $count;
#
# 3. Find optimal entry zones:
#    match let $trail in optimal_entries();
#    $trail has entry-percentage $ep, has profit-percentage $pp;
#    select $ep, $pp;
#
# 4. Insert an observation (pheromone deposit):
#    insert
#        $obs isa token-observation,
#            has observation-id "obs-001",
#            has observation-type "volume_spike",
#            has signal-strength 75.0,
#            has observer-agent-id "scout-001",
#            has observed-at 2024-01-15T10:30:00;
#        $t isa token, has token-address "0x123...";
#        (observed-token: $t, observation: $obs) isa token-observation-rel;
#
# =============================================================================
