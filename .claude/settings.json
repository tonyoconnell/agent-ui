{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(bun *)",
      "Bash(bunx *)",
      "Bash(npm run *)",
      "Bash(npx vitest *)",
      "Bash(npx biome *)",
      "Bash(npx tsc *)",
      "Bash(ls *)",
      "Bash(git *)"
    ]
  },
  "rules": {
    "auto-load": {
      "*.astro": ["rules/astro.md"],
      "*.tsx": ["rules/react.md"],
      "src/engine/**/*.ts": ["rules/engine.md"]
    }
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/post-edit-check.sh",
            "timeout": 15000
          }
        ]
      }
    ]
  }
}
