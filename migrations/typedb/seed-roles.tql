# seed-roles.tql — Seed the role-grant permission matrix into TypeDB.
# Source of truth: src/lib/role-check.ts PERMISSIONS constant.
# Run: once after schema migration adds the role-grant entity.
# Re-run is idempotent: match-not guards prevent duplicate inserts.
#
# chairman — all 17 actions
# ceo      — 16 actions (no appoint_role)
# operator — 9 actions
# board    — 5 actions (read-only)
# auditor  — 5 actions (read-only)
# agent    — 3 actions (mark/warn/discover)

define

# --- chairman ---

insert $rg isa role-grant, has rg-id "rg:chairman:add_unit",
  has governance-role "chairman", has role-action "add_unit";
insert $rg isa role-grant, has rg-id "rg:chairman:remove_unit",
  has governance-role "chairman", has role-action "remove_unit";
insert $rg isa role-grant, has rg-id "rg:chairman:mark",
  has governance-role "chairman", has role-action "mark";
insert $rg isa role-grant, has rg-id "rg:chairman:warn",
  has governance-role "chairman", has role-action "warn";
insert $rg isa role-grant, has rg-id "rg:chairman:tune_sensitivity",
  has governance-role "chairman", has role-action "tune_sensitivity";
insert $rg isa role-grant, has rg-id "rg:chairman:read_highways",
  has governance-role "chairman", has role-action "read_highways";
insert $rg isa role-grant, has rg-id "rg:chairman:read_revenue",
  has governance-role "chairman", has role-action "read_revenue";
insert $rg isa role-grant, has rg-id "rg:chairman:read_toxic",
  has governance-role "chairman", has role-action "read_toxic";
insert $rg isa role-grant, has rg-id "rg:chairman:appoint_role",
  has governance-role "chairman", has role-action "appoint_role";
insert $rg isa role-grant, has rg-id "rg:chairman:read_memory",
  has governance-role "chairman", has role-action "read_memory";
insert $rg isa role-grant, has rg-id "rg:chairman:delete_memory",
  has governance-role "chairman", has role-action "delete_memory";
insert $rg isa role-grant, has rg-id "rg:chairman:discover",
  has governance-role "chairman", has role-action "discover";
insert $rg isa role-grant, has rg-id "rg:chairman:create_group",
  has governance-role "chairman", has role-action "create_group";
insert $rg isa role-grant, has rg-id "rg:chairman:update_group",
  has governance-role "chairman", has role-action "update_group";
insert $rg isa role-grant, has rg-id "rg:chairman:delete_group",
  has governance-role "chairman", has role-action "delete_group";
insert $rg isa role-grant, has rg-id "rg:chairman:invite_member",
  has governance-role "chairman", has role-action "invite_member";
insert $rg isa role-grant, has rg-id "rg:chairman:change_role",
  has governance-role "chairman", has role-action "change_role";

