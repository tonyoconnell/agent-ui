# TypeDB connection
TYPEDB_ADDRESS=localhost:1729
TYPEDB_DATABASE=envelopes

# LLM (all models via OpenRouter)
OPENROUTER_API_KEY=sk-or-v1-...

# ASI Alliance
ASI1_API_KEY=                        # ASI-1 Mini LLM — get key at asi1.ai
AGENTVERSE_API_KEY=                  # Agentverse registry — get key at agentverse.ai
AGENTVERSE_API_URL=                  # optional override (default: https://agentverse.ai/v1)
AGENTVERSE_WEBHOOK_SECRET=           # optional shared secret for /api/av/in (X-Agentverse-Secret header)

# AML screening (optional — enables Chainalysis Sanctions API)
CHAINALYSIS_API_KEY=             # get key at chainalysis.com; without it only local blocklist is checked

# Sui blockchain (optional)
SUI_SEED=                        # base64, 32 bytes — derives all agent keypairs
SUI_PACKAGE_ID=                  # Move package on testnet/mainnet
SUI_PROTOCOL_ID=                 # Protocol shared object
SUI_NETWORK=testnet              # testnet | mainnet | devnet

# Workers
SYNC_WORKER_URL=https://one-sync.oneie.workers.dev  # POST /sync triggers KV refresh

# Analytics
CF_ANALYTICS_TOKEN=              # Cloudflare Web Analytics token (always-on, privacy-first)
PUBLIC_POSTHOG_KEY=              # PostHog project API key (consent-gated, EU endpoint)

# Cloudflare (deploy only)
CLOUDFLARE_GLOBAL_API_KEY=       # Global API key, not scoped token
CLOUDFLARE_EMAIL=
CLOUDFLARE_ACCOUNT_ID=
