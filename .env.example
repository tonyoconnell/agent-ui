# TypeDB connection
TYPEDB_ADDRESS=localhost:1729
TYPEDB_DATABASE=envelopes

# LLM (all models via OpenRouter)
OPENROUTER_API_KEY=sk-or-v1-...

# Sui blockchain (optional)
SUI_SEED=                        # base64, 32 bytes — derives all agent keypairs
SUI_PACKAGE_ID=                  # Move package on testnet/mainnet
SUI_PROTOCOL_ID=                 # Protocol shared object
SUI_NETWORK=testnet              # testnet | mainnet | devnet

# Workers
SYNC_WORKER_URL=https://one-sync.oneie.workers.dev  # POST /sync triggers KV refresh

# Cloudflare (deploy only)
CLOUDFLARE_GLOBAL_API_KEY=       # Global API key, not scoped token
CLOUDFLARE_EMAIL=
CLOUDFLARE_ACCOUNT_ID=
